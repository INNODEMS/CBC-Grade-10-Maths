<stack-static>
    <statement><p><p>
Expand and simplify:
</p>

<p>
<me>
(x + {12})^2
</me>
</p>

<p>
<fillin characters="15" name="ans1"/>  
</p></p></statement>
    <solution><p><h3>Worked Solution</h3>

<p>
<me>
(x + {12})^2 = (x + {12})(x + {12})
</me>
</p>

<p>
Multiply each term:
</p>

<p>
<me>
x(x + {12}) + {12}(x + {12})
</me>
</p>

<p>
<me>
= x^2 + {12}x + {12}x + {144}
</me>
</p>

<p>
Combine like terms:
</p>

<p>
<me>
= x^2 + {24}x + {144}
</me>
</p></p></solution>
    <answer><p><m>x^2+24 x+144</m></p></answer>
</stack-static>