<stack-static>
    <statement><p><p>
Given that:
<me>
\log a = {3}, \quad \log b = {1}
</me>
</p>

<p>
Find 
<me>
\log (ab)
</me>
</p>

<p>
<fillin characters="8" name="ans1"/>  
</p></p></statement>
    <solution><p><h3>Worked Solution</h3>

<p>
We use the product rule of logarithms:
</p>

<p>
<me>
\log(ab) = \log a + \log b
</me>
</p>

<p>
Substitute the values:
</p>

<p>
<me>
= {3} + {1}
</me>
</p>

<p>
<me>
= {4}
</me>
</p></p></solution>
    <answer><p><m>4</m></p></answer>
</stack-static>