<stack-static>
    <statement><p><p>
Find the antilogarithm of:
<me>
{1}
</me>
</p>

<p>
<fillin characters="15" name="ans1"/>  
</p></p></statement>
    <solution><p><h3>Worked Solution</h3>

<p>
The antilogarithm means raising 10 to the given number.
</p>

<p>
<me>
\text{antilog}({1}) = 10^{1}
</me>
</p>

<p>
<me>
= {10}
</me>
</p></p></solution>
    <answer><p><m>10</m></p></answer>
</stack-static>