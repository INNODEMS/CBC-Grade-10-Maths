        </dl>
    </axiom>

    <exercises xml:id="exercises-Speed">
        <exercise xml:id="auto_hjaza2qh">
            <statement>
                <p xml:id="auto_cqistlch">
                    Juma cycled for <m>3</m> hours to a trading centre <m>60</m> km away, then drove <m>250 \,</m>km in a van at 
                    <m>50 \,</m> km/h and finally cycled home at <m>20 \,</m> km/h. Find the average speed for the whole journey.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_r0vy11o6">
                    <m>\text{Average speed} = \frac{60 + 250 + 60}{3 + \frac{250}{50} + \frac{60}{20}}  </m>
                </p>
                <p xml:id="auto_wmbqar48">
                    <m>= \frac{370}{11} \, \text{km/h}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_uc8dmle5">
            <statement>
                <p xml:id="auto_xp9iompd">
                    If a sprinter runs <m>100 \text{ m}</m> in <m>10 \text{ seconds}</m>, what is his average velocity?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_g4rbnuaa">
                    <m>10 \, \text{m/s}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_3d52cgvq">
            <statement>
                <p xml:id="auto_swaojzen">
                    Sarah is rushing to school. She walks the first <m>500 \text{ meters} \,</m> at <m> 5 \, \text{km/h}</m>, 
                    realizing she's late, she then sprints the next <m>300 \text{ meters} \,</m> at <m> 10 \, \text{km/h}</m>
                    What was her average speed for the entire trip to school?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_g2weblqv">
                    <m>\text{Average speed} = \frac{0.5 + 0.3}{\frac{0.5}{5} + \frac{0.3}{10}}  </m>
                </p>
                <p xml:id="auto_2nnzg3ev">
                    <m> = \frac{80}{13} \ \, \text{km/h}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_l96kt4t4">
                <statement>
                    <p xml:id="auto_to3840sl">
                        The world record for the men's marathon is <m>2:03:38</m>.
                         If the distance is <m>42.195 \, \text{km}</m>, what is the average velocity during the run?
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_vrlfdqpg">
                        <m>5.69 \, \text{m/s}</m>
                    </p>
                </answer>
            </exercise>
        <exercise xml:id="auto_pe6bdxnx">
            <statement>
                <p xml:id="auto_c9a9yedp">
                    John walks to the store, a distance of <m>1 \, \text{km}</m>, at a speed of <m>4 \, \text{km/hr}</m>. He spends <m>15 \, \text{minutes}</m> at the store, and then walks back at <m>5 \, \text{km/hr}</m>. 
                    What was John's average speed for the entire trip, including the time spent at the store
                </p>
            </statement>
            <answer>
                <p xml:id="auto_3eli3t73">
                    <m>\text{Average speed} = \frac{1 + 1}{\frac{1}{4} + \frac{1}{5} + \frac{15}{60}}  </m>
                </p>
                <p xml:id="auto_99qzu1il">
                    <m>= \frac{20}{7} \ \, \text{km/h}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_kd0szga7">
            <statement>
                <p xml:id="auto_2mdzdtbb">
                    A hiker covered <m>12 \,\text{ km in}\, 3\, \text{ hours}</m>. After taking a <m>15 \, \text{ minute}</m> break, 
                    what speed must the hiker maintain to reach their destination within a total travel time of <m>4 \, \text{ hours}</m>?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_fut53orw">
                    <m>\text{Required speed} = \frac{12 \text{ km}}{4 \text{ hours} - 3 \text{ hours} - \frac{15 }{60} \text{hours}}  </m>
                </p>
                <p xml:id="auto_2vpunfyk">
                    <m> = 16 \, \text{km/h}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_71dhkg09">
            <statement>
                <p xml:id="auto_mdw1o0po">
                    A runner completed <m>10 \, \text{ km in} 1.5 \, \text{ hours}</m>.
                    After a <m>\text{5 minute}</m> rest, what pace does the runner need to maintain to finish a total distance within <m>\text{2 hours}</m>?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_2xz94oy2">
                    <m>\text{Required pace} = \frac{10 \text{ km}}{2 \text{ hours} - 1.5 \text{ hours} - \frac{5}{60} \text{hours}}</m>
                </p>
                <p xml:id="auto_gs0f2a1e">
                    <m>= 24 \, \text{km/h}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_601brggg">
            <statement>
            <p xml:id="auto_u99zyb3e">
                A train journey consisted of three segments. The train traveled for <m>3 \text{ hours at} \, 90 \text{ km/h}</m>, then paused for <m>0.75 \text{ hours}</m> at a station,
                and finally continued for <m>2 \text{ hours at} \, 70 \text{ km/h}</m>.
                What was the average speed of the train for the entire journey?
            </p>
            </statement>
            <answer>
                <p xml:id="auto_29lxs5vn">
                    <m>\text{Average speed} = \frac{(3 \times 90) + (2 \times 70)}{3 + 0.75 + 2}  </m>
                </p>
                <p xml:id="auto_zztd5a1i">
                    <m>= \frac{1640}{23} \, \text{km/h}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_t1z8fxvv">
            <statement>
                <p xml:id="auto_l593338k">
                    A sailboat is traveling north at <m>10 \, \text{km/h}</m>, relative to the water. The water is flowing north at <m>5 \, \text{km/h}</m>. 
                    What is the velocity of the boat relative to ground? 
                </p>
            </statement>
            <answer>
                <p xml:id="auto_s4xvw1ia">
                    <m>15 \, \text{km/h}</m>
                </p>
            </answer>
        </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation Strategies</title>
        <p xml:id="auto_xcmuobtp">
            <alert>For Struggling Learners:</alert>
            <ul>
                <li xml:id="auto_6hxg5gyv"><p xml:id="auto_ggcgnfd1">Provide formula sheets with speed and velocity formulas clearly displayed.</p></li>
                <li xml:id="auto_pxvruin4"><p xml:id="auto_3m4l66hw">Use physical demonstrations (rolling a ball, walking) to connect formulas to real motion.</p></li>
                <li xml:id="auto_vjas128i"><p xml:id="auto_3lklma4p">Allow use of calculators for all calculations.</p></li>
                <li xml:id="auto_rhnmgqrm"><p xml:id="auto_lowlu47e">Break down multi-segment journey problems into smaller steps.</p></li>
                <li xml:id="auto_9xrocpg7"><p xml:id="auto_1od8g0vi">Pair with peer tutors during practice.</p></li>
            </ul>
        </p>
        <p xml:id="auto_sqvy3fd8">
            <alert>For On-Level Learners:</alert>
            <ul>
                <li xml:id="auto_lmh747ts"><p xml:id="auto_1mk4jl4y">Encourage students to explain the difference between speed and velocity in their own words.</p></li>
                <li xml:id="auto_lqph7fi4"><p xml:id="auto_4wmwabzi">Provide mixed practice with single and multi-segment journeys.</p></li>
                <li xml:id="auto_f8sjfm3p"><p xml:id="auto_55kvidzi">Ask students to convert between units (km/h to m/s).</p></li>
            </ul>
        </p>
        <p xml:id="auto_p81jgtjk">
            <alert>For Advanced Learners:</alert>
            <ul>
                <li xml:id="auto_9gg76usk"><p xml:id="auto_seluoblk">Explore problems involving relative velocity.</p></li>
                <li xml:id="auto_1kxgc9m8"><p xml:id="auto_wprb5uwz">Challenge with journeys that require unit conversion between km/h and m/s.</p></li>
                <li xml:id="auto_b3h98dse"><p xml:id="auto_vfthfzb9">Investigate the difference between instantaneous speed and average speed.</p></li>
                <li xml:id="auto_o6b62kgq"><p xml:id="auto_x3fskhdi">Analyse real-world data from GPS tracking apps.</p></li>
            </ul>
        </p>
        <p xml:id="auto_eh4chhaz">
            <alert>Extension Activity <mdash/> Journey Analysis:</alert> Use a GPS app to track a walk with multiple turns. Record the total distance traveled from the app. Measure the straight-line displacement on a map. Calculate both average speed and average velocity. Discuss why GPS gives both <q>distance traveled</q> and <q>distance remaining.</q>
        </p>
    </axiom>

