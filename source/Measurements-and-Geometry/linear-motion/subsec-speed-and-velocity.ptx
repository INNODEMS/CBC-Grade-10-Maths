    <activity xml:id="auto_s6dnc2zb">
        <introduction xml:id="auto_v90ozx30">
            <p xml:id="auto_hjl9m24v">
                <alert>Work in groups</alert>
            </p>
            <p xml:id="auto_4yoy9edt">
                <alert>What you need</alert>
            </p>
            <p xml:id="auto_oz7tvxx5">
                <ul>
                    <li xml:id="auto_hssbnpdw">
                        <p xml:id="auto_dg3ua97h">
                            Measuring tape (or marked floor tiles)
                        </p>
                    </li>
                    <li xml:id="auto_d1y74gix">
                        <p xml:id="auto_q8h19ry0">
                            Stopwatch
                        </p>
                    </li>
                    <li xml:id="auto_vdxhg7gg">
                        <p xml:id="auto_vnwxuyyu">
                            Chalk/tape to mark positions
                        </p>
                    </li>
                    <li xml:id="auto_ycbvnvv3">
                        <p xml:id="auto_9c3k8y9c">
                            Open space (classroom or field)
                        </p>
                    </li>
                </ul>
            </p>
            <p xml:id="auto_6k372e0q">
                <alert>What to do</alert>
            </p>
            <p xml:id="auto_ajzn7794">
                Mark a central point and label it C (origin).
            </p>
            <p xml:id="auto_omhvdhbk">
                Measure and mark:
            </p>
            <p xml:id="auto_nol2gdk3">
                <ul>
                    <li xml:id="auto_amd7eai2">
                        <p xml:id="auto_05c99nbq">
                            Point A → 10 m East of C
                        </p>
                    </li>
                    <li xml:id="auto_7hnz9cbj">
                        <p xml:id="auto_kdpjrrvn">
                            Point B → 10 m West of C
                        </p>
                    </li>
                </ul>
            </p>
            <p xml:id="auto_uba66b4u">
                Two students stand at point C.
            </p>
            <p xml:id="auto_ukw6o82l">
                The two groups of students to set the stopwatch and shout "go":
                <ul>
                    <li xml:id="auto_gcea14cu">
                        <p xml:id="auto_oijf0a17">
                            Student 1 walks to Point A (East)
                        </p>
                    </li>
                    <li xml:id="auto_fm484mug">
                        <p xml:id="auto_lbjcn8gm">
                            Student 2 walks to Point B (West)
                        </p>
                    </li>
                </ul>
            </p>
            <p xml:id="auto_jcdnypyx">
                Record the time taken for each student to reach their respective points.
            </p>
        </introduction>
        <task xml:id="auto_43j9hnn9">
            <statement>
                <p xml:id="auto_yf3nrc75">
                    For student 1 and student 2, calculate:
                </p>
                <p xml:id="auto_sy00cja2">
                    <ol>
                        <li xml:id="auto_na7pgves">
                            <p xml:id="auto_p4ykxpv4">
                                The displacement
                            </p>
                        </li>
                        <li xml:id="auto_kjiml6kg">
                            <p xml:id="auto_3sb6mw1d">
                                The time taken
                            </p>
                        </li>
                        <li xml:id="auto_q5jm8tlx">
                            <p xml:id="auto_r7mumaer">
                                 The average velocity
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
        </task>
        <task xml:id="auto_7ipovxhh">
            <statement>
                <p xml:id="auto_fdj7vub5">
                    Compare the average velocity of student 1 and student 2. 
                </p>
            </statement>
        </task>
    </activity>

    <exploration xml:id="exploration-speed-velocity">
        <title>Speed vs. Velocity: The Round Trip</title>
        
        <introduction xml:id="auto_byb65kui">
            <p xml:id="auto_5tbdj9pl">
                While we often use the words "speed" and "velocity" interchangeably in daily life, in physics, they describe two very different things. 
            </p>
            <p xml:id="auto_bivp1o9q">
                Start the car's journey below and use the questions in <xref ref="inst-speed-velocity" text="custom">the instructions below</xref> to uncover the difference between velocity and speed.
            </p>
        </introduction>

        <figure xml:id="fig-speed-velocity-interactive">
            <caption>Interactive: Comparing Average Speed and Average Velocity</caption>
            <interactive xml:id="interactive-speed-velocity" platform="jsxgraph" width="90%" aspect="4:3" source="jsxgraph/speed-velocity-animation.js">
                <slate xml:id="jxgbox-speed-velocity" surface="jsxboard" aspect="4:3"/>
                <instructions xml:id="inst-speed-velocity">
                    <p xml:id="auto_5esulo0a">
                        Press the <alert>Start Trip</alert> button and watch the data counters carefully as the car reaches the "Turn" and begins to come back:
                    </p>
                    <p xml:id="auto_mjee72x3">
                        
                        <ul>
                            <li xml:id="auto_j1hckv28">
                                <alert>The First Leg:</alert> During the first <m>4</m> seconds, as the car moves toward the right, how do the values for Average Speed and Average Velocity compare? Why are they identical during this part of the trip?
                            </li>
                            <li xml:id="auto_ek0jh6ql">
                                <alert>The Turn-Around:</alert> After the car passes the 10m mark and starts moving back toward Home, what happens to the <term>Average Velocity</term>? Why does it start to decrease even though the car is still moving?
                            </li>
                            <li xml:id="auto_7jv0kdm4">
                                <alert>Distance vs. Displacement:</alert> Notice the <term>Total Distance</term> never stops growing. Since Speed is calculated as <m>\text{speed} = \frac{\text{distance}}{\text{time}}</m>, how does this explain why the Speed stays high while Velocity drops?
                            </li>
                            <li xml:id="auto_5r1e8xm4">
                                <alert>Critical Thinking:</alert> If the car drove all the way back to "Home" (<m>0</m> m), what would its final <term>Average Velocity</term> be? What would its <term>Average Speed</term> be?
                            </li>
                        </ul>
                    </p>
                </instructions>
            </interactive>
        </figure>
    </exploration>
    <axiom component="lesson-plan">
        <title>Phase 2: Formalizing Speed and Velocity Concepts</title>
        <dl>
            <li xml:id="auto_h14qzssv">
                <title>Suggested Time</title>
                <p xml:id="auto_o8qzofua">
                    10 minutes
                </p>
            </li>
            <li xml:id="auto_9y1yyqv1">
                <title>Grouping</title>
                <p xml:id="auto_b157pild">
                    Whole class
                </p>
            </li>
            <li xml:id="auto_qrjya44g">
                <title>Scaffolding Strategies to Address Misconceptions</title>
                <p xml:id="auto_c2767dnq">
                    <ul>
                        <li xml:id="auto_57m1xgh5"><p xml:id="auto_zugaz5z1"><alert>Misconception:</alert> Speed and velocity are the same thing. <alert>Clarification:</alert> Speed is a scalar (magnitude only), while velocity is a vector (magnitude and direction). Two objects can have the same speed but different velocities if they move in different directions.</p></li>
                        <li xml:id="auto_hepjge31"><p xml:id="auto_lj9rkqm0"><alert>Misconception:</alert> Average speed equals average velocity. <alert>Clarification:</alert> Average speed uses total distance, while average velocity uses total displacement. For a round trip back to the starting point, average velocity is zero but average speed is not.</p></li>
                        <li xml:id="auto_ph8ddrj2"><p xml:id="auto_eoij91v0"><alert>Misconception:</alert> A stationary break doesn't affect average speed. <alert>Clarification:</alert> Rest time is included in total time, which lowers the average speed.</p></li>
                    </ul>
                </p>
            </li>
        </dl>
    </axiom>

    <insight xml:id="auto_apsvhtro">
        <p xml:id="auto_p4nqgp90">
          <term>Speed</term> is the rate of change of distance with time. SI unit: <m>km/h</m> .
        </p>
        <p xml:id="auto_kqxeqbev">
            Speed is how fast something moves.
        </p>
        <p xml:id="auto_clc1pufn">
           Speed normally varies over time, so the average speed is often used
        </p>
        <p xml:id="auto_0pbnuzic">
        <md>
            <mrow>\text{Average speed} = \frac{\text{Total distance covered}}{\text{Total time taken}} </mrow>
        </md>
        </p>
         <p xml:id="auto_p76g3hm7">
          <term>Velocity</term> is Speed in a specified direction or the rate of change of displacement with time. SI unit: <m>km/h</m>.
        </p>
        <p xml:id="auto_aq99sptr">
            Symbol of velocity is given as <term>v</term> while speed is given as <term>s</term>.
        </p>
         <p xml:id="auto_lfjst8yj">
        <md>
            <mrow>\text{Average velocity} = \frac{\text{Total displacement}}{\text{Total time taken}} </mrow>
        </md>
        </p>
        <p xml:id="auto_rgzq9lau">
           or  <m> v = \frac{d}{t} </m>
        </p>
        <p xml:id="auto_nji9o7w9">
            where <m>d</m> represents the distance and <m>t</m> represents time
        </p>
        <p xml:id="auto_jq1dsh3y">
            For motion with <term>constant velocity</term>, the equation is 
        </p>
        <p xml:id="auto_nwym29tn">
            <md>
                <mrow> s = vt </mrow>
            </md>
        </p>
        <p xml:id="auto_kgafqi3n">
            where <m>v</m> is velocity , <m>t</m> is time and <m>s</m> is displacement
        </p>
       
       
    </insight>

    
    <axiom component="lesson-plan">
        <title>Phase 3: Practice and Application</title>
        <dl>
            <li xml:id="auto_dpqms4zp">
                <title>Suggested Time</title>
                <p xml:id="auto_3zdti5kq">
                    10 minutes
                </p>
            </li>
            <li xml:id="auto_lvp3ss2v">
                <title>Grouping</title>
                <p xml:id="auto_yik4nm69">
                    Individual, then pairs for checking
                </p>
            </li>
            <li xml:id="auto_qmo03l4f">
                <title>Teacher's Role</title>
                <p xml:id="auto_ag2hjiya">
                    Walk through the first worked example on the board, then allow students to attempt the remaining examples independently. Circulate to check working and provide support where needed. Emphasise the importance of converting units (e.g., minutes to hours) when calculating average speed.
                </p>
            </li>
        </dl>
    </axiom>
   
    
    <example xml:id="auto_4wdky1rp">
        <statement>
            <p xml:id="auto_qcss66kh">
                A car travels 100 km in 2 hours. Find its speed.
            </p>
        </statement>
            <solution>
                <p xml:id="auto_9khiv5dk">
                    <m>\text{Speed} = \frac{\text{distance}}{\text{time}}</m>
                </p>
                <p xml:id="auto_p7l4cwka">
                    <m> \text{Speed} = \frac{100}{2} = 50 \text{ km/h} </m>
                </p>
                
            </solution>
    </example>
    <example xml:id="auto_wxg35tfl">
        <statement>
            <p xml:id="auto_07q640rp">
                Find the velocity of a car that travels 150 km north in 3 hours.
            </p>
        </statement>
        <solution>
            <p xml:id="auto_6dasxugy">
                Displacement = 150 km (in the north direction)
            </p>
            <p xml:id="auto_24cy6wv2">
                Time taken = 3 hours
            </p>
            <p xml:id="auto_9hlbrk9e">
                Average velocity = Displacement / Time taken = 150 km / 3 h = 50 km/h (in the north direction)
            </p>
            <p xml:id="auto_5hrl6hkn">
                <md>
                    <mrow> \text{Average velocity} =\amp \frac{\text{Displacement}}{\text{Time taken}} </mrow>
                    <mrow> =\amp \frac{150 \text{ km}}{3 \text{ h}} </mrow>
                    <mrow> =\amp 50 \text{ km/h (north direction)} </mrow>
                </md>
                
            </p>
        </solution>
    </example>
    <example xml:id="auto_pxsuq4v9">
        <statement>
            <p xml:id="auto_gc52ld35">
                A motorist covers a distance of 360 km in 3 hours travelling from Busia to Bahangongo. Calculate the average speed.
            </p>
        </statement>
        <solution>
            <p xml:id="auto_5ir57a2o">
                <m>\text{Speed} = \frac{\text{distance}}{\text{time}}</m>
            </p>
            <p xml:id="auto_iwiezobc">
                <md>
                    <mrow> \text{Average speed} = \frac{\text{360 km}}{\text{3 h}} </mrow>
                </md>
            </p>
            <p xml:id="auto_4hpw7fkw">
                <md>
                    <mrow> \text{120 km/h} </mrow>
                </md>
            </p>
        </solution>
    </example>
    <example xml:id="auto_jlj7lvke">
        <statement>
            <p xml:id="auto_9qny8b8q">
                 A cyclist travels <m>10 \, \text{km}</m> in the positive direction in <m>40 \, \text{minutes}</m>, and then reverses, riding <m>6 \, \text{km}</m> in the negative direction in <m>20 \, \text{minutes}</m>. Calculate the average velocity.
            </p>
        </statement>
        <solution>
            <p xml:id="auto_eal6yf41">
                Displacement = <m>10 \text{ km (positive)}</m> + <m>-6 \text{ km (negative)}</m> = <m>4 \text{ km (positive)}</m>
            </p>
            <p xml:id="auto_dft6stfs">
                Time taken = <m>40 \text{ minutes} + 20 \text{ minutes} = 60 \text{ minutes} = 1 \text{ hour}</m>
            </p>
            <p xml:id="auto_ej30tsbh">
                <md>
                    <mrow>\text{Average velocity} = \frac{\text{Total displacement}}{\text{Total time}} </mrow>
                    <mrow>= \frac{4 \text{ km}}{1 \text{ h}} </mrow>
                    <mrow>= 4 \text{ km/h (positive direction)} </mrow>
                </md>
            </p>
        </solution>
    </example>
    <example xml:id="auto_ecoe2brz">
        <statement>
            <p xml:id="auto_cwzm87jz">
                Alex is cycling from home to the market. He rides the first 8 km at a speed of 16 km/h. After reaching a park, 
                Alex takes a 20-minute break to play football with his friends. Then, he cycles the remaining 6 km to the market at a speed of 12 km/h.
                What was Alex's average speed for the entire journey?
            </p>
        </statement>
        <solution>
            <p xml:id="auto_f133hga8">
                <ol xml:id="auto_zyutzprj">
                    <li xml:id="auto_w830ub3n">
                        <p xml:id="auto_qxgmtnup">
                            Calculating the time for each cycling part.
                            <ul xml:id="auto_w53ajnbe">
                                <li xml:id="auto_10wy6d82">
                                    <p xml:id="auto_uavptzzx">
                                        <alert>part 1</alert>
                                    </p>
                                    <p xml:id="auto_pdwognk6">
                                        Distance: <m>8 km</m>
                                    </p>
                                    <p xml:id="auto_5ycpst8h">
                                        Speed: <m>16 km/h</m>
                                    </p>
                                    <p xml:id="auto_mf0niz8z">
                                        <md>
                                            <mrow>\text{Time}\, = \, \frac{\text{Distance}}{\text{Speed}} \, = \, \frac{\text{8 km}}{\text{16 km/h}} \,  = \text{0.5 hours}</mrow>
                                        </md>
                                    </p>
                                </li>
                                <li xml:id="auto_x1nkzbgf">
                                    <p xml:id="auto_zyjiz4u3">
                                        <alert>part 2</alert>
                                    </p>
                                    <p xml:id="auto_vn5ueg4n">
                                        Distance: <m>6 km</m>
                                    </p>
                                    <p xml:id="auto_558tjwgr">
                                        Speed: <m>12 km/h</m>
                                    </p>
                                    <p xml:id="auto_idk1993s">
                                        <md>
                                            <mrow>\text{Time}\, = \, \frac{\text{Distance}}{\text{Speed}} \, = \, \frac{\text{6 km}}{\text{12 km/h}} \,  = \text{0.5 hours}</mrow>
                                        </md>
                                    </p>
                                </li>
                            </ul>
                        </p>
                    </li>
                    <li xml:id="auto_8wn1zfen">
                        <p xml:id="auto_tbwy2eci">
                            Convert the break time to hours
                        </p>
                        <p xml:id="auto_b46jg3au">
                            <m>\frac{\text{20 minutes}}{\text{60 minutes}} = \frac{1}{3} \, \text{hours}</m>
                        </p>
                    </li>
                    <li xml:id="auto_y6kwuuh7">
                        <p xml:id="auto_pk8h4eq1">
                            Calculating the total distance gives
                        </p>
                        <p xml:id="auto_dzprjg6x">
                            <md>
                                <mrow> \text {Total distance = 8 km + 6 km = 14 km }</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_t0p3s7ix">
                        <p xml:id="auto_ndtz9bl9">
                            Calculating the total time gives
                        </p>
                        <p xml:id="auto_pz1o2i3a"> Total time =
                            <md>
                                <mrow> \frac{1}{2} \, \text{hours} + \frac{1}{3} \, \text{hours} + \frac{1}{2} \, \text{hours} = 1\frac{1}{3} \, \text{hours}  </mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_q60djqkm">
                        <p xml:id="auto_7jtdmjy2">
                            Now Calculating the average speed gives
                        </p>
                        <p xml:id="auto_pguax3jr">
                            <m>\text{Average speed} \, = \, \frac{\text{Total distance}}{\text{Total time}}</m>
                        </p>
                        <p xml:id="auto_7ea9ntib">
                            <m>\text{Average speed} \, = \, \frac{\text{14 km}}{\text{1.33 hours}} \, = \, \text{10.53 km/h} </m> 
                        </p>
                    </li>
                </ol>
            </p>
            <p xml:id="auto_y13ncn1y">
                Alex's average speed for the entire journey was approximately <m>10.53</m> km/h.
            </p>
        </solution>
    </example>
     <exercise xml:id="ex-calculating-average-speed-with-time-segment">
        <stack label="stk-calculating-average-speed-with-time-segment" source="stack/top/2-0-Measurement-Geometry/2-9-Linear-Motion/Speed/Calculating-average-speed-with-time-segment.xml"/>
    </exercise>
