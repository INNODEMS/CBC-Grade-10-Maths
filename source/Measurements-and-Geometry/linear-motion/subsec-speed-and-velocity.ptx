                <p xml:id="auto_f44hg9q5">
                    5 minutes
                </p>
            </li>
            <li xml:id="auto_l92mio32">
                <title>Grouping</title>
                <p xml:id="auto_urf58gmv">
                    Individual
                </p>
            </li>
             <li xml:id="auto_9ipevy0m">
                <title>Exit Ticket</title>
                   <p xml:id="auto_xc9mi3u6">
                    Learners independently complete a short assessment task (select from the exercises below).
                </p>
            </li>
            <li xml:id="auto_g6zhbl8p">
                <title><alert>Teacher's Role</alert></title>
                <p xml:id="auto_sz7z7cuh">
                    Collect and review the exit tickets to gauge Learner understanding and identify any common misconceptions that need to be addressed in the next lesson.
                </p>
            </li>
