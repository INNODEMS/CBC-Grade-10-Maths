    <axiom component="lesson-plan">
        <title>Phase 4: Assessment — Exit Ticket (5 minutes)</title>
        <p xml:id="auto_q0y6xqdd">
            Students complete individually to demonstrate understanding.
        </p>
        <p xml:id="auto_igha4hkj">
            <alert>Question 1:</alert> A cyclist is riding at <m>18</m> km/h, and a motorcycle is travelling at <m>30</m> km/h on the same road. If the cyclist starts <m>200</m> metres ahead, how long will it take for the motorcycle to overtake the cyclist?
        </p>
        <p xml:id="auto_mq7oirsi">
            <alert>Question 2:</alert> A toy car is pulled at <m>5</m> m/s, while a person walks at <m>2</m> m/s along the same path. If the toy car starts <m>15</m> metres ahead, how much time will it take for the person to catch up?
        </p>
        <p xml:id="auto_xvq83gvx">
            <alert>Question 3:</alert> Two cyclists are riding along the same road. Cyclist A travels at <m>12</m> km/h and Cyclist B travels at <m>15</m> km/h. If Cyclist B starts <m>100</m> metres behind Cyclist A, how long will it take for Cyclist B to overtake Cyclist A?
        </p>
        <p xml:id="auto_17ypodgz">
            <alert>Answer Key (teacher reference):</alert>
        </p>
        <p xml:id="auto_k9l41txp">
            <ol marker="1.">
                <li xml:id="auto_j7sodu1d">Relative speed = <m>12</m> km/h = <m>\frac{10}{3}</m> m/s. Time = <m>\frac{200}{\frac{10}{3}} = 60</m> seconds.</li>
                <li xml:id="auto_6omcxidu">Relative speed = <m>3</m> m/s. Time = <m>\frac{15}{3} = 5</m> seconds.</li>
                <li xml:id="auto_f13x6yi7">Relative speed = <m>3</m> km/h = <m>\frac{5}{6}</m> m/s. Time = <m>\frac{100}{\frac{5}{6}} = 120</m> seconds.</li>
            </ol>
        </p>
    </axiom>

    <exercises xml:id="exercises-moving-same-direction">
        <exercise xml:id="auto_ctsl9dii">
            <statement>
                <p xml:id="auto_vz4e22jm">
                    A cyclist is riding at a speed of <m>18</m> <em>km/h</em>, 
                    and a motorcycle is traveling at <m>30</m> <em>km/h</em> on the same road. 
                    If the cyclist starts <m>200</m> meters ahead of the motorcycle, 
                    how long will it take for the motorcycle to overtake the cyclist?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_d36s2234">
                    The relative speed is <m>12</m> <em>km/h</em>. 
                </p>
                <p xml:id="auto_lp50zn2v">
                    Converting to <em>m/s</em>: <m>12 \times \frac{1000}{3600} = \frac{10}{3}</m> <em>m/s</em>. 
                </p>
                <p xml:id="auto_6cxq4iuj">
                    The time taken to overtake is <m>\frac{200}{\frac{10}{3}} = 60</m> seconds.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_fpycvk1z">
            <statement>
                <p xml:id="auto_jkhqugmo">
                    A toy car is being pulled along a straight path at a speed of <m>5</m> <em>m/s</em>, 
                    while a person walks at <m>2</m> <em>m/s</em> along the same path. 
                    If the toy car starts <m>15</m> meters ahead of the person, 
                    how much time will it take for the person to catch up with the toy car?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_bplplmn9">
                    The relative speed is <m> 3</m> <em>m/s</em>. 
                </p>
                <p xml:id="auto_ldnbex2z">
                    The time taken to catch up is <m>\frac{15}{3} = 5</m> seconds.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_4gje0vaf">
            <statement>
                <p xml:id="auto_nl4tu7pl">
                    Two cyclists are riding along the same road. 
                    Cyclist <m>A</m> is traveling at <m>12</m> <em>km/h</em> and Cyclist 
                    <m>B</m> is traveling at <m>15</m> <em>km/h</em>. 
                    If Cyclist <m>B</m> starts <m>100</m> meters behind Cyclist <m>A</m>, 
                    how long will it take for Cyclist <m>B</m> to overtake Cyclist <m>A</m>?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_4zlv40bq">
                    The relative speed is <m>3</m> <em>km/h</em> which is <m>\frac{5}{6}</m> <em>m/s</em>. 
                </p>
                <!-- <p xml:id="auto_72kkkf0f">
                    Speed in <em>m/s</em> is <m> = \frac{5}{6}</m>. 
                </p> -->
                <!-- <p xml:id="auto_dw4jm46q">
                    The time taken to overtake is <m>\frac{100}{\frac{5}{6}} = 120</m> seconds.
                </p> -->
                <p xml:id="auto_dw4jm46q">
                    The time taken to overtake is <m>120</m> seconds.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_6wdof9af">
            <statement>
                <p xml:id="auto_povdv6b0">
                    A person walks at a speed of <m>1.5</m> <em>m/s</em>, 
                    and a dog runs at a speed of <m>3</m> <em>m/s</em>. 
                    If the dog starts <m>10</m> meters behind the person, 
                    how long will it take the dog to catch up with the person?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_q0oq25uh">
                    The relative speed is <m> 1.5</m> <em>m/s</em>. 
                </p>
                <p xml:id="auto_xx915bmp">
                    The time taken to catch up is <m>6.67</m> seconds.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_yq7b2otk">
            <statement>
                <p xml:id="auto_whuihaze">
                    Two buses are traveling on the same road in the same direction. 
                    Bus <m>A</m> moves at <m>55</m> <em>km/h</em>, 
                    and Bus <m>B</m> moves at <m>45</m> <em>km/h</em>. 
                    If Bus <m>A</m> is <m>500</m> meters behind Bus <m>B</m>, 
                    how long will it take for Bus <m>A</m> to overtake Bus B?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_60crugad">
                    The relative speed is <m>10</m> <em>km/h</em> which is <m>\frac{25}{9}</m> <em>m/s</em>.
                </p>
                <!-- <p xml:id="auto_g215021e">
                    Converting to <em>m/s</em>, we get <m>10 \times \frac{1000}{3600} = \frac{25}{9}</m> <em>m/s</em>.
                </p> -->
                <!-- <p xml:id="auto_zmyugqiq">
                    The time taken to overtake is <m>\frac{500}{\frac{25}{9}} = 180</m> seconds.
                </p> -->
                <p xml:id="auto_zmyugqiq">
                    The time taken to overtake is <m>180</m> seconds.
                </p>
            </answer>
        </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation Strategies</title>
        <p xml:id="auto_vu2d9lz4">
            <alert>For Struggling Learners:</alert>
        </p>
        <p xml:id="auto_s3j8utc4">
            <ul>
                <li xml:id="auto_8sm03cgr">Provide step-by-step calculation sheets with formulas already written.</li>
                <li xml:id="auto_6v2lph9y">Use visual aids showing objects moving in the same direction.</li>
                <li xml:id="auto_239fnu50">Allow use of calculators for conversions.</li>
                <li xml:id="auto_o82f4fh5">Pair with peer tutors during practice.</li>
            </ul>
        </p>
        <p xml:id="auto_ot13b9iw">
            <alert>For Advanced Students:</alert>
        </p>
        <p xml:id="auto_ukvnkbll">
            <ul>
                <li xml:id="auto_7tlbey8i">Solve problems involving three objects moving in the same direction.</li>
                <li xml:id="auto_ya8wjnbq">Calculate relative speeds with changing speeds (acceleration).</li>
                <li xml:id="auto_avsusl5g">Explore real-world applications: highway traffic, race cars, trains.</li>
                <li xml:id="auto_fpkjejqj">Create their own relative speed problems for classmates to solve.</li>
            </ul>
        </p>
    </axiom>

    <axiom component="lesson-plan">
        <title>Extension Activity: Highway Traffic Simulation</title>
        <p xml:id="auto_ck6k0tlp">
            Two cars are travelling on a highway. Car A is travelling at <m>80</m> km/h, and Car B is travelling at <m>100</m> km/h. Car B is <m>500</m> metres behind Car A.
        </p>
        <p xml:id="auto_pq8mxr63">
            <ol marker="1.">
                <li xml:id="auto_u0kke5a0">Calculate the relative speed of Car B with respect to Car A.</li>
                <li xml:id="auto_vxylrmcq">Determine how long it will take for Car B to overtake Car A.</li>
                <li xml:id="auto_7q0er6ub">If the highway is <m>10</m> km long, where will Car B overtake Car A?</li>
                <li xml:id="auto_8k2hbdcy">Create a distance-time graph showing both cars.</li>
            </ol>
        </p>
    </axiom>

