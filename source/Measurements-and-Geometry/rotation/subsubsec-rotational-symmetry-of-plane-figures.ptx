        <exercises xml:id="exercises-rotation-on-different-planes">

        <exercise xml:id="auto_jo0ickny">
            <p xml:id="auto_mvyi5fyu">
                A point <m>P\, (4,3)</m> maps onto <m>P'\, (-1,4)</m> under a rotation R centre <m>(1,1)</m>. Find the angle of rotation.
            </p>
        </exercise>

        <exercise xml:id="auto_sxfqjkxa">
            <p xml:id="auto_jzznp16v">
                Describe the rotation which maps the rectangle whose verticies are <m>P\, (2,2)</m>, <m>Q\, (6,2)</m>, <m>R\,(6,4)</m> and <m>S\, (2,4)</m> onto a rectangle whose verticies are <m>P'\,(2,-2)</m>, <m>Q'\,(2,-6)</m>, <m>R'\,(4,-6)</m> and <m>S'\, (4,-2)</m>
            </p>
        </exercise>

        <exercise xml:id="auto_34rue0q0">
            <p xml:id="auto_fh2xo5gi">
                Give the coordinates of the image of each of the following points when rotated through <m>180^\circ</m> in a clockwise direction about <m>(2,1)</m>
            </p>

            <sidebyside>
                <p xml:id="auto_he0runot">
                    (a)  (4,-2)
                </p>

                <p xml:id="auto_rl9eyecy">
                    (b)  (-2,2)
                </p>

                <p xml:id="auto_t95wngxh">
                    (c)  (4,4)
                </p>

                <p xml:id="auto_n2098vhg">
                    (d)  (-2,-1)
                </p>

                <p xml:id="auto_sx8kp0xx">
                    (e)  (-3,2)
                </p>
            </sidebyside>
        </exercise>

        <exercise xml:id="auto_la88f274">
            <statement>
                <p xml:id="auto_wz382hga">
                    Find the coordinates of the verticies of the image of a triangle whose verticies are <m>P\, (-4,6)</m>, <m>Q\, (-4,2)</m> and <m>R\, (-2,2)</m> when rotated about the origin through:
                </p>

                <sidebyside>
                    <p xml:id="auto_f1f2goff">
                    (a) <m>-90^\circ</m>
                </p>

                <p xml:id="auto_ftomwvel">
                    (b) <m>-180^\circ</m>
                </p>

                <p xml:id="auto_fcwnfnq3">
                    (c) <m>270^\circ</m>
                </p>
                </sidebyside>
            </statement>
        </exercise>

        <exercise xml:id="auto_6sv5g67h">
            <statement>
                <p xml:id="auto_ccg5a265">
                    The parallelogram whose verticies are <m>A\, (4,4)</m>, <m>B\, (8,4)</m>, <m>C\, (2,2)</m> and <m>D\, (6,2)</m> is rotated to give an image whose verticies are <m>A'\, (4,-2)</m>, <m>B'\, (4,-6)</m>, <m>C'\, (2,0)</m> and <m>D'\, (2,-4)</m>. Find the centre and angle of rotation.
                </p>
            </statement>
        </exercise>

        <exercise xml:id="auto_chuv0uke">
      <statement>
        <p xml:id="auto_012sbg7k">
          State the order of symmetry in the figures below.
        </p>
        <sidebyside>
          <image width="50%">
          <latex-image label="triangle_rotational_symmetry">
            \begin{tikzpicture}
              \draw[thick,red] (0:.5cm) \foreach \x in {120,240} {
                -- (\x:.5cm)
                } -- cycle (90:.5cm);
            \end{tikzpicture}
          </latex-image>
        </image>

        <image width="50%">
          <latex-image label="pentagon_rotational_symmetry">
              \begin{tikzpicture}
              \draw[thick,orange] (0:.5cm) \foreach \x in {72,144,...,359} {
                -- (\x:.5cm)
               } -- cycle (90:.5cm) ;  
              \end{tikzpicture}
          </latex-image>
          </image>

          <image width="50%">
          <latex-image label="octagon_rotaional_symmetry">
            \begin{tikzpicture}
              \draw[thick,purple] (0:.5cm) \foreach \x in {45,90,...,359} {
               -- (\x:.5cm)
               } -- cycle (90:.5cm);
            \end{tikzpicture}
          </latex-image>
          </image>
        </sidebyside>

        <sidebyside>
          <image width="50%">
          <latex-image label="circle_rotational_symmetry">
            \begin{tikzpicture}
              \draw[thick,purple] (0:.5cm) \foreach \x in {50, 100,200} {
               -- (\x:.5cm)
               } -- cycle (90:.5cm);
            \end{tikzpicture}
          </latex-image>
          </image>

          <image width="50%">
            <latex-image label="Circle_triangle_rotational_symmetry">
              \begin{tikzpicture}
                \fill[black!20] circle (2pt);
                \draw (0:.5cm) \foreach \x in {120,240} {
                    -- (\x:.5cm)
                  } -- cycle (90:.5cm) ;
              \end{tikzpicture}
            </latex-image>
          </image>

          <image width="50%">
          <latex-image label="rhombus_rotational_symmetry">
            \begin{tikzpicture}
                \usetikzlibrary{quotes,angles}
                \draw[blue,thick](0,2) coordinate (D)-- (0,0) coordinate (A)-- (4,0) coordinate (B)--(2,2)coordinate(C)--(0,2)coordinate(D);
                \draw[blue](0,0)--(0,0.3)--(0.3,0.3)--(0.3,0);
                \draw[blue](0,2)--(0.3,2)--(0.3,1.7)--(0,1.7);
                \draw[blue](0.9,2.1)--(1,2)--(0.9,1.9);
                \draw[blue](0.9,0.1)--(1,0)--(0.9,-0.1);
                \end{tikzpicture}
          </latex-image>
          </image>
        </sidebyside>
      </statement>
    </exercise>

    <exercise xml:id="auto_euvelelj">
      <statement>
        <p xml:id="auto_52jf1osh">
          Find the order of rotational symmetry in the letters of the alphabet.
        </p>
      </statement>
    </exercise>
            
        </exercises>
        
                
    <axiom component="lesson-plan">
        <title>Differentiation</title>
        <table>
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Provide physical cutouts and a pin. Start with a square (easiest to see). Colour one edge or corner to track rotation. Use the "Does it look the same?" test. Provide a table template for recording results.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>Complete all activities and problems as described. Apply the formula for order of rotational symmetry. Analyse letter shapes for rotational symmetry.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extension Learning Experience:</alert> Design a logo with a specific order of rotational symmetry. Investigate Fibonacci patterns in nature related to symmetry. Create a tessellation using rotational symmetry. Explore the connection between group theory and symmetry.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
        <p>
            <alert>Extension Activities:</alert>
        </p>
        <p>
            <ol>
                <li>
                    <p>
                        <alert>Symmetry Poster:</alert> Find 10 logos or symbols, determine the order of rotational symmetry for each, classify them by order, and present to the class.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Playing Cards:</alert> Analyse playing card designs. Which cards have order 2? (Most face cards.) Which have order 4? (Some number cards with symmetric pip arrangements.)
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Islamic Geometric Art:</alert> Islamic geometric art often uses high-order rotational symmetry (order 8, 12, etc.). Research and recreate one pattern.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Creative Challenge:</alert> Create a shape with order 7 rotational symmetry but NO lines of symmetry. (Hint: use a curved, asymmetric motif repeated 7 times.)
                    </p>
                </li>
            </ol>
        </p>
    </axiom>
