            <exercise  label="ex-describing-a-rotation">
                <stack label="stk-describing-a-rotation" source="stack/top/2-0-Measurement-Geometry/2-3-Rotation/2-3-1-Properties-of-Rotation/Describing-a-rotation.xml" />
            </exercise>

    <exercises xml:id="exercises-properties-of-rotation">

        <exercise xml:id="ex-rotation-triangle-90">
            <statement>
                <p>
                    Triangle <m>ABC</m> has vertices <m>A(1,2)</m>, <m>B(4,2)</m>, and <m>C(3,5)</m>.
                    Rotate the triangle <m>90°</m> anticlockwise about the origin. 
                    State the coordinates of the image <m>A'B'C'</m> and verify that the distance from the origin is preserved.
                </p>

            </statement>
            <answer>
                                <image width="60%">
                <latex-image label="ex-rotation-triangle-90-diag">
                    \begin{tikzpicture}[scale=0.7]
                        % Axes
                        \draw[thick, -&gt;] (-6.5,0) -- (5.5,0) node[right] {$x$};
                        \draw[thick, -&gt;] (0,-1.5) -- (0,6.5) node[above] {$y$};
                        % Grid
                        \draw[gray!30, very thin] (-6,-1) grid (5,6);
                        % Tick marks on x-axis
                        \foreach \x in {-6,-5,-4,-3,-2,-1,1,2,3,4,5}
                            \draw (\x,0.1) -- (\x,-0.1) node[below, font=\tiny] {$\x$};
                        % Tick marks on y-axis
                        \foreach \y in {-1,1,2,3,4,5,6}
                            \draw (0.1,\y) -- (-0.1,\y) node[left, font=\tiny] {$\y$};
                        % Origin label
                        \node[below left, font=\tiny] at (0,0) {$O$};
                        % Original triangle ABC (blue)
                        \draw[very thick, blue, fill=blue!15] (1,2) -- (4,2) -- (3,5) -- cycle;
                        \fill[blue] (1,2) circle (0.1) node[below right] {$A(1,2)$};
                        \fill[blue] (4,2) circle (0.1) node[below right] {$B(4,2)$};
                        \fill[blue] (3,5) circle (0.1) node[above right] {$C(3,5)$};
                        % Image triangle A'B'C' (red)
                        \draw[very thick, red, fill=red!15] (-2,1) -- (-2,4) -- (-5,3) -- cycle;
                        \fill[red] (-2,1) circle (0.1) node[below left] {$A'(-2,1)$};
                        \fill[red] (-2,4) circle (0.1) node[above left] {$B'(-2,4)$};
                        \fill[red] (-5,3) circle (0.1) node[left] {$C'(-5,3)$};
                        % Rotation arc from A to A'
                        \draw[thick, dashed, gray] (0,0) -- (1,2);
                        \draw[thick, dashed, gray] (0,0) -- (-2,1);
                        \draw[-&gt;, thick, purple] (0.7,1.4) arc[start angle=63.4, end angle=153.4, radius=1.57];
                        \node[purple, above] at (-0.5,1.8) {$90°$};
                    \end{tikzpicture}
                </latex-image>
                </image>
                <p>
                    Using the rotation rule for <m>90°</m> anticlockwise about the origin: <m>(x, y) \to (-y, x)</m>.
                </p>
                <p>
                    <md>
                        <mrow>A(1, 2) \amp\to A'(-2, 1)</mrow>
                        <mrow>B(4, 2) \amp\to B'(-2, 4)</mrow>
                        <mrow>C(3, 5) \amp\to C'(-5, 3)</mrow>
                    </md>
                </p>
                <p>
                    <em>Verifying that distances from the origin are preserved:</em>
                </p>
                <p>
                    <md>
                        <mrow>OA \amp= \sqrt{1^2 + 2^2} = \sqrt{5}</mrow>
                        <mrow>OA' \amp= \sqrt{(-2)^2 + 1^2} = \sqrt{5} \checkmark</mrow>
                    </md>
                </p>
                <p>
                    <md>
                        <mrow>OB \amp= \sqrt{4^2 + 2^2} = \sqrt{20} = 2\sqrt{5}</mrow>
                        <mrow>OB' \amp= \sqrt{(-2)^2 + 4^2} = \sqrt{20} = 2\sqrt{5} \checkmark</mrow>
                    </md>
                </p>
                <p>
                    <md>
                        <mrow>OC \amp= \sqrt{3^2 + 5^2} = \sqrt{34}</mrow>
                        <mrow>OC' \amp= \sqrt{(-5)^2 + 3^2} = \sqrt{34} \checkmark</mrow>
                    </md>
                </p>
                <p>
                    In each case, the distance from the origin to the image point equals the distance from the origin to the original point, confirming the distance-preserving property of rotation.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="ex-rotation-rectangle-180">
            <statement>
                <p>
                    Rectangle <m>PQRS</m> has vertices <m>P(1,1)</m>, <m>Q(4,1)</m>, <m>R(4,3)</m>, and <m>S(1,3)</m>.
                    Rotate the rectangle <m>180°</m> about the origin. 
                    State the coordinates of the image <m>P'Q'R'S'</m> and verify that the distance from the origin is preserved.
                </p>
            </statement>
            <answer>
                                <image width="65%">
                <latex-image label="ex-rotation-rectangle-180-diag">
                    \begin{tikzpicture}[scale=0.7]
                        % Axes
                        \draw[thick, -&gt;] (-5.5,0) -- (5.5,0) node[right] {$x$};
                        \draw[thick, -&gt;] (0,-4.5) -- (0,4.5) node[above] {$y$};
                        % Grid
                        \draw[gray!30, very thin] (-5,-4) grid (5,4);
                        % Tick marks on x-axis
                        \foreach \x in {-5,-4,-3,-2,-1,1,2,3,4,5}
                            \draw (\x,0.1) -- (\x,-0.1) node[below, font=\tiny] {$\x$};
                        % Tick marks on y-axis
                        \foreach \y in {-4,-3,-2,-1,1,2,3,4}
                            \draw (0.1,\y) -- (-0.1,\y) node[left, font=\tiny] {$\y$};
                        % Origin label
                        \node[below left, font=\tiny] at (0,0) {$O$};
                        % Original rectangle PQRS (blue)
                        \draw[very thick, blue, fill=blue!15] (1,1) -- (4,1) -- (4,3) -- (1,3) -- cycle;
                        \fill[blue] (1,1) circle (0.1) node[below right] {$P$};
                        \fill[blue] (4,1) circle (0.1) node[below right] {$Q$};
                        \fill[blue] (4,3) circle (0.1) node[above right] {$R$};
                        \fill[blue] (1,3) circle (0.1) node[above right] {$S$};
                        % Image rectangle P'Q'R'S' (red)
                        \draw[very thick, red, fill=red!15] (-1,-1) -- (-4,-1) -- (-4,-3) -- (-1,-3) -- cycle;
                        \fill[red] (-1,-1) circle (0.1) node[above left] {$P'$};
                        \fill[red] (-4,-1) circle (0.1) node[above left] {$Q'$};
                        \fill[red] (-4,-3) circle (0.1) node[below left] {$R'$};
                        \fill[red] (-1,-3) circle (0.1) node[below left] {$S'$};
                        % Rotation arc from P to P'
                        \draw[thick, dashed, gray] (0,0) -- (1,1);
                        \draw[thick, dashed, gray] (0,0) -- (-1,-1);
                        \draw[-&gt;, thick, purple] (0.85,0.85) arc[start angle=45, end angle=225, radius=1.2];
                        \node[purple, left] at (-1.5,0) {$180°$};
                    \end{tikzpicture}
                </latex-image>
                </image>
                <p>
                    Using the rotation rule for <m>180°</m> about the origin: <m>(x, y) \to (-x, -y)</m>.
                </p>
                <p>
                    <md>
                        <mrow>P(1, 1) \amp\to P'(-1, -1)</mrow>
                        <mrow>Q(4, 1) \amp\to Q'(-4, -1)</mrow>
                        <mrow>R(4, 3) \amp\to R'(-4, -3)</mrow>
                        <mrow>S(1, 3) \amp\to S'(-1, -3)</mrow>
                    </md>
                </p>
                <p>
                    <em>Verifying that distances from the origin are preserved:</em>
                </p>
                <p>
                    <md>
                        <mrow>OP \amp= \sqrt{1^2 + 1^2} = \sqrt{2}</mrow>
                        <mrow>OP' \amp= \sqrt{(-1)^2 + (-1)^2} = \sqrt{2} \checkmark</mrow>
                    </md>
                </p>
                <p>
                    <md>
                        <mrow>OQ \amp= \sqrt{4^2 + 1^2} = \sqrt{17}</mrow>
                        <mrow>OQ' \amp= \sqrt{(-4)^2 + (-1)^2} = \sqrt{17} \checkmark</mrow>
                    </md>
                </p>
                <p>
                    The distances are preserved for every vertex, confirming the property of rotation. Note also that the shape and size of the rectangle are unchanged — <m>PQRS</m> is congruent to <m>P'Q'R'S'</m>.
                </p>
            </answer>
        </exercise>

    </exercises>

