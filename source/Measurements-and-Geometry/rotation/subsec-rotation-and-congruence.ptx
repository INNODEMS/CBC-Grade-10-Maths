    <exercises xml:id="exercises-identifying-congruence-in-rotation-using-objects-and-images">
      <exercise xml:id="auto_390ew8jq">
        <statement>
          <p xml:id="auto_k8off74a">
            Identify the axes of rotational symmetry and their respective order in the following:
          </p>
          <p xml:id="auto_keq3oc9p">
            <ol marker="(a)">
                <li>
                    <p>
                       Cylinder 
                    </p>
                </li>
                <li>
                    <p>
                         Rectangular pyramid
                    </p>
                </li>
                <li>
                    <p>
                        Sphere
                    </p>
                </li>
                <li>
                    <p>
                        Cube
                    </p>
                </li>
            </ol>
          </p>
        </statement>
        <answer>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            Axes is infinite
                        </p>
                        <p>
                             Order 2
                        </p>
                    </li>
                    <li>
                        <p>
                            Axis is <m>1</m>
                        </p>
                        <p>
                            Order is <m>2</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            Axis is infinite
                        </p>
                        <p>
                            Order is infinite
                        </p>
                    </li>
                    <li>
                        <p>
                            Axes is <m>13</m>
                        </p>
                        <p>
                            Order through opposite faces is <m>4</m>
                        </p>
                        <p>
                            Order through opposite faces is <m>3</m>
                        </p>
                        <p>
                            Order through opposite faces is <m>2</m>
                        </p>
                    </li>
                </ol>
            </p>
        </answer>
      </exercise>

      <exercise xml:id="auto_p0b97aa0">
        <statement>
          <p xml:id="auto_hoezkutc">
            Identify the axes of rotational symmetry and their respective order for the following figures:
          </p>
          <p>
            <ol marker="(a)">
                <li>
                    <image width="50%">
                        <latex-image label="square_base_pyramid_axis_of_rotation">
                            \begin{tikzpicture}
                                % Define vertices of the square base
                                \coordinate (A) at (-2,-1);
                                \coordinate (B) at (0,-1);
                                \coordinate (C) at (1,0);  
                                \coordinate (D) at (-1,0);  

                                % Define the apex of the pyramid
                                \coordinate (E) at (0,3);  % Center above the square base
                                
                                % Draw the square base
                                \draw[thick] (A) -- (B) -- (C) -- (D) -- cycle;
                                
                                % Draw edges connecting the apex to the base
                                \draw[thick] (E) -- (A);
                                \draw[thick] (E) -- (B);
                                \draw[thick] (E) -- (C);
                                \draw[style=dashed,thick] (E) -- (D);
                                
                                % Optional: Add shading for clarity
                                \fill[blue!20,opacity=0.5] (A) -- (B) -- (C) -- (D) -- cycle;  % Shade one face
                                \fill[red!20,opacity=0.5] (B) -- (C) -- (E) -- cycle; % Shade another face
                                \fill[orange!20,opacity=0.5] (D) -- (C) -- (E) -- cycle; % Shade another face
                                \fill[yellow!20,opacity=0.5] (A) -- (D) -- (E) -- cycle; % Shade another face

                                \node[below] at (A) {square-base pyramid};

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </li>
                <li>
                    <image width="50%">
                        <latex-image label="pentagonal_base_pyramid_axis_of_rotation">
                            \begin{tikzpicture}
                                % Define vertices of the square base
                                \coordinate (A) at (0,0.4);
                                \coordinate (B) at (-1,0);
                                \coordinate (C) at (-.8,-1);  
                                \coordinate (D) at (.8,-1); 
                                \coordinate (E) at (1,0);  

                                % Define the apex of the pyramid
                                \coordinate (F) at (0,4);  % Center above the pentagon base
                                
                                % Draw the pentagon base
                                \draw[thick] (A) -- (B) -- (C) -- (D) -- (E) -- cycle;
                                
                                % Draw edges connecting the apex to the base
                                \draw[style=dashed,thick] (F) -- (A);
                                \draw[thick] (F) -- (B);
                                \draw[thick] (F) -- (C);
                                \draw[thick] (F) -- (D);
                                \draw[thick] (F) -- (E);
                                
                                % Optional: Add shading for clarity
                                \fill[blue!20,opacity=0.5] (A) -- (B) -- (C) -- (D) -- (E) -- cycle;  % Shade one face
                                \fill[red!20,opacity=0.5] (A) -- (F) -- (E) -- cycle; % Shade another face
                                \fill[orange!20,opacity=0.5] (D) -- (F) -- (E) -- cycle; % Shade another face
                                \fill[white!20,opacity=0.5] (C) -- (F) -- (D) -- cycle; % Shade another face
                                \fill[brown!20,opacity=0.5] (B) -- (F) -- (C) -- cycle; % Shade another face
                                \fill[purple!20,opacity=0.5] (B) -- (F) -- (A) -- cycle; % Shade another face

                                \node[below] at (C) {pentagonal-base pyramid};

                            \end{tikzpicture}
                        </latex-image>
                    </image>
                </li>
            </ol>
          </p>
        </statement>
        <answer>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                           Axes is <m>1</m> 
                        </p>
                        <p>
                            Order is <m>4</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            Axes is <m>1</m>
                        </p>
                        <p>
                            Order is <m>5</m>
                        </p>
                    </li>
                </ol>
            </p>
        </answer>
      </exercise>

      <!-- <li xml:id="auto_4kz9ew29">
                <title>Problem 1</title>
                <p xml:id="auto_i4klr7yk">
                    Square <m>P(0,0)</m>, <m>Q(3,0)</m>, <m>R(3,3)</m>, <m>S(0,3)</m>. Rotate <m>90°</m> anticlockwise about the origin.
                </p>
                <p xml:id="auto_kd34uzl6">
                    Image: <m>P'(0,0)</m>, <m>Q'(0,3)</m>, <m>R'(-3,3)</m>, <m>S'(-3,0)</m>.
                </p>
                <p xml:id="auto_nun3ilzh">
                    Verification: <m>PQ = 3 = P'Q'</m>, <m>QR = 3 = Q'R'</m>, <m>RS = 3 = R'S'</m>, <m>SP = 3 = S'P'</m>. Diagonal <m>PR = 3\sqrt{2} = P'R'</m>. Congruent by SSS.
                </p>
            </li>
            <li xml:id="auto_c6mb5grk">
                <title>Problem 2</title>
                <p xml:id="auto_a9h2o1ho">
                    Point <m>A(4,1)</m> is rotated to <m>A'(-1,4)</m>. What is the angle of rotation?
                </p>
                <p xml:id="auto_qrtudvts">
                    Original angle with <m>x</m>-axis: <m>\tan^{-1}(1/4)</m>. Image angle: <m>\tan^{-1}(4/{-1}) = \tan^{-1}(-4) = 180° - 76° = 104°</m>. Difference <m>\approx 90°</m>.
                </p>
                <p xml:id="auto_pujgrl8f">
                    <m>OA = \sqrt{17}</m>, <m>OA' = \sqrt{17}</m>. Therefore, the rotation is <m>90°</m> anticlockwise.
                </p>
            </li>
            <li xml:id="auto_5izucc7y">
                <title>Problem 3 (3D)</title>
                <p xml:id="auto_828hyja1">
                    Regular tetrahedron <mdash/> axes of rotational symmetry:
                    <ol marker="(a)">
                        <li xml:id="auto_lhhly4qx">
                            <p xml:id="auto_l5bqjmtv">
                                4 axes through a vertex and the centre of the opposite face, each of order 3 (<m>120°</m>, <m>240°</m>).
                            </p>
                        </li>
                        <li xml:id="auto_qba3bwed">
                            <p xml:id="auto_sko66p2i">
                                3 axes through midpoints of opposite edges, each of order 2 (<m>180°</m>).
                            </p>
                        </li>
                    </ol>
                </p>
                <p xml:id="auto_gt6e8dk5">
                    Total: 12 rotational symmetries (including identity). Each face maps to another, so all faces are congruent.
                </p>
            </li> 

            <ol>
                        <li xml:id="auto_nnwc286t">
                            <p xml:id="auto_8ortoj79">
                                <alert>Q1:</alert> Why does rotation produce congruent figures? <mdash/> It preserves distances and angles (rigid/isometric transformation).
                            </p>
                        </li>
                        <li xml:id="auto_wgemcp8d">
                            <p xml:id="auto_skllqcd8">
                                <alert>Q2:</alert> <m>A(2,3)</m>, <m>B(5,3)</m>, <m>C(4,6)</m> rotated <m>180°</m> about the origin. Find the vertices and verify one pair of sides. <m>A'(-2,-3)</m>, <m>B'(-5,-3)</m>, <m>C'(-4,-6)</m>. <m>AB = 3</m>, <m>A'B' = 3</m> ✓.
                            </p>
                        </li>
                        <li xml:id="auto_wnllsflu">
                            <p xml:id="auto_kqj7l9kd">
                                <alert>Q3:</alert> Name 3 real-world objects with rotational symmetry. <mdash/> Clock, wheel, fan blade, etc.
                            </p>
                        </li>
                    </ol>
            
            
            -->
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table xml:id="auto_n1a2alx6">
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Use tracing paper rotation. Focus on <m>180°</m> first. Provide the distance formula. Use colour-coding for object/image. Pair work for support.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>Complete all rotations. Verify congruence using the distance formula. Explore 3D symmetry basics.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> Prove rotation preserves distances algebraically. Explore composition of rotations. Investigate 3D symmetry groups (cube, tetrahedron). Create a tessellation using rotation.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>

