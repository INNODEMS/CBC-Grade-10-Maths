    <axiom component="lesson-plan">
        <title>Practice and Application</title>
        <p xml:id="auto_khka4ddt">
            <alert>Expected Time:</alert> 10 minutes
        </p>
        <p xml:id="auto_avpnfz4p">
            <alert>Teacher Guidance:</alert> Work through examples using the two-step approach. Encourage learners to write the base area calculation and volume calculation as separate steps.
        </p>
        <p xml:id="auto_7nmy5y3e">
            <alert>Monitoring:</alert> Circulate during practice. Watch for learners who:
        </p>
        <p xml:id="auto_6o4zvet4">
            <ul>
                <li xml:id="auto_w9p362q2">
                    <p xml:id="auto_treyuzum">Forget to multiply by <m>\frac{1}{3}</m> (using the cylinder formula instead).</p>
                </li>
                <li xml:id="auto_rdbtsh6r">
                    <p xml:id="auto_uz0kune0">Confuse the height of the cone with the slant height.</p>
                </li>
                <li xml:id="auto_hvih6h2y">
                    <p xml:id="auto_g5kxrb28">Use the diameter instead of the radius in the formula.</p>
                </li>
                <li xml:id="auto_7ut8zp9h">
                    <p xml:id="auto_kpoanlhx">Forget to square the radius (writing <m>\pi r h</m> instead of <m>\pi r^2 h</m>).</p>
                </li>
            </ul>
        </p>
    </axiom>

        <example xml:id="auto_bsjt0be2">
            <statement>
               <sidebyside>
                 <p xml:id="auto_2bafcvfj">
                    Find the volume of the following cone (correct to 1 decimal place):
                </p>
                <image width="30%">
               <latex-image label="cone-volume">
                \begin{tikzpicture}
                     % Draw the entire cone with one uniform color
                    \fill[blue!40] (-2,0) arc (180:360:2 and 0.7) -- (2,0) arc (0:180:2 and 0.7) -- cycle;
                    \fill[blue!40] (-2,0) -- (0,4) -- (2,0) -- cycle;
                    
                    % Draw the base ellipse
                    \draw[thick] (-2,0) arc (180:360:2 and 0.7);
                    \draw[dashed] (2,0) arc (0:180:2 and 0.7);
                    
                    % Draw the cone's sides
                    \draw[thick] (-2,0) -- (0,4);
                    \draw[thick] (2,0) -- (0,4);
                    
                    % Draw the height
                    \draw[dashed] (0,0) -- (0,4);
                    \node[left] at (0.4,2) {28cm};
                    
                    % Draw the radius
                    \draw[dashed] (0,0) -- (2,0);
                    \node[below] at (1,0) {14 cm};
                \end{tikzpicture}
               </latex-image>
               </image>
               </sidebyside> 
            </statement>
            <solution>
                <p xml:id="auto_bix4o1qn">
                   Step 1: Find the area of the base .
                   <md>
                    <mrow>\text{Area of a Circle} = \amp \pi r^2 </mrow>
                    <mrow> = \amp \frac{22}{7} \times 14\, \text{cm} \times 14 \, \text{cm} </mrow>
                    <mrow> = \amp 616{cm}^2 </mrow>
                   </md>
                </p>
                <p xml:id="auto_nu6bi9x4">
                    Step 2: Calculate the volume
                    <md>
                        <mrow>\text{V} =\amp \frac{1}{3} \times \pi r^2\times H </mrow>
                        <mrow> = \amp 616\, \text{cm}^2 \times 28\,  \text{cm} </mrow>
                        <mrow>  = 17, 248\, \text{cm}^3 \amp </mrow>
                    </md>
                </p>
            </solution>
        </example> 

        <example xml:id="auto_qm5yq3r3">
            <statement>
                <p xml:id="auto_o3f1pye7">
                    The slant height of a cone is <m>13</m> cm and the radius of its base is <m>5</m> cm.
                </p>
                <p xml:id="auto_a4rdya93">
                    Find:
                </p>
                <p xml:id="auto_9yi6y1ia">
                    <ol marker="(a)">
                        <li xml:id="auto_9zlfcrz9">
                            <p xml:id="auto_7wfuyztd">
                                The vertical height of the cone.
                            </p>
                        </li>
                        <li xml:id="auto_0jstavn7">
                            <p xml:id="auto_b31ykpvc">
                                The volume of the cone (Give your answer in terms of <m>\pi</m> and then correct to two decimal places).
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <solution>
                <p xml:id="auto_mlr63m31">
                    <ol marker="(a)">
                        <li xml:id="auto_dxeieg2x">
                            <p xml:id="auto_oknozi8f">
                                In a cone, the radius, height and slant height form a right-angled triangle.
                            </p>
                            <p xml:id="auto_46zwosfw">
                                <m>l^2 = r^2 + h^2</m>
                            </p>
                            <p xml:id="auto_zvjwepzm">
                                Substitute <m>l = 13</m> and <m>r = 5</m>
                            </p>
                            <p xml:id="auto_uqr3tm7d">
                               <m>13^2 = 5^2 + h^2</m> 
                            </p>
                            <p xml:id="auto_f1kyp4qd">
                                <m>169 = 25 + h^2</m>
                            </p>
                            <p xml:id="auto_sa3kpyp9">
                                <m> h^2 = 144</m>
                            </p>
                            <p xml:id="auto_vvrtsqlc">
                                <m>h = 12 \;\text{ cm}</m>
                            </p>
                        </li>
                        <li xml:id="auto_iorzqqiq">
                            <p xml:id="auto_arbcqup5">
                                Use the volume formula
                            </p>
                            <p xml:id="auto_6x270xwc">
                                <md>
                                    <mrow> V =\amp \frac{1}{3}\pi r^2 h</mrow>
                                    <mrow> = \amp \frac{1}{3}\pi (5)^2 (12)</mrow>
                                    <mrow> = \amp \frac{1}{3}\pi (25)(12)</mrow>
                                    <mrow> = \amp \frac{1}{3}\pi (300)</mrow>
                                    <mrow> V = \amp 100\pi</mrow>
                                </md>
                            </p>
                            <p xml:id="auto_hz0g22qq">
                                Therefore, <m>V = 100\pi \;\text{ cm}^3</m>
                            </p>
                            <p xml:id="auto_47qqiq95">
                                Using <m>\pi \approx 3.142</m>
                            </p>
                            <p xml:id="auto_x2892hi0">
                                <m>V \approx 314.16 \;\text{ cm}^3</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </solution>
        </example>

    <axiom component="lesson-plan">
        <title>Assessment – Exit Ticket</title>
        <p xml:id="auto_zn9luspf">
            <alert>Expected Time:</alert> 5 minutes
        </p>
        <p xml:id="auto_v928fnwf">
            Learners complete individually to demonstrate understanding.
        </p>
        <p xml:id="auto_so4nkcc7">
            <alert>Question 1:</alert> An ice cream cone has a radius of <m>3</m> cm and a height of <m>8</m> cm. Estimate how much ice cream it can hold.
        </p>
        <p xml:id="auto_58w31mld">
            <alert>Question 2:</alert> Two cones have the same height of <m>84</m> cm but different radii. The first cone has a radius of <m>14</m> cm, and the second cone has a radius of <m>42</m> cm. Calculate and compare the volumes of the two cones. Which one has a larger volume?
        </p>
        <p xml:id="auto_7tvg52yh">
            <alert>Answer Key:</alert>
        </p>
        <p xml:id="auto_xh48p1dk">
            <alert>Q1:</alert> <m>V = \frac{1}{3} \times \pi \times 3^2 \times 8 = \frac{1}{3} \times 3.14 \times 9 \times 8 \approx 75.36 \; \text{cm}^3</m>.
        </p>
        <p xml:id="auto_dtf74jeg">
            <alert>Q2:</alert> First cone: <m>V = \frac{1}{3} \times \pi \times 14^2 \times 84 \approx 17\,248 \; \text{cm}^3</m>. Second cone: <m>V = \frac{1}{3} \times \pi \times 42^2 \times 84 \approx 155\,232 \; \text{cm}^3</m>. The second cone has a larger volume.
        </p>
    </axiom>

    <exercises>
        <exercise>
            <statement>
                <p>
                    A cone has a radius of 12 cm and a height of 18 cm. Calculate the volume of the cone.
                </p>
                <image width="30%">
               <latex-image label="cone-volume-exercise-two">
                \begin{tikzpicture}
                     % Draw the entire cone with one uniform color
                    \draw[thick] (-2,0) arc (180:360:2 and 0.7) -- (2,0) arc (0:180:2 and 0.7) -- cycle;
                    \draw[thick] (-2,0) -- (0,4) -- (2,0) -- cycle;
                    
                    % Draw the base ellipse
                    \draw[thick] (-2,0) arc (180:360:2 and 0.7);
                    \draw[dashed] (2,0) arc (0:180:2 and 0.7);
                    
                    % Draw the cone's sides
                    \draw[thick] (-2,0) -- (0,4);
                    \draw[thick] (2,0) -- (0,4);
                    
                    % Draw the height
                    \draw[dashed] (0,0) -- (0,4);
                    \node[left] at (0.3,2) {18cm};
                    
                    % Draw the radius
                    \draw[dashed] (0,0) -- (2,0);
                    \node[below] at (1,0) {12 cm};
                \end{tikzpicture}
               </latex-image>
               </image>
            </statement>
            <answer>
                <p>
                    <m>2714.34 \;\text{cm}^3</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    An ice cream cone has a radius of 3 cm and a height of 8 cm. Estimate how much ice cream it can hold?
                </p>
            </statement>
            <answer>
                <p>
                    <m>75.4 \;\text{cm}^3</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Two cones have the same height of 84 cm but different radii. The first cone has a radius of 14 cm, and the second cone has a radius of 42 cm. Calculate and compare the volumes of the two cones. Which one has a larger volume?
                </p>
            </statement>
            <answer>
                <p>
                    <m>V_1 = 17241.06 \;\text{cm}^3</m>
                </p>
                <p>
                    <m>V_2 = 155169.55 \;\text{cm}^3</m>
                </p>
                <p>
                    The second cone has the larger volume.
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A cone-shaped funnel has a radius of 9 cm and a height of 18 cm.How much water can the funnel hold? (Leave your answer in cubic meters.)
                </p>
                <image width="30%">
               <latex-image label="cone-volume-exercise-one">
                \begin{tikzpicture}
                     % Draw the entire cone with one uniform color
                    \draw[thick] (-2,0) arc (180:360:2 and 0.7) -- (2,0) arc (0:180:2 and 0.7) -- cycle;
                    \draw[thick] (-2,0) -- (0,4) -- (2,0) -- cycle;
                    
                    % Draw the base ellipse
                    \draw[thick] (-2,0) arc (180:360:2 and 0.7);
                    \draw[dashed] (2,0) arc (0:180:2 and 0.7);
                    
                    % Draw the cone's sides
                    \draw[thick] (-2,0) -- (0,4);
                    \draw[thick] (2,0) -- (0,4);
                    
                    % Draw the height
                    \draw[dashed] (0,0) -- (0,4);
                    \node[left] at (0.4,2) {18cm};
                    
                    % Draw the radius
                    \draw[dashed] (0,0) -- (2,0);
                    \node[below] at (1,0) {9 cm};
                \end{tikzpicture}
               </latex-image>
               </image>
            </statement>
            <answer>
                <p>
                    <m>1.53 \times 10^{-3}\;\text{m}^3</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                   A cone has an outer radius of 7 cm and an inner radius of 5 cm. The height of the cone is 12 cm.Calculate the volume of the hollow cone. 
                </p>
            </statement>
            <answer>
                <p>
                    <m>301.59 \;\text{cm}^3</m>
                </p>
            </answer>
        </exercise>
    </exercises>

