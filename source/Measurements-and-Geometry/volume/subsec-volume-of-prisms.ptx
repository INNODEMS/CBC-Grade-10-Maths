    <example xml:id="auto_bsirq6fe">
    <statement>

        <p xml:id="auto_ahwsjssi">
        Find the volume of the triangular prism below. 
        </p> 
        <image width="50%">
        <shortdescription></shortdescription>
        <latex-image label="Volume-triangular-prism-triangle">
            \begin{tikzpicture}
                % Define vertices of the triangular prism
                \coordinate (A) at (0,0,0);
                \coordinate (B) at (3,0,0);
                \coordinate (C) at (1.5,2,0);
                \coordinate (D) at (0,0,2);
                \coordinate (E) at (3,0,2);
                \coordinate (F) at (1.5,2,2);

                % Draw base triangle
                \draw[thin] (A) -- (B) -- (C) -- cycle;
                % Draw top triangle
                \draw[thin] (D) -- (E) -- (F) -- cycle;
                % Connect top and bottom faces
                \draw[thin] (A) -- (D);
                \draw[thin] (B) -- (E);
                \draw[thin] (C) -- (F);
                \draw[dashed] (F) -- (1.5,0,2)  ;
                \node[above] at (1.8,0.8,2) {12 cm};
                \draw[thick](1.5,0.3,2) --(1.8,0.3,2) --(1.8,0,2);
                % Label faces
                \node at (0.5,-1,0) {8 cm};
                <!-- \node at (1.5,1.5) {Top}; -->
            \end{tikzpicture}
        </latex-image>
    
    </image> 
    </statement>
    <solution>
        <p xml:id="auto_axb3j3hx">
        Step 1: Find the area of the base. 
        </p>
        <p xml:id="auto_vyqbkbkh">
            <md>
                <mrow> \text{area of a triangle} = \amp \frac{1}{2} b\, \times \,h</mrow>
                <mrow> = \amp \frac{1}{2} \times 8 \text{cm}  \times 12\, \text{cm} </mrow>
                <mrow> = \amp 48\, \text{cm}^2</mrow>
            </md>
        </p>
        <p xml:id="auto_4ct51ou6">
        Step 2: Multiply the area of the base by the height of the solid to find the volume 
        </p>
        <p xml:id="auto_eil7hwg5">
            <md>
                <mrow>\text{volume} = \amp  \text{area of base} \times \text{height}</mrow>
                <mrow> = \amp \frac{1}{2} b \times h \times H</mrow>
                <mrow> = \amp 48 \,\text{cm}^2 \times 12\, \text{cm} </mrow>
                <mrow> = \amp 576\, \text{cm}^3</mrow>
            </md>
        </p>
        <p xml:id="auto_4wg7gnd1">
            The volume of the triangular prism is<m> \, 576 \, \text{cm}^3</m>
        </p>
    </solution>
    </example>


    <axiom component="lesson-plan">
        <title>Assessment – Exit Ticket</title>
        <p xml:id="auto_bcbevejl">
            <alert>Expected Time:</alert> 5 minutes
        </p>
        <p xml:id="auto_z2eo657y">
            Learners complete individually to demonstrate understanding.
        </p>
        <p xml:id="auto_0n892q1z">
            <alert>Question 1:</alert> A rectangular prism has base <m>8 \times 2.5</m> metres and height <m>6</m> metres. Find its volume in m³.
        </p>
        <p xml:id="auto_7elnngg7">
            <alert>Question 2:</alert> A prism has a volume of <m>200 \; \text{cm}^3</m> and a height of <m>10</m> cm. What is the area of its base?
        </p>
        <p xml:id="auto_0qhg9mla">
            <alert>Question 3:</alert> Explain in your own words: Why does the formula Volume = Area of base × Height work for ANY prism, regardless of base shape?
        </p>
        <p xml:id="auto_8wadqaym">
            <alert>Answer Key:</alert>
        </p>
        <p xml:id="auto_fj49ayxa">
            <alert>Q1:</alert> Base area <m>= 8 \times 2.5 = 20 \; \text{m}^2</m>. <m>V = 20 \times 6 = 120 \; \text{m}^3</m>.
        </p>
        <p xml:id="auto_38g6dosu">
            <alert>Q2:</alert> <m>V = \text{Base area} \times h</m>, so <m>200 = \text{Base area} \times 10</m>, giving Base area <m>= 20 \; \text{cm}^2</m>.
        </p>
        <p xml:id="auto_kb2sb1z9">
            <alert>Q3:</alert> The base area tells us how many cubes fit in one layer, and the height tells us how many layers we stack. Multiplying these gives the total number of cubes (volume). The shape of the base does not matter — only its area.
        </p>
    </axiom>

        <exercises xml:id="exercises-volume-of-prisms">
            <exercise xml:id="auto_vznh0jzx">
                <statement>
                    <p xml:id="auto_uj2q15tf">
                        A triangular prism has base triangle area <m>15 \, \text{cm}^2</m> and height  <m>9 \, \text{cm}</m>. Find its volume.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_i80f8nwl">
                        <m>135 \, \text{cm}^3</m>.
                    </p>
                </answer>
            </exercise>
            <exercise xml:id="auto_hqk7y9cf">
                <statement>
                    <p xml:id="auto_dfcjthyf">
                        The area of the base of a prism is <m>18 \, \text{m}^2</m> and its height is <m>12 \, \text{m}</m>. Find the volume.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_2vaxpchh">
                        <m>216 \, \text{m}^3</m>.
                    </p>
                </answer>
            </exercise>
            <exercise xml:id="auto_31h3jz9q">
                <statement>
                    <p xml:id="auto_ixq83bor">
                        A prism has a volume of <m>200 \, \text{cm}^3</m> and a height of <m>10 \, \text{cm}</m>. Find the area of the base.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_nkgfondn">
                        <m>20 \, \text{cm}^2</m>.
                    </p>
                </answer>
            </exercise>
            <exercise xml:id="auto_wvemlyfd">
                <statement>
                    <p xml:id="auto_jap109u4">
                        A prism has a volume of <m>500 \, \text{m}^3</m> and a base area of <m>25 \, \text{m}^2</m>. Find the height of the prism.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_cjne3wws">
                        <m>20 \, \text{m}</m>.
                    </p>
                </answer>
            </exercise>
            <exercise xml:id="auto_4db249gv">
                <statement>
                    <p xml:id="auto_9vlhet3j">
                        A triangular prism has vertices at (0,0), (4,0) and (0,3). If the height of the prism is <m>15</m> units, find its volume.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_jqhp8zvt">
                        <m>90 \, \text{units}^3</m>.
                    </p>
                </answer>
            </exercise>
        
            <exercise xml:id="auto_i3p7vrwv">
                <statement>
                    <p xml:id="auto_3ksmzapw">
                        A prism has a base area <m>(x^2 + 4x) \, \text{cm}^2</m> and height <m>(x + 3) \, \text{cm}</m>. Write an algebraic expression for its volume.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_tth6uvck">
                        <m>(x^2 + 4x)(x + 3) \, \text{cm}^3</m>.
                    </p>
                </answer>
            </exercise>
            <exercise xml:id="auto_mtd5kyfk">
                <statement>
                    <p xml:id="auto_14y3funq">
                        A triangular prism has base triangle area <m>(2x - 3) \, \text{m}^2</m> and height <m>4 \, \text{m}</m>. Form the expression for its volume.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_jcfcg8jf">
                        <m>(2x - 3) \times 4 \, \text{m}^3</m>.
                    </p>
                </answer>
            </exercise>
            
            <exercise xml:id="auto_pd8aoxms">
                <statement>
                    <p xml:id="auto_eo76ui4a">
                        A rectangular greenhouse measures <m>15 \, \text{m}</m> long, <m>8 \, \text{m}</m> wide and <m>3 \, \text{m}</m> high. Find the volume of air inside the greenhouse.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_6r27nm2t">
                        <m>360 \, \text{m}^3</m>.
                    </p>
                </answer>
            </exercise>
            <exercise xml:id="auto_f2dwug9w">
                <statement>
                    <p xml:id="auto_ix3nusj7">
                        A solid block of wood is in the shape of a prism. Its triangular base has area <m>24 \, \text{cm}^2</m> and the prism height is <m>18 \, \text{cm}</m>. Find its volume.
                    </p>
                </statement>
                <answer>
                    <p xml:id="auto_jvhnc3bq">
                        <m>432 \, \text{cm}^3</m>.
                    </p>
                </answer>
            </exercise>
    <exercise xml:id="auto_arhrqlkm">
        
        <statement>
        <p xml:id="auto_glqrums9">
                A triangular prism has a volume of 360 cm³. The base of the triangular cross-section is 10 cm, and the height of the triangle is 9 cm.
            Find the length of the prism.
        </p>
        <image width="50%">
            <shortdescription></shortdescription>
            <latex-image label="Volume-triangular-triangular">
                \begin{tikzpicture}
                    % Define vertices of the triangular prism
                    \coordinate (A) at (0,0,0);
                    \coordinate (B) at (3,0,0);
                    \coordinate (C) at (1.5,2,0);
                    \coordinate (D) at (0,0,2);
                    \coordinate (E) at (3,0,2);
                    \coordinate (F) at (1.5,2,2);

                    % Draw base triangle
                    \draw[thin] (A) -- (B) -- (C) -- cycle;
                    % Draw top triangle
                    \draw[thin] (D) -- (E) -- (F) -- cycle;
                    % Connect top and bottom faces
                    \draw[thin] (A) -- (D);
                    \draw[thin] (B) -- (E);
                    \draw[thin] (C) -- (F);
                    \draw[dashed] (F) -- (1.5,0,2)  ;
                    \node[above] at (1.8,0.8,2) {$V = 360 cm^3$};
                    \draw[thick](1.5,0.3,2) --(1.8,0.3,2) --(1.8,0,2);
                    % Label faces
                    \node at (0.5,-1,0) {8 cm};
                \end{tikzpicture}
            </latex-image>
        
        </image> 
        </statement>
    </exercise>
    <exercise xml:id="auto_y6emhqhd">
        <statement>
        <p xml:id="auto_k5ge5of7">
            A water trough is in the shape of a triangular prism. The triangular cross-section has a base of 10 cm and a height of 12 cm. The trough is 2 meters long.
            How much water can it hold in liters? (Hint: 1 cm³ = 1 mL, and 1,000 mL = 1 L)
        </p>
        </statement>
    </exercise>
