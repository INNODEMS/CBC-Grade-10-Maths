    <axiom component="lesson-plan">
        <title>Differentiation</title>
        <p xml:id="auto_4jjxyrk5">
            <alert>Struggling Learners:</alert>
        </p>
        <p xml:id="auto_tp5iaplc">
            <ul>
                <li xml:id="auto_05qchny4">
                    <p xml:id="auto_xmdjtpqe">Provide physical unit cubes to manipulate.</p>
                </li>
                <li xml:id="auto_5yiz3npb">
                    <p xml:id="auto_c69afh2w">Use grid paper to draw and count squares.</p>
                </li>
                <li xml:id="auto_51ryf6ko">
                    <p xml:id="auto_tftglfli">Break the formula into two steps: (1) Find base area, (2) Multiply by height.</p>
                </li>
                <li xml:id="auto_zwx6jhqu">
                    <p xml:id="auto_nkvphzmf">Focus on rectangular prisms and cubes initially.</p>
                </li>
                <li xml:id="auto_gfjfzki0">
                    <p xml:id="auto_4rzcfcrk">Provide a formula reference card.</p>
                </li>
            </ul>
        </p>
        <p xml:id="auto_uxq6ahzx">
            <alert>On-Level Learners:</alert>
        </p>
        <p xml:id="auto_bo5vk305">
            <ul>
                <li xml:id="auto_vp5gh0qk">
                    <p xml:id="auto_r79ly3r0">Complete all practice problems independently.</p>
                </li>
                <li xml:id="auto_tj207trg">
                    <p xml:id="auto_srn8hln0">Explain the formula to a peer in their own words.</p>
                </li>
            </ul>
        </p>
        <p xml:id="auto_xih2jaal">
            <alert>Advanced Learners:</alert>
        </p>
        <p xml:id="auto_9oq1biyn">
            <ul>
                <li xml:id="auto_fcmmdqey">
                    <p xml:id="auto_fu8ldgow">Introduce prisms with complex polygon bases (hexagon, octagon).</p>
                </li>
                <li xml:id="auto_4bpkvt1c">
                    <p xml:id="auto_m7khx2nr">Challenge with working backwards (given volume, find dimensions).</p>
                </li>
                <li xml:id="auto_yl9b1upy">
                    <p xml:id="auto_ztirx55a">Explore how changing dimensions affects volume (doubling, tripling).</p>
                </li>
                <li xml:id="auto_w4tcxsc9">
                    <p xml:id="auto_zyqfzk7o">Connect to real-world applications (storage, construction).</p>
                </li>
            </ul>
        </p>
        <p xml:id="auto_9svb9qzo">
            <alert>Extension Activity — Build a Bridge with Triangular Prisms:</alert>
        </p>
        <p xml:id="auto_9acq9xbd">
            Work in groups of 5 learners.
        </p>
        <p xml:id="auto_2kugyi49">
            <ol markers="1.">
                <li xml:id="auto_5w8mgihy">
                    <p xml:id="auto_h0k490dk">Materials: Cardboard or wooden sticks, ruler, calculator.</p>
                </li>
                <li xml:id="auto_j8r6kgym">
                    <p xml:id="auto_ktgtxf7s">Construct a bridge model with triangular prism supports.</p>
                </li>
                <li xml:id="auto_gy4h8icr">
                    <p xml:id="auto_kofs2j93">Measure the base, height of the triangle, and length of the prism.</p>
                </li>
                <li xml:id="auto_ul42adbu">
                    <p xml:id="auto_x3qgfet2">Calculate the volume of the prism-shaped supports using <m>V = \frac{1}{2}bh \times H</m>.</p>
                </li>
                <li xml:id="auto_grkmasbl">
                    <p xml:id="auto_tqn3n2uz">Compare different bridge designs and discuss which structure is strongest.</p>
                </li>
            </ol>
        </p>
    </axiom>

