        <statement>
            <p xml:id="auto_oej7vp1i">
        A cuboid has a volume of 600 cm³, a length of 10 cm, and a width of 5 cm.
       Find its height.
    </p>

                <image width="50%">
                <latex-image label="cuboid-example-one-b">
                    \begin{tikzpicture}
                          % Define points for the cuboid
                        \coordinate (A) at (0,0,0);
                        \coordinate (B) at (6,0,0);
                        \coordinate (C) at (6,4,0);
                        \coordinate (D) at (0,4,0);
                        \coordinate (E) at (0,0,5);
                        \coordinate (F) at (6,0,5);
                        \coordinate (G) at (6,4,5);
                        \coordinate (H) at (0,4,5);
                        
                        % Draw the front face
                        \draw[thick] (A) -- (B) -- (C) -- (D) -- cycle;
                        % Draw the back face
                        \draw[thick] (E) -- (F) -- (G) -- (H) -- cycle;
                        % Draw the top face
                        \draw[thick] (D) -- (C) -- (G) -- (H) -- cycle;
                        % Draw the side face
                        \draw[thick] (B) -- (C) -- (G) -- (F) -- cycle;
                        
                        % Draw the edges
                        \draw[thick] (A) -- (B) -- (C) -- (D) -- cycle;
                        \draw[thick] (E) -- (F) -- (G) -- (H) -- cycle;
                        \draw[thick] (A) -- (E);
                        \draw[thick] (B) -- (F);
                        \draw[thick] (C) -- (G);
                        \draw[thick] (D) -- (H);                      
                        % Adding dimensions
                        \node[below] at (1,-2,0) {$V = 5 cm$};
                        
                        \node[right] at (7,3,3) {10 cm};
                        
                        \node[right] at (6,0,2.5) {?};
                    \end{tikzpicture}
                </latex-image>
                 </image>
            </statement>
    </exercise>
