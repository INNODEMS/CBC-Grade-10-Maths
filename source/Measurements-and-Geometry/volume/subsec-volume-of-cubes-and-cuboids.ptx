            <exercise xml:id="auto_45wnk3n1">
                <statement>
                    <p xml:id="auto_m99fjwfo">
                        A crate measures <m>(x + 2)</m> cm by <m>(x + 3)</m> cm by <m>5</m> cm. Form an expression for its volume.
                    </p>
