    <exercise xml:id="auto_s2mcjx11">
        <statement>
    <p xml:id="auto_vrx0viut">
        If the length, width, and height of a cuboid are all doubled,
        by what factor does the volume increase?
    </p>
    
          <image width="30%">
        <latex-image label="cuboid-three-op">
            \begin{tikzpicture}
                 % Define cuboid dimensions
                \def\cubex{1.5} % Length
                \def\cubey{1} % Width
                \def\cubez{1.0} % Height

                % Draw the base face with grey fill
                \draw[thick] (0,0,0) -- ++(\cubex,0,0) -- ++(0,\cubey,0) -- ++(-\cubex,0,0) -- cycle;

                % Draw the front face
                \draw[thick] (0,0,0) -- ++(\cubex,0,0) -- ++(0,\cubey,0) -- ++(-\cubex,0,0) -- cycle;

                % Draw the top face
                \draw[thick] (0,0,\cubez) -- ++(\cubex,0,0) -- ++(0,\cubey,0) -- ++(-\cubex,0,0) -- cycle;

                % Draw the side face
                \draw[thick] (\cubex,0,0) -- ++(0,0,\cubez);
                \draw[thick] (0,\cubey,0) -- ++(0,0,\cubez);
                \draw[thick] (\cubex,\cubey,0) -- ++(0,0,\cubez);

                % Draw hidden lines
                \draw[dashed] (0,0,0) -- ++(0,0,\cubez);
                \draw[dashed] (0,0,\cubez) -- ++(0,\cubey,0);
                \draw[dashed] (0,\cubey,\cubez) -- ++(\cubex,0,0);
            \end{tikzpicture}
        </latex-image>
    </image>  <image width="50%">
        <latex-image label="cuboid-three-o">
            \begin{tikzpicture}
                 % Define cuboid dimensions
                \def\cubex{3} % Length
                \def\cubey{2} % Width
                \def\cubez{1.5} % Height

                % Draw the base face with grey fill
                \draw[thick] (0,0,0) -- ++(\cubex,0,0) -- ++(0,\cubey,0) -- ++(-\cubex,0,0) -- cycle;

                % Draw the front face
                \draw[thick] (0,0,0) -- ++(\cubex,0,0) -- ++(0,\cubey,0) -- ++(-\cubex,0,0) -- cycle;

                % Draw the top face
                \draw[thick] (0,0,\cubez) -- ++(\cubex,0,0) -- ++(0,\cubey,0) -- ++(-\cubex,0,0) -- cycle;

                % Draw the side face
                \draw[thick] (\cubex,0,0) -- ++(0,0,\cubez);
                \draw[thick] (0,\cubey,0) -- ++(0,0,\cubez);
                \draw[thick] (\cubex,\cubey,0) -- ++(0,0,\cubez);

                % Draw hidden lines
                \draw[dashed] (0,0,0) -- ++(0,0,\cubez);
                \draw[dashed] (0,0,\cubez) -- ++(0,\cubey,0);
                \draw[dashed] (0,\cubey,\cubez) -- ++(\cubex,0,0);
            \end{tikzpicture}
        </latex-image>
    </image>
</statement>
</exercise>

   
