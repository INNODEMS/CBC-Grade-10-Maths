                        % Draw the front face
                        \draw[thick] (A) -- (B) -- (C) -- (D) -- cycle;
                        % Draw the back face
                        \draw[thick] (E) -- (F) -- (G) -- (H) -- cycle;
                        % Draw the top face
                        \draw[thick] (D) -- (C) -- (G) -- (H) -- cycle;
                        % Draw the side face
                        \draw[thick] (B) -- (C) -- (G) -- (F) -- cycle;
                        
                        % Draw the edges
                        \draw[thick] (A) -- (B) -- (C) -- (D) -- cycle;
                        \draw[thick] (E) -- (F) -- (G) -- (H) -- cycle;
                        \draw[thick] (A) -- (E);
                        \draw[thick] (B) -- (F);
                        \draw[thick] (C) -- (G);
                        \draw[thick] (D) -- (H);                      
                        % Adding dimensions
