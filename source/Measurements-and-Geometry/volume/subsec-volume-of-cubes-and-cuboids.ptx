                        <exercise xml:id="auto_60usardi">
                <statement>
                    <p xml:id="auto_c4n23zdt">
                        A packing box has volume <m>360 \, \text{cm}^3</m> and base area <m>15 \, \text{cm}^2</m>. Find its height.
