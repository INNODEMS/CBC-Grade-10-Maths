    <exercises xml:id="exercises-cubes-and-cuboids">
        <exercise xml:id="auto_bxlkwmui">
            <statement>
                <p xml:id="auto_3aem4g2x">
                    Find the volume of the following cube whose side is <m>5\, \text{cm}.</m> 
                </p>
            </statement>
            <answer>
                <p xml:id="auto_netc226d">
                    <m>125 \, \text{cm}^3</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_br1a499q">
            <statement>
                <p xml:id="auto_4qc6pu9z">
                    A cube has a side length of <m>12 \, \text{cm}</m>. Find its volume.
                </p>
                    <image width="50%">
                            <latex-image label="cube-exercise-one-two">
                                \begin{tikzpicture}
                                        % Define points for the cube
                                        \coordinate (A) at (-1,-1,0);
                                        \coordinate (B) at (1,-1,0);
                                        \coordinate (C) at (1,1,0);
                                        \coordinate (D) at (-1,1,0);
                                        \coordinate (E) at (-1,-1,2);
                                        \coordinate (F) at (1,-1,2);
                                        \coordinate (G) at (1,1,2);
                                        \coordinate (H) at (-1,1,2);
                                        
                                        % Fill the base of the cube accurately
                                        \draw[thick] (A) -- (B) -- (C) -- (D) -- cycle; 
                                        \draw[thick] (E) -- (F) -- (G) -- (H) -- cycle;  
                                        \draw[thick] (E) -- (F) -- (B) -- (A) -- cycle;  
                                        \draw[thick] (C) -- (D) -- (H) -- (G) -- cycle;  

                                        % Draw edges of the cube
                                        \draw (A) -- (B) -- (C) -- (D) -- cycle; % Bottom face (Base)
                                        \draw (E) -- (F) -- (G) -- (H) -- cycle; % Top face
                                        \draw (A) -- (E) ;
                                        \draw (B) -- (F);
                                        \draw (C) -- (G);
                                        \draw (D) --(H);
                                        % Add dimensions without angle brackets
                                        \draw (E) -- (F) node[midway, below] {12 cm}; 
                                \end{tikzpicture}
                            </latex-image>
                    </image>
            </statement>
            <answer>
                <p xml:id="auto_04c4glw1">
                    <m>1728 \, \text{cm}^3</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_2hehrrnn">
            <statement>
                <p xml:id="auto_aaug01cg">
                    The cube below has a volume of <m>343 \, \text{cm}^3</m>. Find the length of one side of the cube.
                </p>
                <image source="cube-volume.jpg" width="50%">
                    <shortdescription></shortdescription>
                </image>
            </statement>
            <answer>
                <p xml:id="auto_pn16h2cg">
                    <m>7 \, \text{cm}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_ngsts4b5">
            <statement>
                <p xml:id="auto_2og8p9b4">
                    If the side length of a cube is doubled, by what factor does the volume increase?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_aprkn6u8">
                    <m>8</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_0ymwwg5i">
            <statement>
                <p xml:id="auto_94fe2lf9">
                    A big cube is made by stacking <m>8</m> smaller identical cubes together. If the volume of each small cube is <m>27 \, \text{cm}^3</m>, find the volume of the big cube.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_4y0cwscs">
                    <m>216 \, \text{cm}^3</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_wgu1mnle">
            <statement>
                <p xml:id="auto_xdzazd9a">
                    <ol marker="(a)">
                        <li xml:id="auto_ca2o8ixt">A cubical water tank is <m>1 \, \text{m}</m> on each side. How many liters of water can it hold when full?</li>
                        <li xml:id="auto_f80z3b82">A cubical water tank is <m>2 \, \text{m}</m> on each side. If it is filled completely, how many liters of water can it hold?</li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_ss1sanwd">
                    <ol marker="(a)">
                        <li xml:id="auto_9r1yc7v4"><m>1,000 \, \text{liters}</m></li>
                        <li xml:id="auto_07x4d329"><m>8,000 \, \text{liters}</m></li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_an6qrapp">
            <statement>
                <p xml:id="auto_oneqg7k9">
                    A sugar cube has a side length of <m>1 \, \text{cm}</m>. If <m>1,000</m> sugar cubes are stacked together to form a larger cube, find the volume of the larger cube.
                </p>
