                \draw[dashed,blue!30] (1,3) arc (0:180:1 and 0.3);
    
                % Draw the slant height lines
               \draw[thick,blue!60] (-2,0) -- (-1,3);
               \draw[thick,blue!60] (2,0) -- (1,3);
               \draw[dashed,blue!30] (0,0) --(0,3) ;
               \draw[dashed,blue!30] (0,3) --(-1,3);
               \draw[dashed,blue!30] (0,0) --(-2,0);
    
               % Labeling the diagram
               <!-- \node[left] at (0,1.5) {$h$}; -->
