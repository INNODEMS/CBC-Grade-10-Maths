    <exercise  label="ex-25-3-reflections">
        <stack label="stk-25-3-reflections" source="stack/top/2-0-Measurement-Geometry/2-2-Reflection-and-Congruence/2-2-5-Determining-the-Equation-of-a-Mirror-Line/25-3-Reflections.xml" />
    </exercise>

    <exercises xml:id="exercises-determining-the-equation-of-a-mirror-line-given-an-object-and-its-image">
      <exercise xml:id="auto_6rgjlk9d">
        <statement>
          <p xml:id="auto_fp1qhdtb">
            Determine if the transformation is a reflection. If it is a reflection, what is the equation of the mirror line?
          </p>

          <sidebyside>
            <image>
            <shortdescription>Line of reflection</shortdescription>
            <latex-image label="Object_image_exercise1">
            \begin{tikzpicture}
                
                % Draw the grid lines
                \draw[step=1,gray,very thin] (-5,-5) grid (5,5);

                % Draw the axes
                \draw[thin,-&gt;] (-5,0) -- (5,0) node[right] {x-axis};
                \foreach \x in {-4,...,4}{
                \draw(\x,.25)--(\x,-.25) node[below]{\x};
                }

                \draw[thin,-&gt;] (0,-5) -- (0,5) node[above] {y-axis}; 
                \foreach \y/\ytext in {-4/-4,-3/-3,-2/-2,-1/-1,0/0,1/1, 2/2, 3/3, 4/4}
                \draw[shift={(0,\y)}] (2pt,0pt) -- (-2pt,0pt) node[left] {$\ytext$};


                % Draw the original object
                \fill[blue,opacity=0.3] (1,2) -- (3,4) -- (4,1) --cycle;
                \draw[blue,thick] (1,2) -- (3,4) -- (4,1) -- cycle;
                \node[blue] at (.8,2) {A};
                \node[blue] at (3.2,4) {B};
                \node[blue] at (4.2,.8) {C};
                

                % Calculate and draw the image
                \fill[red,opacity=0.3](3,0) -- (5,2) -- (2,3) -- cycle;
                \draw[red,thick] (3,0) -- (5,2) -- (2,3) -- cycle;
                \node[red] at (2.8,0) {A'};
                \node[red] at (5.2,2) {B'};
                \node[red] at (2,3.2){C'};
                
            \end{tikzpicture}
            </latex-image>
        </image>

        <image>
            <shortdescription>Line of reflection</shortdescription>
            <latex-image label="Object_image_exercise2">
            \begin{tikzpicture}
                
                % Draw the grid lines
                \draw[step=1,gray,very thin] (-5,-5) grid (5,5);

                % Draw the axes
                \draw[thin,-&gt;] (-5,0) -- (5,0) node[right] {x-axis};
                \foreach \x in {-4,...,4}{
                \draw(\x,.25)--(\x,-.25) node[below]{\x};
                }

                \draw[thin,-&gt;] (0,-5) -- (0,5) node[above] {y-axis}; 
                \foreach \y/\ytext in {-4/-4,-3/-3,-2/-2,-1/-1,0/0,1/1, 2/2, 3/3, 4/4}
                \draw[shift={(0,\y)}] (2pt,0pt) -- (-2pt,0pt) node[left] {$\ytext$};


                % Draw the original object
                \fill[orange,opacity=0.3] (-4,-1) -- (-1,-1) -- (-1,-4) -- (-4,-4) --cycle;
                \draw[orange,thick] (-4,-1) -- (-1,-1) -- (-1,-4) -- (-4,-4) -- cycle;
                \node[orange] at (-4.2,-1) {A};
                \node[orange] at (-.8,-1) {B};
                \node[orange] at (-.8,-4) {C};
                \node[orange] at (-4.2,-4) {D};
                

                % Calculate and draw the image
                \fill[purple,opacity=0.3](1,4) -- (4,4) -- (4,1) -- (1,1) -- cycle;
                \draw[purple,thick] (1,4) -- (4,4) -- (4,1) -- (1,1) -- cycle;
                \node[purple] at (1,4.2) {A'};
                \node[purple] at (4,4.2) {B'};
                \node[purple] at (4.2,1){C'};
                \node[purple] at (.8,1){D'};

            \end{tikzpicture}
            </latex-image>
        </image>
        </sidebyside>
        </statement>
        <answer>
            <p>
                <ol marker="(i)">
                    <li>
                        <p>
                            Neither a Reflection nor a Rotation
                        </p>
                    </li>
                    <li>
                        <p>
                            Neither a Reflection nor a Rotation
                        </p>
                    </li>
                </ol>
            </p>
        </answer>

      </exercise>

      <exercise xml:id="auto_4tbofx7k">
        <statement>
            <p xml:id="auto_eolr3t9o">
            The vertices of a triangle are <m>A(1,2),\, B(3,4)\text{ and }C(5,4).</m> The vertices of the  image are <m>A'(1,-2),\, B'(3,-4)\text{ and }C'(5,-4).</m>
            Find the equation of the line of reflection.
            </p>
        </statement>
        <answer>
            <p>
                <m>y = 0</m>
            </p>
        </answer>
      </exercise>

      <exercise xml:id="auto_5urtn6tt">
      <statement>
        <p xml:id="auto_ytox4tj7">
          The vertices of a a letter <m>V</m> are <m>P(-3,4),\,Q(-3,2)\text{ and }R(-1,2).</m> The vertices of the  image are <m>P'(-1,2),\, Q'(-1,0)\text{ and }R'(1,0).</m>
           Find the equation of the line of reflection.
        </p>
      </statement>
      <answer>
        <p xml:id="auto_0cdafc52">
          The line of reflection is the line <m>y = x - 1.</m>
        </p>
      </answer>
      </exercise>

      <exercise xml:id="auto_4i8a6s2s">
        <statement>
          <p xml:id="auto_mvaywn3m">
            <m>O(0,0)</m> is the centre of a circle of radius <m>2\,cm.</m> If <m>O'(2,0)</m> is the reflection of the centre of the circle, find the equation of the line of reflection. 
          </p>
        </statement>
        <answer>
          <p xml:id="auto_a7r8vo9m">
            The line of reflection is the vertical line <m>x = 1.</m>
          </p>
        </answer>
      </exercise>
      <exercise xml:id="auto_cci6zbhd">
        <statement>
          <p xml:id="auto_6a8alpwl">
            The vertices of a triangle are <m>A(1,2),\, B(3,4)\text{ and }C(5,4).</m> The vertices of the  image are <m>A'(-1,2),\, B'(-3,4)\text{ and }C'(-5,4).</m>
             Find the equation of the line of reflection.
          </p>
        </statement>
        <answer>
          <p xml:id="auto_h7jkulra">
            The line of reflection is the y-axis and its equation is <m>x = 0.</m>
          </p>
        </answer>
      </exercise>
      <exercise xml:id="auto_3ipz057t">
        <statement>
          <p xml:id="auto_71yrntlo">
            The vertices of a triangle are <m>A(1,2),\, B(3,4)\text{ and }C(5,4).</m> The vertices of the  image are <m>A'(-1,-2),\, B'(-3,-4)\text{ and }C'(-5,-4).</m>
             Find the equation of the line of reflection.
          </p>
        </statement>
        <answer>
          <p xml:id="auto_g1m0z970">
            The line of reflection is the line <m>y = -x.</m>
          </p>
        </answer>
      </exercise>
    </exercises>
    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table xml:id="auto_swlra71v">
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Provide pre-plotted graphs and allow physical folding activities. Start with axis mirror lines (<m>x = 0</m>, <m>y = 0</m>). Provide a step-by-step worksheet with the five-step method. Review midpoint and gradient formulas before the lesson. Use colour coding to match object points with their images.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above. Learners complete all problems, verify that all midpoints lie on the mirror line, and recognise patterns in common mirror lines.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> 1) Given quadrilateral <m>A(1,1), B(3,1), C(4,3), D(2,4)</m> and image <m>A'(-1,-1), B'(-1,-3), C'(-3,-4), D'(-4,-2)</m>, find the equation of the mirror line. 2) Point <m>P(a,b)</m> is reflected in <m>y = x</m> then in <m>y = 0</m>. Find the single mirror line mapping <m>(a,b)</m> to the final image. 3) A laser beam from <m>A(1,4)</m> hits a mirror at <m>M(3,0)</m> and reflects to <m>B(5,4)</m>. Verify the mirror is the x-axis. 4) Find the mirror line that maps <m>(2,3)</m> to <m>(6,7)</m>.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>
