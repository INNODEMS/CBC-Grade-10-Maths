        </image>

        <image>
          <latex-image label="SSS2">
            \begin{tikzpicture}
              % Draw the another triangle
              \draw[thick] (2,3) -- (4,0) -- (1,-2) -- cycle;

              \draw[black] (3.1,1.6)--(2.9,1.4);
              \draw[black] (2.2,-1.3)--(2.2,-1);
              \draw[black] (2.5,-.8)--(2.5,-1.2);
              \draw[black] (1.8,1)--(1.4,1);
              \draw[black] (1.8,0.8)--(1.4,.8);
              \draw[black] (1.8,0.6)--(1.4,.6);
            \end{tikzpicture}
          </latex-image>
        </image>

        <image>
          <latex-image label="RHS2">
            \begin{tikzpicture}
            \usetikzlibrary{angles,quotes} % Required for angle annotations

              % Triangle PQR
              \coordinate (P) at (4,5);
              \coordinate (Q) at (4,0);
              \coordinate (R) at (0,0);

              \draw[thick] (P) -- (Q) -- (R) -- cycle;

              \draw[draw=blue] plot coordinates{(P)(Q)(R)} pic["$ $", draw=orange, angle eccentricity=1.2, angle radius=1cm]
              {angle=R--P--Q};; 

              \draw[draw=blue] (3.6,0) -- (3.6,0.4) -- (4,0.4); 
