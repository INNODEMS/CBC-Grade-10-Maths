    <exercises xml:id="exercises-congruence">
      <exercise xml:id="auto_2gusvosz">
      <statement>
        <p xml:id="auto_4cputlq5">
          Identify figures that are congruent.
        </p>

        <image>
          <latex-image label="shapes_exercise">
            \begin{tikzpicture}
            % Grid
            \draw[step=1,gray,very thin] (-9,-6) grid (9,6);

            % a
            \fill[red,opacity=0.3](-9,6) -- (-7,4) -- (-9,2) -- (-3,4) -- cycle;
            \draw[red,thick] (-9,6) -- (-7,4) -- (-9,2) -- (-3,4) -- cycle;
            \node at (-7.2,4) {\Large a};

            % b
            \fill[orange,opacity=0.3](-2,2) -- (-2,5) -- (-1,5) -- (-1,4) --(0,4) -- cycle;
            \draw[orange,thick] (-2,2) -- (-2,5) -- (-1,5) -- (-1,4) --(0,4) -- cycle;
            \node at (-1.2,3.6) {\Large b};

            % c
            \fill[yellow,opacity=0.3](-7,1) -- (-6,1) -- (-6,2) -- (-5,2) --(-5,-1) -- cycle;
            \draw[yellow,thick] (-7,1) -- (-6,1) -- (-6,2) -- (-5,2) --(-5,-1) -- cycle;
            \node at (-5.8,0.7) {\Large c};

            % d
            \fill[green,opacity=0.3](2,3) -- (5,3) -- (4,5) -- (1,5) -- cycle;
            \draw[green,thick] (2,3) -- (5,3) -- (4,5) -- (1,5) -- cycle;
            \node at (3,4) {\Large d};

            % e
            \fill[blue,opacity=0.3](-4,1) -- (-2,1) -- (-1,-1) -- (-3,-1) -- cycle;
            \draw[blue,thick] (-4,1) -- (-2,1) -- (-1,-1) -- (-3,-1) -- cycle;
            \node at (-2.5,0) {\Large e};

            % f
            \fill[purple,opacity=0.3](-4,-2) -- (-1,-2) -- (0,-4) -- (-3,-4) -- cycle;
            \draw[purple,thick] (-4,-2) -- (-1,-2) -- (0,-4) -- (-3,-4) -- cycle;
            \node at (-2.2,-3) {\Large f};

            % g
            \fill[blue,opacity=0.3](-9,-1) -- (-7,-1) -- (-6,-2) -- (-8,-2) -- cycle;
            \draw[blue,thick] (-9,-1) -- (-7,-1) -- (-6,-2) -- (-8,-2) -- cycle;
            \node at (-7.8,-1.4) {\Large g};

            % h
            \fill[orange,opacity=0.3](-1,2) -- (1,3) -- (3,2) -- (1,1) -- cycle;
            \draw[orange,thick] (-1,2) -- (1,3) -- (3,2) -- (1,1) -- cycle;
            \node at (1,2) {\Large h};

            % i
