        <image>
          <latex-image label="RHS1">
            \begin{tikzpicture}
              \usetikzlibrary{angles,quotes} % Required for angle annotations

              % Triangle ABC
              \coordinate (A) at (-5,5);
              \coordinate (B) at (-5,0);
              \coordinate (C) at (-1,0);

              \draw[thick] (A) -- (B) -- (C) -- cycle;

              \draw[draw=blue] plot coordinates{(A)(B)(C)} pic["$ $", draw=orange, angle eccentricity=1.2, angle radius=1cm]
              {angle=B--A--C};; 

              \draw[draw=blue] (-4.6,0) -- (-4.6,0.4) -- (-5,0.4); 

