          </latex-image>
        </image>

        <image>
          <latex-image label="ASA1">
            \begin{tikzpicture}
              \usetikzlibrary{angles,quotes} % Required for angle annotations

              % Triangle ABC
              \coordinate (A) at (-4,4);
              \coordinate (B) at (-1,1);
              \coordinate (C) at (-8,1);

              \draw[thick] (A) -- (B) -- (C) -- cycle;

              \draw[draw=blue] plot coordinates{(A)(B)(C)} pic["$ $", draw=orange, angle eccentricity=1.2, angle radius=1cm]
              {angle=C--A--B};; 

              \draw[draw=blue] plot coordinates{(A)(B)(C)} pic["$ $", draw=blue, angle eccentricity=1.2, angle radius=1cm]
              {angle=A--B--C};;

              \draw[black] (-2.6,2.4)--(-2.4,2.6);  
