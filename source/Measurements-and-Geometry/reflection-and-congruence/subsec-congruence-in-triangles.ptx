            \draw[green,thick] (0,-1) -- (1,-2) -- (2,-1) -- (1,-4)-- cycle;
            \node at (1,-2.2) {\Large j};

            % k
            \fill[purple,opacity=0.3](4,-1) -- (3,-3) -- (4,-5) -- (5,-3) -- cycle;
            \draw[purple,thick] (4,-1) -- (3,-3) -- (4,-5) -- (5,-3)-- cycle;
            \node at (4,-3) {\Large k};

          \end{tikzpicture}
          </latex-image>
          
        </image>
      </statement>
      <answer>
        <p>
          b and c
        </p>
        <p>
          e and i
        </p>
        <p>
          f and d
        </p>
        <p>
          h and k
        </p>
