    <example xml:id="auto_obsviaky">
      <statement>
        <p>
          How many planes of symmetry does a square based pyramid have?
        </p>
        <image width="30%">
          <latex-image label="sq_pyramid_ex">
            \begin{tikzpicture}
              % Coordinates
              \coordinate (A) at (-1,0.7); % Bottom left corner
              \coordinate (B) at (0,0); % Bottom right corner
              \coordinate (C) at (1.5,.7); % Top right corner
              \coordinate (D) at (0.4,1.5); % Top left corner
              \coordinate (E) at (0,5); % Apex of the pyramid
              \coordinate (F) at (-.3,1.1);
              \coordinate (G) at (.8,.3);
              \coordinate (H) at (1,1.1);
              \coordinate (I) at (-.5,.4);

              % Draw base
              \draw[thick] (A) -- (B) -- (C);
              \draw[thick, dashed] (C) -- (D) -- (A);

              %  Base of the pyramid
              \fill[cyan,opacity=0.5] (A) -- (B) -- (C) -- (D) -- cycle;
              
              % Draw pyramid edges
              \draw[thick] (E) -- (A);
              \draw[thick] (E) -- (B);
              \draw[thick] (E) -- (C);
              \draw[style=dashed,thick] (E) -- (D);



            \end{tikzpicture}
          </latex-image>
        </image>
      </statement>
      <solution>
        <p>
          A square based pyramid has <m>4</m> planes of symmetry as shown below.
        </p>

        <sidebyside>
        <image >
          <latex-image label="sq_pyramid_1">
            \begin{tikzpicture}
              % Coordinates
              \coordinate (A) at (-1,0.7); % Bottom left corner
              \coordinate (B) at (0,0); % Bottom right corner
              \coordinate (C) at (1.5,.7); % Top right corner
              \coordinate (D) at (0.4,1.5); % Top left corner
              \coordinate (E) at (0,5); % Apex of the pyramid
              \coordinate (F) at (-.3,1.1);
              \coordinate (G) at (.8,.3);
              \coordinate (H) at (1,1.1);
              \coordinate (I) at (-.5,.4);

              % Draw base
              \draw[thick] (A) -- (B) -- (C);
              \draw[thick, dashed] (C) -- (D) -- (A);
              
              % Draw pyramid edges
              \draw[thick] (E) -- (A);
              \draw[thick] (E) -- (B);
              \draw[thick] (E) -- (C);
              \draw[style=dashed,thick] (E) -- (D);

              % Draw planes of symmetry
              \begin{scope}[opacity=0.3]
                  % Plane 1: through SA and SC
                  \fill[blue] (E) -- (A) -- (C) -- cycle;


                  % Plane 5: Base of the pyramid
                  \fill[cyan] (A) -- (B) -- (C) -- (D) -- cycle;
              \end{scope}
            \end{tikzpicture}
          </latex-image>
        </image>

        <image>
          <latex-image label="sq_pyramid_2">
            \begin{tikzpicture}
              % Coordinates
              \coordinate (A) at (-1,0.7); % Bottom left corner
              \coordinate (B) at (0,0); % Bottom right corner
              \coordinate (C) at (1.5,.7); % Top right corner
              \coordinate (D) at (0.4,1.5); % Top left corner
              \coordinate (E) at (0,5); % Apex of the pyramid
              \coordinate (F) at (-.3,1.1);
              \coordinate (G) at (.8,.3);
              \coordinate (H) at (1,1.1);
              \coordinate (I) at (-.5,.4);

              % Draw base
              \draw[thick] (A) -- (B) -- (C);
              \draw[thick, dashed] (C) -- (D) -- (A);
              
              % Draw pyramid edges
              \draw[thick] (E) -- (A);
              \draw[thick] (E) -- (B);
              \draw[thick] (E) -- (C);
              \draw[style=dashed,thick] (E) -- (D);

              % Draw planes of symmetry
              \begin{scope}[opacity=0.3]

                  % Plane 2: through SB and SD
                  \fill[red] (E) -- (B) -- (D) -- cycle;

                  % Plane 5: Base of the pyramid
                  \fill[cyan] (A) -- (B) -- (C) -- (D) -- cycle;
              \end{scope}
            \end{tikzpicture}
          </latex-image>
        </image>

        <image>
          <latex-image label="sq_pyramid_3">
            \begin{tikzpicture}
              % Coordinates
              \coordinate (A) at (-1,0.7); % Bottom left corner
              \coordinate (B) at (0,0); % Bottom right corner
              \coordinate (C) at (1.5,.7); % Top right corner
              \coordinate (D) at (0.4,1.5); % Top left corner
              \coordinate (E) at (0,5); % Apex of the pyramid
              \coordinate (F) at (-.3,1.1);
              \coordinate (G) at (.8,.3);
              \coordinate (H) at (1,1.1);
              \coordinate (I) at (-.5,.4);

              % Draw base
              \draw[thick] (A) -- (B) -- (C);
              \draw[thick, dashed] (C) -- (D) -- (A);
              
              % Draw pyramid edges
              \draw[thick] (E) -- (A);
              \draw[thick] (E) -- (B);
              \draw[thick] (E) -- (C);
              \draw[style=dashed,thick] (E) -- (D);

              % Draw planes of symmetry
              \begin{scope}[opacity=0.3]

                  % Plane 3: through midpoints of edges (vertical)
                  \fill[green] (E) -- (F) -- (G) -- cycle;

                  % Plane 5: Base of the pyramid
                  \fill[cyan] (A) -- (B) -- (C) -- (D) -- cycle;
              \end{scope}
            \end{tikzpicture}
          </latex-image>
        </image>

        <image>
          <latex-image label="sq_pyramid_4">
            \begin{tikzpicture}
              % Coordinates
              \coordinate (A) at (-1,0.7); % Bottom left corner
              \coordinate (B) at (0,0); % Bottom right corner
              \coordinate (C) at (1.5,.7); % Top right corner
              \coordinate (D) at (0.4,1.5); % Top left corner
              \coordinate (E) at (0,5); % Apex of the pyramid
              \coordinate (F) at (-.3,1.1);
              \coordinate (G) at (.8,.3);
              \coordinate (H) at (1,1.1);
              \coordinate (I) at (-.5,.4);

              % Draw base
              \draw[thick] (A) -- (B) -- (C);
              \draw[thick, dashed] (C) -- (D) -- (A);
              
              % Draw pyramid edges
              \draw[thick] (E) -- (A);
              \draw[thick] (E) -- (B);
              \draw[thick] (E) -- (C);
              \draw[style=dashed,thick] (E) -- (D);

              % Draw planes of symmetry
              \begin{scope}[opacity=0.3]

                  % Plane 4: through midpoints of edges (other vertical)
                  \fill[yellow] (E) -- (H) -- (I) -- cycle;

                  % Plane 5: Base of the pyramid
                  \fill[cyan] (A) -- (B) -- (C) -- (D) -- cycle;
              \end{scope}
            \end{tikzpicture}
          </latex-image>
        </image>
        </sidebyside>
      </solution>
    </example>

