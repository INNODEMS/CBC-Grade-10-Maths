      <exercise>
        <statement>
          <p>
            Identify fruits and vegetables that have only 2 planes of symmetry.
          </p>
        </statement>
        <solution>
          <p>
              One example is a (curved) banana. When you cut a banana vertically down the middle, you create a plane of symmetry. When you cut a banana horizontally along the banana, you create another plane of symmetry. Therefore, a banana has 2 planes of symmetry.
          </p>
        </solution>
      </exercise>


        <exercise>
        <statement>
          <p>
            Cut out the following shapes from a paper and find the number of lines of symmetry in each.
          </p>
          <sidebyside widths="20% 20% 20% 20%">
          <p>
            <ol marker="(a)">
              <li>
                  <image>
                  <latex-image label="shape_rectangle">
                      \begin{tikzpicture}
                      \draw[thick,blue](0,0) coordinate (A)-- (6,0) coordinate (B)-- (6,4) coordinate (C)--(0,4)coordinate(D)--(0,0)coordinate(A);
                      \end{tikzpicture}
                    </latex-image>
                    </image>
              </li>
              <li>
                <image>
                <latex-image label="shape_pentagon">
                    \begin{tikzpicture}
                    \draw[thick,orange] (0:.8cm) \foreach \x in {72,144,...,359} {
                      -- (\x:.8cm)
                    } -- cycle (90:.8cm) ;  
                    \end{tikzpicture}
                </latex-image>
                </image>
              </li>
              <li>
                <image>
                <latex-image label="shape_hexagon">
                  \begin{tikzpicture}
                    \draw[thick,green] (0:.8cm) \foreach \x in {60,120,...,359} {
                      -- (\x:.8cm)
                    }-- cycle (90:.8cm);  
                  \end{tikzpicture}
                </latex-image>
                </image>
              </li>
              <li>
                <image>
                <latex-image label="shape_octagon">
                  \begin{tikzpicture}
                    \draw[thick,purple] (0:.8cm) \foreach \x in {45,90,...,359} {
                    -- (\x:.8cm)
                    } -- cycle (90:.8cm);
                  \end{tikzpicture}
                </latex-image>
                </image>
              </li>
            </ol>
          </p>
          </sidebyside>
          <sidebyside widths="30% 30% 30%">
          <p>
            <ol marker="(i)">
              <li>
                <image>
                <latex-image label="shape_trapezium">
                    \begin{tikzpicture}
                        \usetikzlibrary{quotes,angles}
                        \draw[blue,thick] (0,0) coordinate (A)-- (4,0) coordinate (B)--(6,2)coordinate(C)--(2,2)coordinate(D)--(0,0)coordinate(A);
                        \draw[orange] (1.9,0.2)--(2,0)--(1.9,-0.2);
                        \draw[orange] (2.0,0.2)--(2.1,0)--(2.0,-0.2);
                        \draw[orange] (2.8,2.2)--(3,2)--(2.8,1.8);
                        \draw[orange] (2.9,2.2)--(3.1,2)--(2.9,1.8);
                        \draw[red] (4.8,0.9)--(5,1)--(5.1,0.9);
                        \draw[red] (0.8,0.9)--(1,1)--(1.1,0.9);
                        \end{tikzpicture}
                </latex-image>
                </image>
              </li>
              <li>
                <image>
                <latex-image label="shape_rhombus">
                    \begin{tikzpicture}
                        \usetikzlibrary{quotes,angles}
                        \draw[green,thick](0,2) coordinate (D)-- (0,0) coordinate (A)-- (4,0) coordinate (B)--(2,2)coordinate(C)--(0,2)coordinate(D);
                        \draw[green](0,0)--(0,0.3)--(0.3,0.3)--(0.3,0);
                        \draw[green](0,2)--(0.3,2)--(0.3,1.7)--(0,1.7);
                        \draw[blue](0.9,2.1)--(1,2)--(0.9,1.9);
                        \draw[blue](0.9,0.1)--(1,0)--(0.9,-0.1);
                        \end{tikzpicture}
                </latex-image>
                </image>
              </li>
              <li>
                <image>
                <latex-image label="shape_circle">
                  \begin{tikzpicture}
                    \draw[thick,purple] (0:.8cm) \foreach \x in {10,20,...,359} {
                    -- (\x:.8cm)
                    } -- cycle (90:.8cm);
                  \end{tikzpicture}
                </latex-image>
                </image>
              </li>
            </ol>
          </p>
          </sidebyside>
        </statement>
        <answer>
          <p>
            <ol marker="(a)">
              <li>
                <p>
                  Rectangle: <m>2</m> lines of symmetry (vertical and horizontal)
                </p>
              </li>
              <li>
                <p>
                  Pentagon (regular): <m>5</m> lines of symmetry
                </p>
              </li>
              <li>
                <p>
                  Hexagon (regular): <m>6</m> lines of symmetry
                </p>
              </li>
              <li>
                <p>
                  Octagon (regular): <m>8</m> lines of symmetry
                </p>
              </li>
            </ol>
          </p>
          <p>
            <ol marker="(i)">
              <li>
                <p>
                  Rhombus: <m>2</m> lines of symmetry (diagonals)
                </p>
              </li>
              <li>
                <p>
                  Trapezium (non-isosceles): <m>0</m> lines of symmetry
                </p>
              </li>
              <li>
                <p>
                  Circle: Infinite lines of symmetry
                </p>
              </li>
            </ol>
          </p>
        </answer>
        </exercise>

        <exercise>
          <statement>
            <p>
              Identify lines of symmetry on the different objects in your classroom and at home.
            </p>
          </statement>
          <answer>
            <p>
              <ol marker="(a)">
                <li>
                  <p>
                    Books - vertical plane through center
                  </p>
                </li>
                <li>
                  <p>
                    Windows - vertical or horizontal depending on design
                  </p>
                </li>
                <li>
                  <p>
                    Plates - circular, infinite planes
                  </p>
                </li>
                <li>
                  <p>
                    Doors - vertical plane through center
                  </p>
                </li>
                <li>
                  <p>
                    Table tops (rectangular) - <m>2</m> planes (vertical and horizontal)
                  </p>
                </li>
              </ol>
            </p>
          </answer>
        </exercise>

      <exercise>
        <statement>
          <p>
            Identify the parts of your body are the mirror images of one another.
          </p>
        </statement>
        <answer>
          <p>
            <ol marker="(a)">
              <li>
                <p>
                  Left and right eyes
                </p>
              </li>
              <li>
                <p>
                  Left and right eyes
                </p>
              </li>
              <li>
                <p>
                  Left and right arms
                </p>
              </li>
              <li>
                <p>
                  Left and right arms
                </p>
              </li>
              <li>
                <p>
                  Hands and feet are mirror images
                </p>
              </li>
            </ol>
          </p>
        </answer>
      </exercise>
      <exercise>
      <statement>
        <p>
          Draw a letter <m>E</m> on a paper using a marker. Show it to the mirror. Observe how the mirror flips the image.
        </p>
      </statement>
      <answer>
        <p>
          Mirror flips the letter <m>E</m> horizontally. The right side becomes left and vice versa.
        </p>
      </answer>
      </exercise>
      <exercise>
        <statement>
          <p>
            What other surface reflects images other than a mirror?
          </p>
        </statement>
        <answer>
          <p>
            <ol marker="(i)">
              <li>
                <p>
                  Water surfaces (lakes, ponds)
                </p>
              </li>
              <li>
                <p>
                  Shiny metal surfaces (spoons, polished metal)
                </p>
              </li>
              <li>
                <p>
                  Glass with reflective coating
                </p>
              </li>
              <li>
                <p>
                  Still ice surfaces
                </p>
              </li>
            </ol>
          </p>
        </answer>
      </exercise>  
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation and Extension</title>
        <dl>
            <li xml:id="auto_wmdns0f2">
                <title>Struggling Learners</title>
                <p>
                    <ul>
                        <li xml:id="auto_ymfdxk4c">Provide pre-cut shapes for folding activities.</li>
                        <li xml:id="auto_mpqj5r3u">Use mirrors to help visualise lines of symmetry.</li>
                        <li xml:id="auto_3e2buqjh">Start with simple shapes (circle, square) before progressing to complex ones.</li>
                        <li xml:id="auto_xyna14q2">Pair struggling learners with a peer mentor.</li>
                    </ul>
                </p>
            </li>
            <li xml:id="auto_e8ges6wn">
                <title>On-Level Learners</title>
                <p>
                    Complete all activities as described in the lesson. Verify answers by folding paper shapes.
                </p>
            </li>
            <li xml:id="auto_mi5ky1yt">
                <title>Advanced Learners</title>
                <p>
                    <ul>
                        <li xml:id="auto_xl3b2zak">Explore rotational symmetry in addition to reflective symmetry.</li>
                        <li xml:id="auto_lgk4qkrn">Investigate symmetry in art, architecture, and nature.</li>
                        <li xml:id="auto_2pf4le8m">Create a symmetry portfolio with photographs and analysis.</li>
                    </ul>
                </p>
            </li>
            <li xml:id="auto_p4rz2m22">
                <title>Extension Challenge 1: Symmetry in African Flags</title>
                <p>
                    Create a poster showing lines of symmetry in the flags of 5 African countries.
                </p>
            </li>
            <li xml:id="auto_mfqtgdp7">
                <title>Extension Challenge 2: Symmetry in Kenyan Buildings</title>
                <p>
                    Research and identify lines of symmetry in famous Kenyan buildings such as the KICC and Parliament buildings.
                </p>
            </li>
            <li xml:id="auto_pecgfmnu">
                <title>Extension Challenge 3: Tile Patterns</title>
                <p>
                    Design a tile pattern that has exactly <m>4</m> lines of symmetry, then create another pattern with exactly <m>6</m> lines of symmetry.
                </p>
            </li>
            <li xml:id="auto_1mylx9xc">
                <title>Extension Challenge 4: Rotational vs Reflective Symmetry</title>
                <p>
                    Compare rotational symmetry and reflective symmetry. Find <m>5</m> objects that have rotational symmetry but no reflective symmetry (for example, the letter S, a parallelogram).
                </p>
            </li>
        </dl>
    </axiom>

