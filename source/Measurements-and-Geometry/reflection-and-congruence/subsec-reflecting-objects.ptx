      <exercise xml:id="auto_aeooh6nc">
        <statement>
      <p xml:id="auto_x1im3ve3">
         Reflect the object about the y-axis
      </p>

      <image>
        <latex-image label="object_on_a_plane_2">
          \begin{tikzpicture}

            % Draw the axes
            \draw[thin,-&gt;] (-5,0) -- (5,0) node[right] {x-axis};
            \draw[thin,-&gt;] (0,-5) -- (0,5) node[above] {y-axis};
            
            % Draw the grid lines
            \draw[step=1,gray,very thin] (-5,-5) grid (5,5);

            % Draw the kite
            \fill[green!30,opacity=0.3] (-4,-4) -- (-1,-4) -- (1,-3) -- (-3,-3) -- (-3,3) -- (-4,3) -- cycle;
            \draw[green,thick] (-4,-4) -- (-1,-4) -- (1,-3) -- (-3,-3) -- (-3,3) -- (-4,3) -- cycle;
  
          \end{tikzpicture}
        </latex-image>
      </image>
      </statement>
      </exercise>

      <exercise xml:id="auto_r1cjf9hi">
        <statement>
          <p xml:id="auto_3cevs5xf">
            The points <m>A'(-4,1),\,B'(-2,4)\text{ and } C'(-1,3)</m> are the images of points <m>A,\,B \text{ and } C</m>
             respectively under a reflection on the line <m>x = -1.</m> Find the coordinates for points <m>A,\,B \text{ and } C.</m>
          </p>
        </statement>
      </exercise>
      <exercise>
        <statement>
            <p>
            A polygon has vertices <m>A(-5,5),\, B(-6,3),\, C(-5,1),\, D(-3,0),\, E(-2,2),\, F(-3,4)</m>. 
            <ol marker="(a)">
                <li>
                    <p>
                        Reflect these points in the line <m>x = 0</m> by applying <m>(x, y) \to (-x, y)</m>
                    </p>
                </li>
                <li>
                    <p>
                        Instead of the previous reflection, first reflect the original points in the line <m>y = x</m> by applying <m>(x, y) \to (y, x)</m>. Then reflect on the line <m>y = 0</m> by applying <m>(x,y) \to (x, -y)</m>.
                    </p>
                </li>
                <li>
                    <p>
                        What do you notice about your answers to (a) and (b)?
                    </p>
                </li>
            </ol>
        </p>
    </statement>
    <solution>
        <ol marker="(a)">
            <li>
                <p>
                    Reflect in <m>x = 0</m>:
                </p>
                <tabular halign="center">
                    <row header="yes" bottom="minor">
                        <cell>Point</cell>
                        <cell>Original</cell>
                        <cell>After <m>x = 0</m></cell>
                    </row>
                    <row><cell><m>A</m></cell><cell><m>(-5,5)</m></cell><cell><m>(5,5)</m></cell></row>
                    <row><cell><m>B</m></cell><cell><m>(-6,3)</m></cell><cell><m>(6,3)</m></cell></row>
                    <row><cell><m>C</m></cell><cell><m>(-5,1)</m></cell><cell><m>(5,1)</m></cell></row>
                    <row><cell><m>D</m></cell><cell><m>(-3,0)</m></cell><cell><m>(3,0)</m></cell></row>
                    <row><cell><m>E</m></cell><cell><m>(-2,2)</m></cell><cell><m>(2,2)</m></cell></row>
                    <row><cell><m>F</m></cell><cell><m>(-3,4)</m></cell><cell><m>(3,4)</m></cell></row>
                </tabular>
                    </li>
            <li>
                <p>
            Reflect in <m>y = x</m> then <m>y = 0</m>:
             <tabular halign="center">
            <row header="yes" bottom="minor">
                <cell>Point</cell>
                <cell>Original</cell>
                <cell>After <m>y = x</m></cell>
                <cell>After <m>y = 0</m></cell>
            </row>
            <row><cell><m>A</m></cell><cell><m>(-5,5)</m></cell><cell><m>(5,-5)</m></cell><cell><m>(5,5)</m></cell></row>
            <row><cell><m>B</m></cell><cell><m>(-6,3)</m></cell><cell><m>(3,-6)</m></cell><cell><m>(3,6)</m></cell></row>
            <row><cell><m>C</m></cell><cell><m>(-5,1)</m></cell><cell><m>(1,-5)</m></cell><cell><m>(1,5)</m></cell></row>
            <row><cell><m>D</m></cell><cell><m>(-3,0)</m></cell><cell><m>(0,-3)</m></cell><cell><m>(0,3)</m></cell></row>
            <row><cell><m>E</m></cell><cell><m>(-2,2)</m></cell><cell><m>(2,-2)</m></cell><cell><m>(2,2)</m></cell></row>
            <row><cell><m>F</m></cell><cell><m>(-3,4)</m></cell><cell><m>(4,-3)</m></cell><cell><m>(4,3)</m></cell></row>
        </tabular>
        </p>
            </li>
            <li>
                <p>
                    These answers are the same. Flipped about <m>y = x</m> and then <m>y = 0</m> is the same as flipping about <m>x = 0</m>. You can confirm this with a piece of paper. 
                </p>
            </li>
        </ol>
        
       
    </solution>
      </exercise>

