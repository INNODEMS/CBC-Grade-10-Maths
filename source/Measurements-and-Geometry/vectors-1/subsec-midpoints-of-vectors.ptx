    </axiom>

    <exercises xml:id="exercises-midpoint-of-vectors">
        <exercise xml:id="auto_g3ttmr4o">
            <statement>
                <p xml:id="auto_j583v5pp">
                    Find the coordinates of the midpoint of <m>\mathbf{PQ}</m> in each of the following cases:
                </p>
                 <p xml:id="auto_jpyjgyda">
                    <ol xml:id="auto_9fja7q39" marker="(a)" cols="2">
                        <li xml:id="auto_a2xj7ef3">
                            <p xml:id="auto_wluusqp5">
                            <m>P\, (-5,6), Q\, (3,-4)</m> 
                            </p>
                        </li>
                        <li xml:id="auto_1j23r38v">
                            <p xml:id="auto_hqyrkuai">
                                <m>P\,(1,−3), Q\,(5,7)</m>
                            </p>
                        </li>
                        <li xml:id="auto_yminqi9r">
                            <p xml:id="auto_lem4mp7l">
                                <m>P\, (-2,4), Q\, (6,0)</m> 
                            </p>
                        </li>
                        <li xml:id="auto_3n6hmas8">
                            <p xml:id="auto_hytsiitv">
                                <m>P\, (a,b), Q\, (c,d)</m> 
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_4nnji8an">
                    <ol marker="(a)" cols="2">
                        <li xml:id="auto_gjqkhg6v">
                            <p xml:id="auto_zowm4f8l">
                                <m>\left( \frac{-5+3}{2} ,\frac{6-4}{2}\right) = (-1,1)</m>
                            </p>
                        </li>
                        <li xml:id="auto_m2cuzn4z">
                            <p xml:id="auto_yhi0c3um">
                                <m>\left( \frac{1+5}{2} ,\frac{-3+7}{2}\right) = (3,2)</m>
                            </p>
                        </li>
                        <li xml:id="auto_gv45io8p">
                            <p xml:id="auto_r808rqau">
                                <m>\left( \frac{-2+6}{2} ,\frac{4+0}{2}\right) = (2,2)</m>
                            </p>
                        </li>
                        <li xml:id="auto_nobua1xl">
                            <p xml:id="auto_nh5azj2a">
                               <m>\left( \frac{a+c}{2} ,\frac{b+d}{2}\right) = \left( \frac{a+c}{2} ,\frac{b+d}{2}\right)</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_6zfycjmh">
            <statement>
                <p xml:id="auto_xi2e59it">
                    In the figure below, <m>ABC</m> is a triangle where <m>M</m> and <m>N</m> are midpoints of <m>\overrightarrow{AC}</m>, 
                    <m>\overrightarrow{AB}</m> respectively.
                </p>
                <p xml:id="auto_6169p0gl">
                    Triangle <m>ABC</m> has vertices at points <m>A(2,2)</m>, <m>B(6,2)</m> and <m>C(4,6)</m>.
                    <!-- Points <m>M</m> and <m>N</m> are the midpoints of sides <m>AC</m> and <m>AB</m>, respectively.  -->
                    Determine the coordinates of <m>M</m> and <m>N</m>.
                </p>
                <image width="50%">
                    <shortdescription></shortdescription>
                    <latex-image label="exercise1-triangle">
                        \begin{tikzpicture}
                            \coordinate (A) at (2,2);
                            \coordinate (B) at (6,2);
                            \coordinate (C) at (4,6);
                            
                            \draw[thick] (A) -- (B) node[right] {$B (6,2)$};
                            \draw[thick] (B) -- (C) node[above] {$C (4,6)$};
                            \draw[thick] (C) -- (A) node[left] {$A (2,2)$};
                            \draw[thick] (B) -- (3,4);
                            \draw[thick] (A) -- (5,4);
                            
                            \node[above left] at (3,4) {M};
                            \node[above right] at (5,4) {N};
                        \end{tikzpicture}
                    </latex-image>
                </image>
            </statement>
            <answer>
                <p xml:id="auto_dvm2ovc7">
                    <ol marker="(a)" cols="2">
                        <li xml:id="auto_nqna1ax6">
                            <p xml:id="auto_huktdqvo">
                                <m>M = \left( \frac{2+4}{2} ,\frac{2+6}{2}\right) = \left( \frac{6}{2} ,\frac{8}{2}\right) = (3,4)</m>
                            </p>
                        </li>
                        <li xml:id="auto_94ul43pg">
                            <p xml:id="auto_okac2kx7">
                                <m>N = \left( \frac{6+4}{2} ,\frac{2+6}{2}\right) = \left( \frac{10}{2} ,\frac{8}{2}\right) = (5,4)</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
