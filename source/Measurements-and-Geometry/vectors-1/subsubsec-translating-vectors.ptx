                                <m>(4, 9)</m>
                            </p>
                        </li>
                        <li xml:id="auto_a5n7ewkw">
                            <p xml:id="auto_gft72alw">
                                <m>(-13, -4)</m>
                            </p>
                        </li>
                        <li xml:id="auto_bljin9rw">
                            <p xml:id="auto_eevw2qxz">
                                <m>(-26, 14)</m>
