    </axiom>

    <exercises>
        <exercise>
            <statement>
                <p>
                    A square-based pyramid has a base with sides measuring 10 cm each, while its triangular faces have a slant height of 15 cm. Determine the total surface area of this pyramid, including the base and all four triangular faces.
                </p>
                 <image width="70%">
                <shortdescription>Square pyramid</shortdescription>
                <latex-image label="square-pyramid-question-net">
                \begin{tikzpicture}
                    % Define colors
                    \definecolor{basecolor}{RGB}{135, 206, 250}  % Gold for the base
                    \definecolor{facecolor}{RGB}{135, 206, 255} % Light blue for the triangular faces

                        % Base (square)
                        \draw[thick] (2,2) -- (4,4) -- (2,6) -- (0,4) -- cycle;  (D) -- (A) -- (P) -- cycle; % Left triangle

                    

                        % Base outline
                        \draw[thick] (2,2) -- (4,4) -- (2,6) -- (0,4) -- cycle;
                        \draw[dashed] (0,4) --(4,4);
                        % Triangular faces outline
                        \draw[thick] (2,6) -- (2,8) -- (4,4);
                        \draw[thick] (4,4) -- (2,8) -- (2,2);
                        \draw[thick] (2,2) -- (2,8) -- (0,4);
                        \draw[thick] (0,4) -- (2,8) -- (2,6);
                        \node at (1,2.7){ 10 cm };
                        \node at(3,6) { 15 cm};
                    \end{tikzpicture}
                </latex-image>
                </image>
            </statement>
            <answer>
                <p>
                    Area of the base <m>= 10^2 = 100 \;\text{cm}^2</m>
                </p>
                <p>
                    Area of one triangular face <m>\frac{1}{2} \times \text{Base} \times \text{Height}</m>
                </p>
                <p>
                   <md>
                    <mrow> A = \amp \frac{1}{2} \times 10 \times 15</mrow>
                    <mrow> = \amp 75 \; \text{cm}^2</mrow>
                   </md>
                    
                </p>
                <p>
                    Area of four triangular faces <m>4\times75 = 300 \;\text{cm}^2</m>
                </p>
                <p>
                    Total surface area <m> 100 + 300 = 400 \; \text{cm}^2</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                   A pyramid with a square base has a total surface area of 400 cm², and its base side measures 8 cm. Using the formula for surface area, calculate the slant height of the pyramid. 
                </p>
            </statement>
            <answer>
                <p>
                    Base area <m> = 8^2 = 64</m>
                </p>
                <p>
                    Area of triangular faces <m> = 400 - 64 = 336</m>
                </p>
                <p>
                    Area of one triangular face <m> = \frac{336}{4} = 84</m>
                </p>
                <p>
                    Use triangle formula <m> A = \frac{1}2 \times b \times h</m>
                </p>
                <p>
                    <m> 84 = \frac{1}{2} \times 8 \times h</m>
                </p>
                <p>
                    <m>4h = 84</m>
                </p>
                <p>
                    <m>h = 21 \; \text{cm}</m>
                </p>
                <p>
                    Slant height <m> = 21 \; \text{cm}</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A square pyramid  has a base with sides of 24 cm each, and the height of the triangular face is 18 cm. Find the total surface area of the pyramid.
                </p>
                <image source="image.png" width="50%">
                    <shortdescription></shortdescription>
                </image>
            </statement>
            <answer>
                <p>
                    Base area: <m>24^2 = 576</m>
                </p>
                <p>
                    Area of one triangular face: <m>\frac{1}{2} \times 24 \times 18 = 216</m>
                </p>
                <p>
                    Four faces: <m>216 \times 4 = 864</m>
                </p>
                <p>
                    Total surface area <m>= 1440 \; \text{cm}^2</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    A miniature paper pyramid is being designed with a square base of 12 cm by 12 cm and a slant height of 20 cm. How much paper is required to construct the entire pyramid?
                </p>
                <image width="40%" >
                <latex-image label="pyramid-ex">
                    \begin{tikzpicture}
                        
                        % Define coordinates
                        \coordinate (A) at (0,0);
                        \coordinate (B) at (6,0);
                        \coordinate (C) at (5,3);
                        \coordinate (D) at (1,3);
                        \coordinate (O) at (3,1.8); % center of base
                        \coordinate (S) at (3,6); % apex

                        % Draw base
                        \draw[thick, black!60!black] (A) -- (B) -- (C) -- (D) -- cycle;

                        % Draw edges to apex
                        \draw[thick, black!60!black] (A) -- (S);
                        \draw[thick, black!60!black] (B) -- (S);
                        \draw[thick, black!60!black] (C) -- (S);
                        \draw[thick, black!60!black] (D) -- (S);

                        % Hidden base diagonal
                        \draw[dashed, black!60!black] (A) -- (C);
                        \draw[dashed, black!60!black] (B) -- (D);

                        % Height line
                        \draw[dashed, red] (S) -- (O);

                        % Right angle box
                        \draw[very thick] (3,1.8) -- ++(0.3,0) -- ++(0,0.3) -- ++(-0.3,0);

                        % Labels
                        \node [right]at (3,3.7) {\small\textbf{20 cm}};
                        \node at (3,-0.4) {\small\textbf{12 cm}};
                    \end{tikzpicture}
                </latex-image>
                </image>
            </statement>
            <answer>
                <p>
                    Base area: <m>12^2 = 144</m>
                </p>
                <p>
                    Four faces: <m>2\times 12 \times 20 = 480</m>
                </p>
                <p>
                    Total surface area: <m> 144 + 480 = 624</m>
                </p>
                <p>
                    Paper required <m> = 624 \; \text{cm}^2</m>
                </p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    The roof of a small storage building is in the shape of a rectangular pyramid with a base side length of 5 m and a slant height of 6 m. If the entire roof needs to be covered with wooden shingles, calculate the total area that needs to be covered.
                </p>
                <image width="50%">
                    <shortdescription> Net of square pyramid</shortdescription>
                
                    <latex-image label="net-square-exercise-pyramid">
                        \begin{tikzpicture}
                                        
                        % Define the coordinates of the rectangular base (4 cm × 2 cm)
                            \coordinate (A) at (0,0);
                            \coordinate (B) at (4,0);
                            \coordinate (C) at (4,2);
                            \coordinate (D) at (0,2);
                            
                            % Define the peak (apex) of the pyramid
                            \coordinate (P) at (2,4);  % Centered above the rectangle

                            % Fill the shapes with different colors
                            \draw[thick] (A) -- (B) -- (C) -- (D) -- cycle;

                            % Draw the outlines of the pyramid
                            \draw[thick] (A) -- (B) -- (C) -- (D) -- cycle; % Base rectangle
                            \draw[thick] (A) -- (P) -- (B); % Front triangle
                            \draw[thick] (B) -- (P) -- (C); % Right triangle
                            \draw[thick] (C) -- (P) -- (D); % Back triangle
                            \draw[thick] (D) -- (P) -- (A); % Left triangle

                            % Add dashed fold lines
                            \draw[dashed] (A) -- (P);
                            \draw[dashed] (B) -- (P);
                            \draw[dashed] (C) -- (P);
                            \draw[dashed] (D) -- (P);

                            % Label the points
                            \node[below left] at (A) {A};
                            \node[below right] at (B) {B};
                            \node[above right] at (C) {C};
                            \node[above left] at (D) {D};
                            \node[below] at ($(B)!0.5!(A)$) { 5 m};
                            \node[right] at ($(B)!0.5!(C)$) {3 m};
                            \node[right] at ($(C)!0.5!(P)$) {6 m};


                            \node[above] at (P) {P};
                        \end{tikzpicture}
                    </latex-image>
                </image>

        </statement>
            <answer>
                <p>
                    Since it is a roof, only the four triangular faces are covered.
                </p>
                <p>
                    Because the base is rectangular, the pyramid has four triangular faces of two different bases
                </p>
                <p>
                    Area of two faces with a base <m>5 \; \text{m}</m>: <m>= \times 5 \times 6 = 30</m>
                </p>
                <p>
                    Area of two faces with a base <m>3 \; \text{m}</m>: <m>= \times 3 \times 6 = 18</m>
                </p>
                <p>
                    Total surface area: <m> 30 + 18 = 48</m>
                </p>
                <p>
                    Total roof area <m> = 48 \; \text{m}^2</m>
                </p>
            </answer>
        </exercise>
    </exercises>
            <exercise  label="ex-working-out-the-surface-area-of-a-pyramid-from-its-net">
