    <exercises xml:id="exercises-further-exercise">

    <exercise xml:id="auto_92l0ph89">
        <statement>
            <p xml:id="auto_dp9rn383">
                An architect is creating a scale model of a building. The actual height of the building is <m>120</m> meters, and the height of the model is <m>0.6</m> meters.
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            What is the scale factor of the model?
                        </p>
                    </li>
                    <li>
                        <p>
                           If the width of the actual building is <m>50</m> meters, what is the width of the model? 
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <answer>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>k = \frac{\text{model height}}{\text{actual height}} = \frac{0.6}{120} = 0.005</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>\text{model width} = k \times \text{actual width} = 0.005 \times 50 = 0.25\; \text{meters}</m>
                        </p>
                    </li>
                </ol>
            </p>
        </answer>
    </exercise>

    <exercise xml:id="auto_dgc7u032">
        <statement>
            <p xml:id="auto_7706npbq">
                A map scale is given as <m>1:25,000</m>, meaning <m>1</m> cm on the map represents <m>25,000</m> cm in real life.
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            A river on the map measures <m>8</m> cm in length. What is the actual length of the river in kilometers?
                        </p>
                    </li>
                    <li>
                        <p>
                            If a road on the map measures <m>12.5</m> cm, how long is the actual road in meters?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <answer>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <m>\text{Actual length} = 8 \times 25,000 = 200,000\; \text{cm} = 2\; \text{km}</m>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>\text{Actual length} = 12.5 \times 25,000 = 312,500\; \text{cm} = 3,125\; \text{meters}</m>
                        </p>
                    </li>
                </ol>
            </p>
        </answer>
    </exercise>

    <exercise xml:id="auto_wwdzd58e">
        <statement>
            <p xml:id="auto_h1ulb5xv">
                A photograph has a size of <m>5</m> cm by <m>7</m> cm. It needs to be enlarged so that the width becomes <m>20</m> cm. The height will also increase proportionally. What is the new height of the photograph after the enlargement?
            </p>
        </statement>
        <answer>
            <p>
                <m>\text{height}' = 7 \times 4 = 28\ \text{cm}</m>
            </p>
        </answer>
    </exercise>

    <exercise xml:id="auto_qwjxcgjh">
        <statement>
            <p xml:id="auto_wa32kyw1">
                A pole of height <m>2.4</m> meters casts a shadow of length <m>1.6</m> meters. A tree casts a shadow of length <m>12</m> meters.
            </p>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            Using the concept of similar triangles, find the height of the tree.
                        </p>
                    </li>
                    <li>
                        <p>
                            If the tree's shadow increases to <m>15</m> meters, what would be the new height of the tree, assuming the proportion remains the same?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <answer>
            <p>
                <ol marker="(a)">
                    <li>
                        <p>
                            <md>
                                <mrow>\frac{\text{pole height}}{\text{pole shadow}} = \frac{\text{tree height}}{\text{tree shadow}}</mrow>
                                <mrow>\frac{2.4}{1.6} = \frac{h}{12}</mrow>
                                <mrow>h = \frac{2.4}{1.6} \times 12 = 1.5 \times 12 = 18\; \text{m}</mrow>
                            </md>
                        </p>
                    </li>
                    <li>
                        <p>
                            <m>h = \frac{2.4}{1.6} \times 15 = 1.5 \times 15 = 22.5\; \text{m}</m>
                        </p>
                    </li>
                </ol>
            </p>
        </answer>
    </exercise>
        
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>
        <table xml:id="auto_oyxnew65">
            <title>Differentiation Strategies</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line>Provide a formula card with <m>\text{LSF} = k</m>, <m>\text{ASF} = k^2</m>, <m>\text{VSF} = k^3</m>.</line>
                        <line>Use grid paper to visualise scaling.</line>
                        <line>Start with LSF only first.</line>
                        <line>Provide step-by-step worked guides.</line>
                    </cell>
                </row>
                <row>
                    <cell>On-Level Learners</cell>
                    <cell>
                        <line>Complete all Phase 3 problems.</line>
                        <line>Verify answers with both methods (direct calculation and scale factor).</line>
                        <line>Include sustainability analysis in discussions.</line>
                    </cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line>Calculate the volume of a hemispherical dome on the blueprint and actual park.</line>
                        <line>Estimate total park budget using area and volume costs.</line>
                        <line>Design their own park feature and calculate all scale factors.</line>
                    </cell>
                </row>
            </tabular>
        </table>
    </axiom>

