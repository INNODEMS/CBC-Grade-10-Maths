<subsubsection xml:id="subsubsec-positive-enlargements" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Positive Enlargements</title>
    <objectives component="outcomes">
        <introduction>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurements and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.1 Similarity and Enlargement
                    </p>
                </li>
            </dl>
        </introduction>
        <ul>
            <li>Construct the image of an object under an enlargement given the centre and the linear scale factor.</li>
            <li>Apply similarity and enlargement to real-life situations.</li>
            <li>Appreciate the use of similarity and enlargement in real-life situations.</li>
        </ul>
    </objectives>
    
    <axiom component="resources">
        <!-- Link to blurb -->
        <xi:include href="../../resources-blurb-lesson.ptx" />

        <sbsgroup widths="45% 45%" margins="2% 2%">
            <sidebyside>
                <p>
                    <dataurl source="lesson_plans/measurements-and-geometry/similarity-and-enlargement/positive-enlargements.pdf"> Lesson Plan </dataurl>
                </p>
                <p>
                    <dataurl source="lesson_plans/measurements-and-geometry/similarity-and-enlargement/step-by-step-guide_positive-enlargements.pdf"> Step-by-Step Guide </dataurl>
                </p>
            </sidebyside>
        </sbsgroup>
    </axiom>


    <activity xml:id="auto_kh8ee4ng">
        <introduction xml:id="auto_d509z6o1">
            <p xml:id="auto_ueysybnc">
                <alert>Work in pairs</alert>
            </p>
        </introduction>
        <task xml:id="auto_ev8gwxfd">
