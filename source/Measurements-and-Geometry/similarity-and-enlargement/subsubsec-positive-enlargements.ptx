                <p xml:id="auto_mky6bvfa">
                    Compare the two triangles and note any similarities.
                </p>
            </statement>
        </task>
        <task xml:id="auto_zr4z9b8z">
            <statement>
                <p xml:id="auto_u04vniw9">
                    Calculate the ratios <m>\frac{OA'}{OA}</m>, <m>\frac{OB'}{OB}</m>, and <m>\frac{OC'}{OC}</m>, what do you notice between the three ratios.
                </p>
            </statement>
