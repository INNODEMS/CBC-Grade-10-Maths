<subsubsection xml:id="subsubsec-positive-enlargements" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Positive Enlargements</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        2.0 Measurements and Geometry
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        2.1 Similarity and Enlargement
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title>
                    <p>
                        Construct the image of an object under an enlargement given the centre and the linear scale factor.
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        10
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
            <p component="lesson-plan">
                <p> Upon completion of this lesson, learners will be able to:
                <ol>
                    <li>
                        <p>
                            <alert>Know (Conceptual Understanding):</alert> Define enlargement as a transformation that changes the size of a shape by a scale factor while preserving its shape. Identify the centre of enlargement, scale factor, object, and image.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Do (Procedural Skill):</alert> Construct the image of a triangle under enlargement with a positive scale factor using the centre of enlargement and coordinate methods. Calculate unknown lengths using the scale factor.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Apply (Application/Problem-Solving):</alert> Apply enlargement with positive scale factors to determine image coordinates, find unknown distances, and solve real-world problems involving maps, models, and scaled drawings.
                        </p>
                    </li>
                </ol>
                </p>
            </p>
        </introduction>
    </objectives>
    
    <axiom component="resources">
        <!-- Link to blurb -->
        <xi:include href="../../resources-blurb-lesson.ptx" />

        <sbsgroup widths="45% 45%" margins="2% 2%">
            <sidebyside>
                <p>
                    <dataurl source="lesson_plans/measurements-and-geometry/similarity-and-enlargement/positive-enlargements.pdf"> Lesson Plan </dataurl>
                </p>
                <p>
                    <dataurl source="lesson_plans/measurements-and-geometry/similarity-and-enlargement/step-by-step-guide_positive-enlargements.pdf"> Step-by-Step Guide </dataurl>
                </p>
            </sidebyside>
        </sbsgroup>
    </axiom>
    <xi:include href="../../resources-materials.ptx" />

    <axiom component="lesson-plan">
        <title>Discovering Enlargement on the Coordinate Plane</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Grouping</title>
                <p>
                    Work in pairs
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Circulate among pairs, asking probing questions: <q>What coordinates did you get for A'?</q>, <q>What is OA' compared to OA?</q> Expected answers: <m>A'=(4,6)</m>, <m>B'=(2,2)</m>, <m>C'=(8,2)</m>. All ratios equal <m>2</m>. The triangles have the same shape but the image is double the size. Corresponding angles are equal.
                </p>
            </li>
        </dl>
    </axiom>

    <activity xml:id="auto_kh8ee4ng">
        <introduction xml:id="auto_d509z6o1">
            <p xml:id="auto_ueysybnc">
                <alert>Work in pairs</alert>
            </p>
        </introduction>
        <task xml:id="auto_ev8gwxfd">
            <statement>
                <p xml:id="auto_ptllkr49">
                    Draw and label the <m>x</m> axis and <m>y</m> axis on the graph paper.
                </p>
                <image source="graph-paper.png">
                    <shortdescription></shortdescription>
                </image>
            </statement>
        </task>
        <task xml:id="auto_u7y9v6w9">
            <statement>
                <p xml:id="auto_uxq9o4h0">
                    Mark the origin at <m>(0,0)</m> and label it as <m>\textbf{O}</m>.
                </p>
                <image source="graph-paper1.png">
                    <shortdescription></shortdescription>
                </image>
            </statement>
        </task>
        <task xml:id="auto_fklmc7w3">
            <statement>
                <p xml:id="auto_9r5lajfb">
                    Plot the points <m>A(2,3)</m>, <m>B(1,1)</m>, and <m>C(4,1)</m>.
                </p>
            </statement>
        </task>
        <task xml:id="auto_hv46u0xy">
            <statement>
                <p xml:id="auto_7dd3q1nr">
                    Connect points <m>A</m>, <m>B</m>, and <m>C</m> with straight lines to form triangle <m>ABC</m>.
                </p>

                <image source="graph-paper2.png">
                    <shortdescription></shortdescription>
                </image>
            </statement>
        </task>
        <task xml:id="auto_rv0pyelx">
            <statement>
                <p xml:id="auto_48n0eb8p">
                    Draw straight lines from O to <m>A</m>, <m>O</m> to <m>B</m>, and <m>O</m> to <m>C</m>.
                </p>
            </statement>
        </task>
        <task xml:id="auto_5v76img1">
            <statement>
                <p xml:id="auto_di8r6w73">
                    Measure and record the lengths of <m>OA</m>, <m>OB</m>, and <m>OC</m>.
                </p>
                <image source="graph-paper3.png">
                    <shortdescription></shortdescription>
                </image>
            </statement>
        </task>
        <task xml:id="auto_t10nct1q">
            <statement>
                <p xml:id="auto_l85lvc7q">
                    Extend each line to twice its original length and mark the new points as <m>A'</m>, <m>B'</m>, and <m>C'</m>.
                </p>
            </statement>
        </task>
        <task xml:id="auto_r3apfewz">
            <statement>
                <p xml:id="auto_qlsep7z4">
                    Connect <m>A'</m>, <m>B'</m>, and <m>C'</m> to form the enlarged triangle <m>A'B'C'</m>.
                </p>
                <image source="graph-paper4.png">
                    <shortdescription></shortdescription>
                </image>
            </statement>
        </task>
        <task xml:id="auto_ucilmr5r">
