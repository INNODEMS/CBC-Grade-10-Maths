            <task xml:id="auto_smz0xdih">
                <statement>
                    <p xml:id="auto_goq571wa">
                        Draw a cuboid with dimensions <m>8</m> cm (length), <m>5</m> cm (width), and <m>4</m> cm (height), and label it as Cuboid <m>A</m> as shown below.
                    </p>

