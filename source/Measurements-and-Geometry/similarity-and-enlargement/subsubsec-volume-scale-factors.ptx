                                \coordinate (D) at (0,4);
                                \coordinate (E) at (1.5,1.5);
                                \coordinate (F) at (9.5,1.5);
                                \coordinate (G) at (9.5,5.5);
                                \coordinate (H) at (1.5,5.5);

                                % Remove color fill (colorless version)
