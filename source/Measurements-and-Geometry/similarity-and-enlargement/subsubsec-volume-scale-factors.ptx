            <stack label="capacity-larger-container" source="stack/top/2-0-Measurement-Geometry/2-1-Similarity-and-Enlargement/2-1-3-Scale-Factors/2-1-3-2Volume-Scale-Factor/Finding-the-Capacity-of-a-Larger-Container-Using-Similarity.xml"/>
