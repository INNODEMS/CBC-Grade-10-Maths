            <stack label="area-side-relationship" source="stack/top/2-0-Measurement-Geometry/2-1-Similarity-and-Enlargement/2-1-3-Scale-Factors/2-1-3-1-Area-scale-factor/Relationship-between-the-side-lengths-and-areas-of-similar-regul.xml"/>
