    <exercise xml:id="auto_6o857yhw">
        <title>Finding Trigonometric Ratios in a Right Angled Triangle (1)</title>

        <introduction xml:id="auto_2j22imx9">
            <p xml:id="auto_gu0r3ifn">Load the question by clicking the button below.</p>
        </introduction>

        <stack label="trig-ratios-right-triangle-1" source="stack/top/2-0-Measurement-Geometry/2-4-Trigonometry-1/2-4-1-Trigonometric-Ratios-of-Acute-Angles/2-4-1-1-Tangent-of-an-Acute-Angle/Finding-Trigonometric-Ratios-in-a-Right-Angled-Triangle.xml"/>
    </exercise>

    <exercises xml:id="exercises-3">
        <exercise xml:id="auto_ldcpwv6t">
            <statement>
                <p xml:id="auto_fp9sx8h5">
                    <ol>
                        <li xml:id="auto_sbhmls7o">
                            <p xml:id="auto_0m4a2aw3">
                                If <m>\theta</m> is an acute angle such that <m>\sin\,(\theta)=\frac{3}{5}</m>, find <m>\cos(90^\circ-\theta)</m>.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_53h13j2c">
                    Using the complementary angle identity, <m>\cos(90^\circ - \theta) = \sin\, \theta</m>.
                    Therefore, <m>\cos(90^\circ - \theta) = \frac{3}{5}</m>.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_mfeoftwn">
            <statement>
                <p xml:id="auto_0q8rgpno">
                    <ol>
                        <li xml:id="auto_jor8dgmd">
                            <p xml:id="auto_3cqi71ba">
                                In the right-angled triangle below, 
                                find <m>\sin\, \theta </m> and <m>\cos \,\theta</m>, then verify that <m>\sin \,\theta= \cos\, \theta</m>.
                            </p>
                            <image width="50%">
                            <latex-image label="Exer1">
                                \begin{tikzpicture}
                                    % Draw the rotated right triangle
                                    \draw[very thick] (0,0) -- (-4,0) -- (0,3) -- cycle;
                                    
                                    % Label the vertices
                                    \node at (0.3,0.2) {\textbf{$A$}};
                                    \node at (-4.3,0.2) {\textbf{$B$}};
                                    \node at (0.2,3.2) {\textbf{$C$}};
                                    
                                    % Right angle symbol
                                    \draw [very thick](-0.3,0) -- (-0.3,0.3) -- (0,0.3);
                                    
                                    % Corrected inward arc for angle θ at B
                                    \draw[thick] (-3.4,0) arc[start angle=0,end angle=35,radius=0.6];
                                    \node at (-3.2,0.2) {$\theta$};

                                    % Label the sides
                                    \node at (-2,-0.3) {5}; % Hypotenuse
                                    \node at (0.3,1.5) {3}; % Opposite to A
                                    \node at (-2,2.3) {4}; % Adjacent to A
                                \end{tikzpicture}
                            </latex-image>
                            
                            </image>

                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_cmv4a9jr">
                    In the right-angled triangle, <m>\sin \theta = \frac{\text{opposite}}{\text{hypotenuse}} = \frac{3}{5}</m> and <m>\cos \theta = \frac{\text{adjacent}}{\text{hypotenuse}} = \frac{4}{5}</m>.
                    Since <m>\sin \theta = \frac{3}{5}</m> and <m>\cos \theta = \frac{4}{5}</m>, we observe that <m>\sin \theta \neq \cos \theta</m>.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_41pg115x">
            <statement>
                <p xml:id="auto_xr7y6ci4">
                    <ol>
                        <li xml:id="auto_f7tpiht3">
                            <p xml:id="auto_g79gzqi0">
                                Given that <m>\cos(32^\circ) = 0.848</m>, 
                                find the value of <m>\sin(58^\circ)</m> without using a calculator.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_e435ny1z">
                    <m>\sin(58^\circ)=0.848</m>
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_zf3zni8h">
            <statement>
                <p xml:id="auto_vnbfnrup">
                    <ol>
                        <li xml:id="auto_80r9iq3d">
                            <p xml:id="auto_cenl0lza">
                                A ladder leans against a wall, making a <m>65^\circ</m> 
                                angle with the ground. Find the height at which 
                                the ladder touches the wall if the ladder is <m>10\,m</m> long.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_wfwozg0c">
                    <m>\text{Find the height at which the ladder touches the wall}=9.06 \,\text{m}</m>
                </p>
            </answer>
        </exercise>

        
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>
        <table>
            <title>Differentiation Strategies</title>
            <tabular halign="left" bottom="minor" top="minor" left="minor" right="minor">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row>
                    <cell>Struggling Learners</cell>
                    <cell>
                        <line>Provide pre-filled angle pair tables for pattern recognition.</line>
                        <line>Use right triangle diagrams to visualise complementary angles.</line>
                        <line>Start with simpler angles (<m>30^\circ</m>, <m>60^\circ</m>, <m>45^\circ</m>).</line>
                        <line>Provide formula cards with <m>\sin(90^\circ - \theta) = \cos \theta</m>.</line>
                        <line>Allow extra time with calculators and tables.</line>
                    </cell>
                </row>
                <row>
                    <cell>On-Level Learners</cell>
                    <cell>
                        <line>Complete all practice problems independently.</line>
                        <line>Verify results using both tables and the complementary identity.</line>
                        <line>Explain reasoning when applying the identity.</line>
                    </cell>
                </row>
                <row>
                    <cell>Advanced Learners</cell>
                    <cell>
                        <line>Explore complementary angle relationships with tangent: <m>\tan(90^\circ - \theta) = \cot \theta</m>.</line>
                        <line>Investigate supplementary angle relationships.</line>
                        <line>Solve complex equations involving multiple complementary pairs.</line>
                        <line>Apply to real-world surveying or navigation problems.</line>
                    </cell>
                </row>
            </tabular>
        </table>
        <p>
            <alert>Extension Activity: Clinometer Investigation</alert>
        </p>
        <p>
            Build a simple clinometer using a protractor and string. Measure the angle of elevation to the top of a building or tree. Calculate the complementary angle and verify that <m>\sin(\text{angle of elevation}) = \cos(\text{complementary angle})</m>. Present findings with diagrams and calculations.
        </p>
    </axiom>

