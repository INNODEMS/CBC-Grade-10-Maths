    </axiom>

    <exercises xml:id="exercises-angles-depression">
        <exercise xml:id="ex-plane-depression">
            <statement>
                <p xml:id="auto_xnvrbhkq">
                    A plane flies to a height of <m>80\,\text{m}</m> above the ground. The angle of
                    depression from the plane to a radar on the ground is <m>30^\circ</m>. Find
                    the horizontal distance between the radar and the plane's projection on the
                    ground.
                </p>
                <image width="55%">
                <latex-image label="exercise-plane-depression">
                    \begin{tikzpicture}
                        % Using polar coordinates for exact 30° depression angle
                        % plane horizontal distance = 4/tan(30°) from person
                        \pgfmathsetmacro{\planedist}{4/tan(30)}
                        \coordinate (plane) at (\planedist,4);
                        \coordinate (person) at (0,0);
                        % Ground line
                        \draw[very thick] (-0.5,0) -- (7.5,0);
                        % Vertical line at plane position
                        \draw[very thick] (\planedist,0) -- (plane);
                        % Horizontal line from plane
                        \draw[dashed] (plane) -- (-0.3,4);
                        % Line of sight using polar: from plane at -30° (depression)
                        \draw[very thick, dashed, blue] (plane) -- ($(plane) + (-150:8)$);
                        % Right angle mark
                        \draw (\planedist-0.3,0) -- (\planedist-0.3,0.3) -- (\planedist,0.3);
                        % Angle of depression - exactly 30° below horizontal
                        \draw ($(plane) + (180:1)$) arc[start angle=180, end angle=210, radius=1cm];
                        \node at ($(plane) + (195:1.4)$) {$30^\circ$};
                        % Radar at origin
                        \fill[black] (person) circle (0.1);
                        % plane symbol
                        \draw[thick,fill=gray] (plane) circle (0.2);
                        \node[above] at ($(plane) + (0,0.3)$) {Plane};
                        % Labels
                        \node[below] at (0,-0.1) {Radar};
                        \node[right] at ($(plane) + (0.15,-2)$) {$80\,\text{m}$};
                        \node[below] at (3.5,0) {$d = ?$};
                    \end{tikzpicture}
                </latex-image>
                </image>
            </statement>
            <answer>
                <p xml:id="auto_ygh0g81l">
                    The angle of depression is <m>30^\circ</m>. Inside the right triangle at the plane's position, 
                    the angle between the line of sight and the vertical is <m>90^\circ - 30^\circ = 60^\circ</m>.
                </p>
                <p xml:id="auto_s546c7zt">
                    Given:
                </p>
                <p xml:id="auto_llm25er8">
                    <ul>
                        <li xml:id="auto_b0fjbirb"><p xml:id="auto_kusmirw8">Height of plane (adjacent to the <m>60^\circ</m> angle) = <m>80\,\text{m}</m></p></li>
                        <li xml:id="auto_thk9v8lm"><p xml:id="auto_hb7twg91">Angle inside the triangle = <m>60^\circ</m></p></li>
                        <li xml:id="auto_easihyx8"><p xml:id="auto_859vkstu">Horizontal distance (opposite to the <m>60^\circ</m> angle) = <m>d</m></p></li>
                    </ul>
                </p>
                <p xml:id="auto_5x12v782">
                    Using tangent:
                </p>
                <p xml:id="auto_ozzlagho">
                    <md>
                        <mrow>\tan\,60^\circ \amp = \frac{d}{80}</mrow>
                        <mrow>d \amp = 80 \times \tan\,60^\circ</mrow>
                        <mrow>\amp = 80 \times 1.7321</mrow>
                        <mrow>\amp = 138.57\,\text{m}</mrow>
                    </md>
                </p>
                <p xml:id="auto_j91alxva">
                    The horizontal distance is approximately <m>138.6\,\text{m}</m>.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="ex-lifeguard-tower">
            <statement>
                <p xml:id="auto_h55rfyxm">
                    A lifeguard sits in a tower that is <m>4.5\,\text{m}</m> above the beach. 
                    She spots a swimmer in distress at an angle of depression of <m>18^\circ</m>. 
                    How far is the swimmer from the base of the lifeguard tower?
                </p>
                <image width="55%">
                <latex-image label="exercise-lifeguard">
                    \begin{tikzpicture}
                        % Using polar coordinates for exact 18° depression angle
                        \coordinate (lifeguard) at (0,2.25);
                        % Swimmer distance = 2.25/tan(18°)
                        \pgfmathsetmacro{\swimmerdist}{2.25/tan(18)}
                        % Beach/water line
                        \draw[very thick, yellow!70!brown] (-0.5,0) -- (7.5,0);
                        \fill[blue!20] (5,0) rectangle (7.5,-0.3);
                        \node[below] at (6.5,-0.3) {Water};
                        % Lifeguard tower at origin
                        \draw[very thick, brown] (0,0) -- (lifeguard);
                        \draw[thick, brown] (-0.3,2.25) -- (0.3,2.25);
                        \draw[thick, brown] (-0.2,0) -- (-0.2,2.25);
                        \draw[thick, brown] (0.2,0) -- (0.2,2.25);
                        % Lifeguard
                        \draw[thick,fill=cyan] ($(lifeguard) + (0,0.1)$) circle (0.12);
                        \node[above] at ($(lifeguard) + (0,0.25)$) {Lifeguard};
                        % Horizontal line from lifeguard
                        \draw[dashed] (lifeguard) -- (7.2,2.25);
                        % Line of sight using polar: from lifeguard at -18° (depression)
                        \draw[very thick, dashed, blue] (lifeguard) -- ($(lifeguard) + (-18:7.5)$);
                        % Swimmer at correct distance
                        \draw[thick, red, fill=red] (\swimmerdist,0) circle (0.15);
                        \node[below] at (\swimmerdist,-0.1) {Swimmer};
                        % Angle of depression - exactly 18° below horizontal
                        \draw ($(lifeguard) + (0:1)$) arc[start angle=0, end angle=-18, radius=1cm];
                        \node at ($(lifeguard) + (-9:1.5)$) {$18^\circ$};
                        % Labels
                        \node[left] at (0,1.1) {$4.5\,\text{m}$};
                        \node[below] at (3.5,0) {$d = ?$};
                    \end{tikzpicture}
                </latex-image>
                </image>
            </statement>
            <answer>
                <p xml:id="auto_k3q87hii">
                    The angle of depression is <m>18^\circ</m>. Inside the right triangle at the lifeguard's position, 
                    the angle between the line of sight and the vertical is <m>90^\circ - 18^\circ = 72^\circ</m>.
                </p>
                <p xml:id="auto_2wcajt5n">
                    Given:
                </p>
                <p xml:id="auto_fahuy4km">
                    <ul>
                        <li xml:id="auto_clylyxu0"><p xml:id="auto_i01m2y7i">Height of tower (adjacent to the <m>72^\circ</m> angle) = <m>4.5\,\text{m}</m></p></li>
                        <li xml:id="auto_1ttjy5l4"><p xml:id="auto_75d2u0aj">Angle inside the triangle = <m>72^\circ</m></p></li>
                        <li xml:id="auto_9jxazcro"><p xml:id="auto_gbcahiie">Horizontal distance (opposite to the <m>72^\circ</m> angle) = <m>d</m></p></li>
                    </ul>
                </p>
                <p xml:id="auto_mq3ccxyo">
                    Using tangent:
                </p>
                <p xml:id="auto_eatjfml5">
                    <md>
                        <mrow>\tan\,72^\circ \amp = \frac{d}{4.5}</mrow>
                        <mrow>d \amp = 4.5 \times \tan\,72^\circ</mrow>
                        <mrow>\amp = 4.5 \times 3.0777</mrow>
                        <mrow>\amp = 13.85\,\text{m}</mrow>
                    </md>
                </p>
                <p xml:id="auto_h4zxcqy9">
                    The swimmer is approximately <m>13.9\,\text{m}</m> from the base of the tower.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="ex-cliff-boat">
            <statement>
                <p xml:id="auto_tzmsg32z">
                    A tourist stands at the edge of a cliff overlooking Lake Victoria. 
                    The cliff is <m>35\,\text{m}</m> high. She sees a fishing boat on the water 
                    at an angle of depression of <m>28^\circ</m>. How far is the boat from 
                    the base of the cliff?
                </p>
                <image width="55%">
                <latex-image label="exercise-cliff-boat">
                    \begin{tikzpicture}
                        % Using polar coordinates for exact 28° depression angle
                        \coordinate (tourist) at (0,3.5);
                        % Boat distance = 3.5/tan(28°)
                        \pgfmathsetmacro{\boatdist}{3.5/tan(28)}
                        % Water
                        \fill[blue!30] (-0.5,0) rectangle (7,-0.4);
                        \draw[very thick, blue!50] (-0.5,0) -- (7,0);
                        % Cliff at origin
                        \draw[very thick, brown!60!black] (0,0) -- (tourist);
                        \fill[brown!40] (-0.3,0) -- (-0.3,3.5) -- (0,3.5) -- (0,0) -- cycle;
                        % Tourist at top of cliff
                        \draw[thick] (tourist) -- ++(0,0.4);
                        \draw[thick,fill=cyan] ($(tourist) + (0,0.4)$) circle (0.1);
                        \node[above] at ($(tourist) + (0,0.5)$) {Tourist};
                        % Horizontal line from cliff top
                        \draw[dashed] (tourist) -- (6.8,3.5);
                        % Line of sight using polar: from tourist at -28° (depression)
                        \draw[very thick, dashed, blue] (tourist) -- ($(tourist) + (-28:7.5)$);
                        % Boat at correct distance
                        \draw[thick, brown] (\boatdist-0.3,-0.1) -- (\boatdist,0.2) -- (\boatdist+0.3,-0.1) -- cycle;
                        \draw[thick, brown] (\boatdist,0.2) -- (\boatdist,0.5);
                        \node[below] at (\boatdist,-0.2) {Boat};
                        % Angle of depression - exactly 28° below horizontal
                        \draw ($(tourist) + (0:1)$) arc[start angle=0, end angle=-28, radius=1cm];
                        \node at ($(tourist) + (-14:1.5)$) {$28^\circ$};
                        % Labels
                        \node[left] at (0,1.75) {$35\,\text{m}$};
                        \node[above] at (3.3,0) {$d = ?$};
                    \end{tikzpicture}
                </latex-image>
                </image>
            </statement>
            <answer>
                <p xml:id="auto_hmo7ji0f">
                    The angle of depression is <m>28^\circ</m>. Inside the right triangle at the tourist's position, 
                    the angle between the line of sight and the vertical is <m>90^\circ - 28^\circ = 62^\circ</m>.
                </p>
                <p xml:id="auto_voxmf1ot">
                    Given:
                </p>
                <p xml:id="auto_ninfflym">
                    <ul>
                        <li xml:id="auto_6mgijb6v"><p xml:id="auto_7ttuuhuk">Height of cliff (adjacent to the <m>62^\circ</m> angle) = <m>35\,\text{m}</m></p></li>
                        <li xml:id="auto_ecnvqhy9"><p xml:id="auto_dow4s576">Angle inside the triangle = <m>62^\circ</m></p></li>
                        <li xml:id="auto_dtu7eqbi"><p xml:id="auto_6ti3p972">Horizontal distance (opposite to the <m>62^\circ</m> angle) = <m>d</m></p></li>
                    </ul>
                </p>
                <p xml:id="auto_zf71q44e">
                    Using tangent:
                </p>
                <p xml:id="auto_wl7xbon3">
                    <md>
                        <mrow>\tan\,62^\circ \amp = \frac{d}{35}</mrow>
                        <mrow>d \amp = 35 \times \tan\,62^\circ</mrow>
                        <mrow>\amp = 35 \times 1.8807</mrow>
                        <mrow>\amp = 65.82\,\text{m}</mrow>
                    </md>
                </p>
                <p xml:id="auto_sw6m8an4">
                    The boat is approximately <m>65.8\,\text{m}</m> from the base of the cliff.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="ex-airplane-landing">
            <statement>
                <p xml:id="auto_knhyefpm">
                    An airplane is preparing to land. The pilot can see the runway at an 
                    angle of depression of <m>5^\circ</m>. If the airplane is flying at an 
                    altitude of <m>1500\,\text{m}</m>, what is the horizontal distance from 
                    the airplane to the runway?
                </p>
                <image width="60%">
                <latex-image label="exercise-airplane">
                    \begin{tikzpicture}
                        % Using polar coordinates for exact 5° depression angle
                        \coordinate (plane) at (0.3,0.8);
                        % Runway distance = 0.8/tan(5°) - very large ratio
                        \pgfmathsetmacro{\runwaydist}{0.8/tan(5)}
                        % Ground/runway
                        \draw[very thick] (-0.5,0) -- (10,0);
                        \draw[thick, gray] (\runwaydist-0.5,-0.1) rectangle (\runwaydist+0.5,0.1);
                        \node[below] at (\runwaydist,0) {Runway};
                        % Airplane
                        \draw[thick, blue, fill=blue!30] ($(plane) + (-0.3,0)$) -- ($(plane) + (0.1,0.12)$) -- ($(plane) + (0.3,0)$) -- ($(plane) + (0.1,-0.12)$) -- cycle;
                        \draw[thick, blue] ($(plane) + (0.1,0)$) -- ($(plane) + (0.5,0)$);
                        \node[above] at ($(plane) + (0.1,0.15)$) {Airplane};
                        % Altitude line
                        \draw[very thick] (0.3,0) -- (plane);
                        % Horizontal line from airplane
                        \draw[dashed] (plane) -- (9.5,0.8);
                        % Line of sight using polar: from plane at -5° (depression)
                        \draw[very thick, dashed, red] (plane) -- ($(plane) + (-5:9.5)$);
                        % Angle of depression - exactly 5° below horizontal
                        \draw ($(plane) + (0:1)$) arc[start angle=0, end angle=-5, radius=1cm];
                        \node at ($(plane) + (-2.5:1.8)$) {$5^\circ$};
                        % Labels
                        \node[left] at (0.3,0.4) {$1500\,\text{m}$};
                        \node[above] at (5,0) {$d = ?$};
                    \end{tikzpicture}
                </latex-image>
                </image>
            </statement>
            <answer>
                <p xml:id="auto_4p2m48hl">
                    The angle of depression is <m>5^\circ</m>. Inside the right triangle at the airplane's position, 
                    the angle between the line of sight and the vertical is <m>90^\circ - 5^\circ = 85^\circ</m>.
                </p>
                <p xml:id="auto_lte6gtew">
                    Given:
                </p>
                <p xml:id="auto_p88otk2e">
                    <ul>
                        <li xml:id="auto_ifiwrs8z"><p xml:id="auto_udpt8m50">Altitude (adjacent to the <m>85^\circ</m> angle) = <m>1500\,\text{m}</m></p></li>
                        <li xml:id="auto_nfrr8zyw"><p xml:id="auto_4kv704e5">Angle inside the triangle = <m>85^\circ</m></p></li>
                        <li xml:id="auto_s18jwnci"><p xml:id="auto_h6ave9vb">Horizontal distance (opposite to the <m>85^\circ</m> angle) = <m>d</m></p></li>
                    </ul>
                </p>
                <p xml:id="auto_m34cri4x">
                    Using tangent:
                </p>
                <p xml:id="auto_8ii1nrhf">
                    <md>
                        <mrow>\tan\,85^\circ \amp = \frac{d}{1500}</mrow>
                        <mrow>d \amp = 1500 \times \tan\,85^\circ</mrow>
                        <mrow>\amp = 1500 \times 11.4301</mrow>
                        <mrow>\amp = 17145.15\,\text{m}</mrow>
                    </md>
                </p>
                <p xml:id="auto_c66do2o3">
                    The horizontal distance is approximately <m>17.1\,\text{km}</m> (or <m>17145\,\text{m}</m>).
                </p>
            </answer>
        </exercise>

        <exercise xml:id="ex-birdwatcher">
            <statement>
                <p xml:id="auto_r7n44caf">
                    A birdwatcher is standing on a platform <m>8\,\text{m}</m> above the ground 
                    in Kakamega Forest. She spots a rare bird on the ground at an angle 
                    of depression of <m>35^\circ</m>. How far must she walk horizontally 
                    to reach the spot where the bird was standing?
                </p>
                <image width="55%">
                <latex-image label="exercise-birdwatcher">
                    \begin{tikzpicture}
                        % Using polar coordinates for exact 35° depression angle
                        \coordinate (watcher) at (0,4);
                        % Bird distance = 4/tan(35°)
                        \pgfmathsetmacro{\birddist}{4/tan(35)}
                        % Ground with forest floor
                        \draw[very thick, green!30!brown] (-0.5,0) -- (6.5,0);
                        % Platform/tree at origin
                        \draw[very thick, brown] (0,0) -- (watcher);
                        \draw[thick, brown] (-0.4,4) -- (0.4,4);
                        % Birdwatcher
                        \draw[thick] (watcher) -- ++(0,0.4);
                        \draw[thick,fill=cyan] ($(watcher) + (0,0.4)$) circle (0.1);
                        \node[above] at ($(watcher) + (0,0.5)$) {Birdwatcher};
                        % Horizontal line from platform
                        \draw[dashed] (watcher) -- (6,4);
                        % Line of sight using polar: from watcher at -35° (depression)
                        \draw[very thick, dashed, blue] (watcher) -- ($(watcher) + (-35:7)$);
                        % Bird at correct distance
                        \draw[thick, orange, fill=orange] (\birddist,0.15) -- (\birddist-0.2,0) -- (\birddist+0.2,0) -- cycle;
                        \node[below] at (\birddist,-0.1) {Bird};
                        % Angle of depression - exactly 35° below horizontal
                        \draw ($(watcher) + (0:1)$) arc[start angle=0, end angle=-35, radius=1cm];
                        \node at ($(watcher) + (-17.5:1.5)$) {$35^\circ$};
                        % Labels
                        \node[left] at (0,2) {$8\,\text{m}$};
                        \node[above] at (2.9,0) {$d = ?$};
                    \end{tikzpicture}
                </latex-image>
                </image>
            </statement>
            <answer>
                <p xml:id="auto_aef8fhps">
                    The angle of depression is <m>35^\circ</m>. Inside the right triangle at the birdwatcher's position, 
                    the angle between the line of sight and the vertical is <m>90^\circ - 35^\circ = 55^\circ</m>.
                </p>
                <p xml:id="auto_f44t0gcj">
                    Given:
                </p>
                <p xml:id="auto_papzj47j">
                    <ul>
                        <li xml:id="auto_fboxafmf"><p xml:id="auto_59su5elg">Height of platform (adjacent to the <m>55^\circ</m> angle) = <m>8\,\text{m}</m></p></li>
                        <li xml:id="auto_7st5bktx"><p xml:id="auto_0equwihj">Angle inside the triangle = <m>55^\circ</m></p></li>
                        <li xml:id="auto_58sw9sz9"><p xml:id="auto_7z2txa19">Horizontal distance (opposite to the <m>55^\circ</m> angle) = <m>d</m></p></li>
                    </ul>
                </p>
                <p xml:id="auto_7v775tu4">
                    Using tangent:
                </p>
                <p xml:id="auto_zacbcgjq">
                    <md>
                        <mrow>\tan\,55^\circ \amp = \frac{d}{8}</mrow>
                        <mrow>d \amp = 8 \times \tan\,55^\circ</mrow>
                        <mrow>\amp = 8 \times 1.4281</mrow>
                        <mrow>\amp = 11.42\,\text{m}</mrow>
                    </md>
                </p>
                <p xml:id="auto_ne06sup6">
                    The birdwatcher must walk approximately <m>11.4\,\text{m}</m> horizontally.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="ex-helicopter-angle">
            <statement>
                <p xml:id="auto_y3nnqtbg">
                    A rescue helicopter is hovering at a height of <m>200\,\text{m}</m> above ground level. 
                    The pilot can see a stranded hiker on the ground <m>350\,\text{m}</m> horizontally 
                    from the helicopter. Calculate the angle of depression from the helicopter to the hiker.
                </p>
                <image width="55%">
                <latex-image label="exercise-helicopter-angle">
                    \begin{tikzpicture}
                        % Helicopter and hiker positions
                        \coordinate (heli) at (0,4);
                        \coordinate (hiker) at (7,0);
                        % Ground line
                        \draw[very thick] (-0.5,0) -- (7.5,0);
                        % Vertical from helicopter
                        \draw[very thick] (0,0) -- (heli);
                        % Helicopter
                        \draw[thick, blue, fill=blue!30] (heli) circle (0.25);
                        \draw[thick, blue] (-0.5,4.25) -- (0.5,4.25);
                        \node[above] at (0,4.4) {Helicopter};
                        % Horizontal line from helicopter
                        \draw[dashed] (heli) -- (7.3,4);
                        % Line of sight to hiker
                        \draw[very thick, dashed, red] (heli) -- (hiker);
                        % Hiker
                        \draw[thick] (7,0) -- (7,0.4);
                        \draw[thick,fill=orange] (7,0.4) circle (0.1);
                        \node[below] at (7,-0.1) {Hiker};
                        % Angle of depression
                        \draw ($(heli) + (0:1)$) arc[start angle=0, end angle=-30, radius=1cm];
                        \node at ($(heli) + (-15:1.5)$) {$\theta = ?$};
                        % Right angle mark
                        \draw (-0.3,0) -- (-0.3,0.3) -- (0,0.3);
                        % Labels
                        \node[left] at (0,2) {$200\,\text{m}$};
                        \node[below] at (3.5,0) {$350\,\text{m}$};
                    \end{tikzpicture}
                </latex-image>
                </image>
            </statement>
            <answer>
                <p xml:id="auto_0nv3exxe">
                    Given:
                </p>
                <p xml:id="auto_re72xqr7">
                    <ul>
                        <li xml:id="auto_rcz1lg29"><p xml:id="auto_6n5a05hs">Height of helicopter (opposite) = <m>200\,\text{m}</m></p></li>
                        <li xml:id="auto_rgfgq2uy"><p xml:id="auto_emeet2vl">Horizontal distance (adjacent) = <m>350\,\text{m}</m></p></li>
                        <li xml:id="auto_bhxlfutj"><p xml:id="auto_diujzv96">Angle of depression = <m>\theta</m></p></li>
                    </ul>
                </p>
                <p xml:id="auto_0lolxxp4">
                    Using tangent:
                </p>
                <p xml:id="auto_0mnnx5rx">
                    <md>
                        <mrow>\tan\,\theta \amp = \frac{200}{350}</mrow>
                        <mrow>\tan\,\theta \amp = 0.5714</mrow>
                        <mrow>\theta \amp = \tan^{-1}(0.5714)</mrow>
                        <mrow>\amp = 29.74^\circ</mrow>
                    </md>
                </p>
                <p xml:id="auto_atmzx249">
                    The angle of depression is approximately <m>29.7^\circ</m>.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="ex-lookout-tower-angle">
            <statement>
                <p xml:id="auto_t700a6go">
                    A ranger stands at the top of a <m>25\,\text{m}</m> lookout tower in Tsavo National Park. 
                    She spots a watering hole that is <m>80\,\text{m}</m> from the base of the tower. 
                    At what angle of depression is she looking at the watering hole?
