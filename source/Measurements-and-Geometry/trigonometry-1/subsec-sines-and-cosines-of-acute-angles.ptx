    <exercises xml:id="auto_j507qoeg" >
        <exercise xml:id="auto_j7halv9d">
            <statement>
                <p xml:id="auto_axbk8s29"> In the figure given below,</p>
                            
                <image width="70%">
                <latex-image label="question">
                    \begin{tikzpicture}
                        % Draw the right-angled triangle
                        \draw [very thick,fill=white] (0,0) -- (4,0) -- (4,3) -- cycle;

                        % Label the sides
                        \node [blue]at (2,-0.3) {8 cm}; % Adjacent side
                        \node [black]at (4.5,1.5) {\textbf{6 cm}}; % Opposite side
                        \node at (2,2) {10 cm}; % Hypotenuse

                        % Label the right angle
                        \draw [very thick] (4,0) -- (3.7,0) -- (3.7,0.3) -- (4,0.3) -- cycle;
                        

                        % Mark the angle theta at the hypotenuse-adjacent junction
                        \draw (0.5,0) arc[start angle=0,end angle=36.87,radius=0.5cm];
                        \node at (0.8,0.3) {\(\alpha\)}; % Place theta at correct position
                    \end{tikzpicture}
                </latex-image>
                    
                </image>
                <p xml:id="auto_ek1xcbqb">
                    Find:
                </p>
                <p xml:id="auto_6pklqn0c">
                    <ol xml:id="auto_6xvk9j1k" marker="a) ">
                        <li xml:id="auto_cned2gyp">
                            <p xml:id="auto_ywz2k0un">
                                <m>\sin\,\alpha</m>
                            </p>
                        </li>
                        <li xml:id="auto_7u8ra6q4">
                            <p xml:id="auto_xjsefbm5">
                                <m>\cos\,\alpha</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_ee3h64pl">
                    <ol marker="(a)">
                        <li xml:id="auto_qynt5euz">
                            <p xml:id="auto_uswjv6jq">
                                <m>\sin\,\alpha=0.6</m>
                            </p>
                        </li>
                        <li xml:id="auto_76l1o6hk">
                            <p xml:id="auto_nlbmgug8">
                                <m>\cos\,\alpha=0.8</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_d13fh33i">
            <statement>
                <p xml:id="auto_dkmv7n34">
                    A flagpole <m>12</m> meters tall casts a shadow of 
                    <m>8</m> meters on the ground.
                </p>
                <p xml:id="auto_2p7z2g1a">
                    <ol xml:id="auto_fv88hcyg" marker="(a)">
                        <li xml:id="auto_offz95xp">
                            <p xml:id="auto_9ty8sc17">
                                What is the angle of elevation of the sun?
                            </p>
                        </li>
                        <li xml:id="auto_0ibgsz3h">
                            <p xml:id="auto_1valkqvq">
                                If the shadow increases to <m>10</m> meters, what will be the new angle of elevation?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_uqk8nev2">
                    <ol marker="(a)">
                        <li xml:id="auto_mr9az1qm">
                            <p xml:id="auto_0ey3e93n">
                                The angle of elevation of the sun is <m>56.31^\circ</m>
                            </p>
                        </li>
                        <li xml:id="auto_2gzun8xs">
                            <p xml:id="auto_2bw30c30">
                                The new angle of elevation is <m>50.19^\circ</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_6in0krfy">
            <statement>
                <p xml:id="auto_b7hi1z1k">
                    An airplane takes off at 
                    an angle of <m>18^\circ</m> to the ground. After flying <m>500</m> meters,
                </p>
                <p xml:id="auto_9kz9o9ws">
                    <ol xml:id="auto_0gdkmqrr" marker="(a)">
                        <li xml:id="auto_fle8i5gd">
                            <p xml:id="auto_2rp5dj97">
                            How high is the airplane above the ground? 
                            </p>
                        </li>
                        <li xml:id="auto_8ekv42gs">
                            <p xml:id="auto_dy6vjyoj">
                                How far has it traveled horizontally from the starting point?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_54cp0qf7">
                    <ol marker="(a)">
                        <li xml:id="auto_dxnli1u1">
                            <p xml:id="auto_9snozadk">
                                <m>\text{height}=154.51 \, \text{m}</m>
                            </p>
                        </li>
                        <li xml:id="auto_wyqg9tf6">
                            <p xml:id="auto_9whzoltc">
                                <m>\text{horizontal distance}=75.53\, \text{m}</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>

        </exercise> 
        <exercise xml:id="auto_jawajmj6">
            <statement>
                <p xml:id="auto_lvvg39w1">
                    A ladder <m>5</m> meters long leans against a 
                    vertical wall, making an angle of <m>65^\circ</m> with the ground as shown.
                </p>
                <image width="50%">
                            <latex-image label="Question1">
                                \begin{tikzpicture}[scale=1.5]
                                    % Draw the wall and ground
                                    \draw [very thick] (0,0) -- (0,5) node[above] {\textbf{Wall}}; % Vertical wall
                                    \draw [very thick] (0,0) -- (6,0) node[right] {\textbf{Ground}}; % Ground line
                                    
                                    % Draw the ladder as a thick rectangle to look real
                                    \draw [very thick, blue, fill=gray!40] (0.3,5) -- (4.3,0.3) -- (4,0) -- (0,4.7) -- cycle;
                                    
                                    % Right-angle marker
                                    \draw[very thick] (0,0) -- (0.5,0) -- (0.5,0.5) -- (0,0.5) -- cycle;
                                    
                                    % Labels
                                    \node at (3,2.5) {\textbf{5 cm}}; % Height to be found
                                    % Base distance to be found
                                    
                                    % Correctly placing the arc and angle label
                                    \draw (4,0) arc[start angle=0, end angle=180, radius=0.3cm];
                                    \node at (3.3,0.3) {\(\mathbf{65^\circ}\)}; % Angle label at the correct position
                                    
                                    % Add ladder rungs (steps)
                                    \foreach \y in {0.8, 1.6, 2.4, 3.2, 4} {
                                        \draw [very thick,blue] ({0.3+(\y/5)*4}, {5-\y}) -- ({(\y/5)*4}, {5-\y});
                                    }
                                \end{tikzpicture}
                            </latex-image>
                                
                            </image>
                <p xml:id="auto_gsxxo33v">
                    <ol xml:id="auto_wipi3xgg" marker="(a)">
                        <li xml:id="auto_nyaeaia8">
                            <p xml:id="auto_qjs05y66">
                                How high does the ladder reach on the wall?
                            </p>
                        </li>
                        <li xml:id="auto_p3jh6vtg">
                            <p xml:id="auto_qxcp5e8e">
                                How far is the base of the ladder from the wall?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_sqkkr6z1">
                    <ol>
                        <li xml:id="auto_vicdpbg6">
                            <p xml:id="auto_jrl79yil">
                                <m>\text{height}=4.53 \, \text{m}</m>
                            </p>
                        </li>
                        <li xml:id="auto_qfd23rnr">
                            <p xml:id="auto_wjfhz23u">
                                <m>\text{base distance}=2.11 \, \text{m}</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>

        
    </exercises>
    
