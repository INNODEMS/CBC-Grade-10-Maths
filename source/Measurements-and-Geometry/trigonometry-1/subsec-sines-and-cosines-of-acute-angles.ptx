                                % Angle x
                                \draw [very thick](0.8,0) arc (0:37:0.8);
                                \node[right] at (0.8,0.3) {\textbf{$\theta$}};
                            \end{tikzpicture}
                        </latex-image>
                        
                            
                        </image>
                    </figure>

                </li>
                <li xml:id="auto_2ijael6l">
                    <p xml:id="auto_l5cnnkml">
                        Copy the above figure in your writing materials.
                    </p>
                    <p xml:id="auto_dc6fpafi">
                        Measure lengths <m>OA,\,OP,\,AP,\,OQ,\,OB,\,BQ,\,OR,\,OC \,\text{and}\,CR </m>
                    </p>
                    
                </li>
                <li xml:id="auto_ve3iysr1">
                    <p xml:id="auto_06rwunxb">
                        Fill in the following;
