    <axiom component="lesson-plan">
        <title>Phase 4: Assessment / Evaluate (Exit Ticket)</title>
        <p xml:id="auto_ywgri866">
            <alert>Suggested Time:</alert> 10 minutes
        </p>
        <p xml:id="auto_3np58soh">
            <alert>Objective:</alert> To formatively assess individual learner understanding of sine and cosine ratios.
        </p>
        <p xml:id="auto_9pn2zqxl">
            <alert>Learning Experience:</alert> Learners independently complete the exercises below. Use the answer key for quick marking.
