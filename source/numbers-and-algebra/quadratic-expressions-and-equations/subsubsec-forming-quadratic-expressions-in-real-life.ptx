    <exercises xml:id="exercises-forming-quadratic-expressions-in-real-life">
    
    <exercise xml:id="auto_ajwpbc61">
        <statement>
            Form a quadratic expression for each situation and write your answer in standard form.
            <ol marker="(a)">
                <li xml:id="auto_10muc86i">
                    The area of a rectangle with length <m>(x + 3)</m> and width <m>(x + 2)</m>.
                </li>
                <li xml:id="auto_nrs4g8jp">
                    The product of a number and the number increased by <m>5</m>.
                </li>
                <li xml:id="auto_wnepwlgb">
                    The product of two numbers where one is <m>x</m> and the other is <m>(x - 4)</m>.
                </li>
                <li xml:id="auto_sylm8ii4">
                    The area of a square with side length <m>(x + 6)</m>.
                </li>
                <li xml:id="auto_yerwsnzy">
                    The area of a rectangle with length <m>(2x + 1)</m> and width <m>(x + 4)</m>.
                </li>
                <li xml:id="auto_cafi0sez">
                    The product of two consecutive even numbers.
                </li>
                <li xml:id="auto_3nyocyx0">
                    A number is multiplied by three more than itself.
                </li>
                <li xml:id="auto_ilnwkw2w">
                    The product of <m>(x - 7)</m> and <m>(x + 2)</m>.
                </li>
                <li xml:id="auto_7wbm3k31">
                    The area of a rectangular field whose length is <m>(x - 5)</m> metres 
                    and width is <m>(x + 3)</m> metres.
                </li>
                <li xml:id="auto_avfhtwsr">
                    The product of two numbers whose difference is <m>4</m>, 
                    if the smaller number is <m>x</m>.
                </li>
                <li xml:id="auto_5j15pmhw">
                    The area of a square whose side length is <m>(3x - 2)</m>.
                </li>
                <li xml:id="auto_6bsx81xz">
                    The product of <m>(x + 1)</m>, <m>(x + 2)</m>, and <m>x</m>. 
                    (Expand fully.)
                </li>
            </ol>
        </statement>
        <answer>
            <p>
        <solution>
            <p xml:id="auto_bgthqzzn">
                <ol marker="(a)">
                    <li xml:id="auto_yez354i8">
                        <p xml:id="auto_ltyt75mw">
                            Expanding:
                            <md>
                                <mrow>\text{Area} \amp= (x + 3)(x + 2)</mrow>
                                <mrow>\amp= x^2 + 2x + 3x + 6</mrow>
                                <mrow>\amp= x^2 + 5x + 6</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_ycq24uem">
                        <p xml:id="auto_vu55oyg9">
                            Let the number be <m>x</m>. The number increased by <m>5</m> is <m>x + 5</m>.
                            <md>
                                <mrow>\text{Product} \amp= x(x + 5)</mrow>
                                <mrow>\amp= x^2 + 5x</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_8wvodw83">
                        <p xml:id="auto_urkdbeyi">
                            Expanding:
                            <md>
                                <mrow>\text{Product} \amp= x(x - 4)</mrow>
                                <mrow>\amp= x^2 - 4x</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_iioj1kdj">
                        <p xml:id="auto_9wdv1n06">
                            Expanding:
                            <md>
                                <mrow>\text{Area of square} \amp= (x + 6)^2</mrow>
                                <mrow>\amp= (x + 6)(x + 6)</mrow>
                                <mrow>\amp= x^2 + 6x + 6x + 36</mrow>
                                <mrow>\amp= x^2 + 12x + 36</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_ngyxydp5">
                        <p xml:id="auto_xnlh67e4">
                            Expanding:
                            <md>
                                <mrow>\text{Area} \amp= (2x + 1)(x + 4)</mrow>
                                <mrow>\amp= 2x^2 + 8x + x + 4</mrow>
                                <mrow>\amp= 2x^2 + 9x + 4</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_kg9xb5kf">
                        <p xml:id="auto_4nsq60my">
                            Let the first even number be <m>x</m>. The next consecutive even number is <m>x + 2</m>.
                            <md>
                                <mrow>\text{Product} \amp= x(x + 2)</mrow>
                                <mrow>\amp= x^2 + 2x</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_5otsxa6j">
                        <p xml:id="auto_3l91v4rq">
                            Let the number be <m>x</m>. Three more than itself is <m>x + 3</m>.
                            <md>
                                <mrow>\text{Product} \amp= x(x + 3)</mrow>
                                <mrow>\amp= x^2 + 3x</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_b0ix8v88">
                        <p xml:id="auto_6tq35bn2">
                            Expanding:
                            <md>
                                <mrow>\text{Product} \amp= (x - 7)(x + 2)</mrow>
                                <mrow>\amp= x^2 + 2x - 7x - 14</mrow>
                                <mrow>\amp= x^2 - 5x - 14</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_x05u71x0">
                        <p xml:id="auto_8h5ua5vg">
                            Expanding:
                            <md>
                                <mrow>\text{Area} \amp= (x - 5)(x + 3)</mrow>
                                <mrow>\amp= x^2 + 3x - 5x - 15</mrow>
                                <mrow>\amp= x^2 - 2x - 15</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_uxet9gm3">
                        <p xml:id="auto_j603ja5c">
                            The smaller number is <m>x</m>. The larger number (difference of <m>4</m>) is <m>x + 4</m>.
                            <md>
                                <mrow>\text{Product} \amp= x(x + 4)</mrow>
                                <mrow>\amp= x^2 + 4x</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_q09lv7j3">
                        <p xml:id="auto_otp82ozr">
                            Expanding:
                            <md>
                                <mrow>\text{Area of square} \amp= (3x - 2)^2</mrow>
                                <mrow>\amp= (3x - 2)(3x - 2)</mrow>
                                <mrow>\amp= 9x^2 - 6x - 6x + 4</mrow>
                                <mrow>\amp= 9x^2 - 12x + 4</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_u7dqfsb7">
                        <p xml:id="auto_gmt75fib">
                            Expanding in stages:
                            <md>
                                <mrow>\text{Product} \amp= x(x + 1)(x + 2)</mrow>
                                <intertext>First expand <m>(x + 1)(x + 2) = x^2 + 3x + 2</m>, then multiply by <m>x</m>:</intertext>
                                <mrow>\amp= x(x^2 + 3x + 2)</mrow>
                                <mrow>\amp= x^3 + 3x^2 + 2x</mrow>
                            </md>
                        </p>
                    </li>
                </ol>
            </p>
        </answer>
    </exercise>

    <exercise xml:id="auto_v2xtv85e">
        <statement>
            <p xml:id="auto_mc03oahw">
                A mobile phone company is designing a new phone screen. The screen is rectangular 
                with a length that is <m>3</m> cm more than twice the width. If the width of the 
                screen is <m>x</m> cm:
                <ol marker="(a)">
                    <li xml:id="auto_b2yc3o3f">Write an expression for the length of the screen.</li>
                    <li xml:id="auto_cyf760fv">Form a quadratic expression for the area of the screen.</li>
                    <li xml:id="auto_f8m92ww6">If the company adds a <m>0.5</m> cm border around the screen, write 
                    the new dimensions and form an expression for the total area including the border.</li>
                </ol>
            </p>
        </statement>
        <answer>
            <p>
        <solution>
            <p xml:id="auto_axzaiks7">
                <ol marker="(a)">
                    <li xml:id="auto_go7kb6ix">
                        <p xml:id="auto_txhx2lgz">
                            The length is <m>3</m> cm more than twice the width.
                            <me>\text{Length} = 2x + 3 \text{ cm}</me>
                        </p>
                    </li>
                    <li xml:id="auto_lfbub21c">
                        <p xml:id="auto_bm3r1vxi">
                            Since <m>\text{Area} = \text{length} \times \text{width}</m>:
                        </p>
                        <p xml:id="auto_pgg5whou">
                            <md>
                                <mrow>\text{Area} \amp= (2x + 3)(x)</mrow>
                                <mrow>\amp= 2x^2 + 3x \text{ square cm}</mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_1bmhccjc">
                        <p xml:id="auto_hzk1jxoo">
                            A <m>0.5</m> cm border on each side adds <m>1</m> cm to both width and length.
                            <md>
                                <mrow>\text{New width} \amp= x + 1 \text{ cm}</mrow>
                                <mrow>\text{New length} \amp= (2x + 3) + 1 = 2x + 4 \text{ cm}</mrow>
                            </md>
                            <md>
                                <mrow>\text{Total area} \amp= (x + 1)(2x + 4)</mrow>
                                <mrow>\amp= 2x^2 + 4x + 2x + 4</mrow>
                                <mrow>\amp= 2x^2 + 6x + 4 \text{ square cm}</mrow>
                            </md>
                        </p>
                    </li>
                </ol>
            </p>
        </answer>
    </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation and Extension</title>
        <dl>
            <li xml:id="auto_twd65ff7">
                <title>Struggling Learners</title>
                <p xml:id="auto_k9csbs8b">
                    <ul>
                        <li xml:id="auto_i3hxkq93">Use area model diagrams to visualise multiplication of binomials.</li>
                        <li xml:id="auto_qljblli1">Provide algebra tiles or grid paper for concrete representation.</li>
                        <li xml:id="auto_4l3aygsu">Start with simpler expressions before progressing to more complex ones.</li>
                        <li xml:id="auto_4czhikfi">Offer step-by-step templates for forming expressions.</li>
                        <li xml:id="auto_jri50dj3">Allow use of calculators for arithmetic while focusing on algebraic structure.</li>
                    </ul>
                </p>
            </li>
            <li xml:id="auto_f1yu66wg">
                <title>On-Level Learners</title>
                <p xml:id="auto_hlm48vd3">
                    Complete the core activities as described in the lesson.
                </p>
            </li>
            <li xml:id="auto_8wn3lx1h">
                <title>Advanced Learners</title>
                <p xml:id="auto_aethgh4r">
                    <ul>
                        <li xml:id="auto_snujsp96">Create expressions with larger coefficients, such as <m>(2x + 3)(3x + 1)</m>.</li>
                        <li xml:id="auto_2bmxhinn">Explore products of three factors, for example <m>(x + 1)(x + 2)(x + 3)</m>.</li>
                        <li xml:id="auto_dm7hidyi">Investigate optimization problems involving quadratic expressions.</li>
                        <li xml:id="auto_7qmn8s6i">Create their own word problems that lead to quadratic expressions.</li>
                        <li xml:id="auto_ungkqcou">Research how quadratic expressions are used in engineering and business applications.</li>
                    </ul>
                </p>
            </li>
            <li xml:id="auto_9qar14st">
                <title>Extension Activity: Garden Design Challenge</title>
                <p xml:id="auto_ia70433l">
                    You have 40 metres of fencing to enclose a rectangular garden. One side of the garden is against a wall, so you only need to fence three sides.
                    <ol marker="(a)">
                        <li xml:id="auto_ad4v0uzd">Let the width of the garden be <m>x</m> metres. Write an expression for the length in terms of <m>x</m>.</li>
                        <li xml:id="auto_hqmf4f7a">Form a quadratic expression for the area of the garden.</li>
                        <li xml:id="auto_eoadgilb">Find the dimensions that give the maximum area.</li>
                        <li xml:id="auto_q74j5lh1">Present your garden design with full calculations.</li>
                    </ol>
                </p>
            </li>
        </dl>
    </axiom>

