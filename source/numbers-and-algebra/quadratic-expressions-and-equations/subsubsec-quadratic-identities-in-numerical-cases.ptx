    </exercise>
    
    <exercises xml:id="exercises-apply-quadratic-identities-in-numerical-cases">
        <exercise xml:id="auto_2d6mwdct">
            <statement>
                <p xml:id="auto_jeg5tv6m">
                    Use a quadratic identity to evaluate <m>202^2</m>.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_i06xnrcj">
                    <m>40\,804</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_yhts2j4k">
            <statement>
                <p xml:id="auto_2jmxb30z">
                    Calculate <m>63 \times 57</m> using the difference of squares identity.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_wasvr7x7">
                    <m>3\,591</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_47zwmz2x">
            <statement>
                <p xml:id="auto_wmih8blp">
                    A rectangular field has dimensions <m>(x+5)</m> metres by <m>(x-5)</m> metres. Express the area using a quadratic identity. If <m>x=12</m>, find the area.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_btkv3x73">
                    <m>119</m> m<m>^2</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_4xj9rcs9">
            <statement>
                <p xml:id="auto_vare8lbt">
                    A square playground has a side length of <m>(y+7)</m> metres. Write the area as a quadratic expression and find the area when <m>y=3</m>.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_sjzmfjno">
                    <m>100</m> m<m>^2</m>
                </p>
            </answer>
        </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Assessment / Exit Ticket</title>
        <dl>
            <li xml:id="auto_o86umori">
                <title>Questions</title>
                <p xml:id="auto_1nl3gbuy">
                    <ol>
                        <li xml:id="auto_k3a6q1wb">
                            <p xml:id="auto_ppzv6nnx">Factor using the difference of squares:
                            <ol marker="(a)">
                                <li xml:id="auto_924ujskz"><m>x^2 - 49</m></li>
                                <li xml:id="auto_4dn9tqst"><m>4a^2 - 9</m></li>
                                <li xml:id="auto_2sj7mtfr"><m>25m^2 - 36n^2</m></li>
                            </ol></p>
                        </li>
                        <li xml:id="auto_asmrxlc0">
                            <p xml:id="auto_lq9hrlc1">Expand:
                            <ol marker="(a)">
                                <li xml:id="auto_pcalbbln"><m>(x + 7)^2</m></li>
                                <li xml:id="auto_d1nr5q61"><m>(3y - 2)^2</m></li>
                            </ol></p>
                        </li>
                        <li xml:id="auto_4863v8uz">
                            <p xml:id="auto_9hfx3nmp">Factor as a perfect square:
                            <ol marker="(a)">
                                <li xml:id="auto_f5zj9ntp"><m>x^2 + 6x + 9</m></li>
                                <li xml:id="auto_f7plako1"><m>4y^2 - 20y + 25</m></li>
                            </ol></p>
                        </li>
                        <li xml:id="auto_reylmprz">
                            <p xml:id="auto_vz6251yo">Which identity would you use for <m>49 - x^2</m>?</p>
                        </li>
                        <li xml:id="auto_symylzb2">
                            <p xml:id="auto_kbqckttu">A square garden has sides of length <m>(x + 5)</m> m. Write the expanded expression for the area.</p>
                        </li>
                    </ol>
                </p>
            </li>
            <li xml:id="auto_xvw5hibk">
                <title>Answer Key</title>
                <p xml:id="auto_otj79e2m">
                    <ol>
                        <li xml:id="auto_cghv4wry">
                            <p xml:id="auto_0iq5dtdf">
                            <ol marker="(a)">
                                <li xml:id="auto_7ek3mu5q"><m>(x - 7)(x + 7)</m></li>
                                <li xml:id="auto_7nnqp8kh"><m>(2a - 3)(2a + 3)</m></li>
                                <li xml:id="auto_bpeh4epw"><m>(5m - 6n)(5m + 6n)</m></li>
                            </ol>
                            </p>
                        </li>
                        <li xml:id="auto_znl2s4qu">
                            <p xml:id="auto_ire6djmy">
                            <ol marker="(a)">
                                <li xml:id="auto_6mi8bg3r"><m>x^2 + 14x + 49</m></li>
                                <li xml:id="auto_eza2bols"><m>9y^2 - 12y + 4</m></li>
                            </ol>
                            </p>
                        </li>
                        <li xml:id="auto_hjl3akf4">
                            <p xml:id="auto_c5mf9u4f">
                            <ol marker="(a)">
                                <li xml:id="auto_msn9sg33"><m>(x + 3)^2</m></li>
                                <li xml:id="auto_1wllnyfk"><m>(2y - 5)^2</m></li>
                            </ol>
                            </p>
                        </li>
                        <li xml:id="auto_i0g9lusa">
                            <p xml:id="auto_1sxzb5zr">Difference of squares: <m>49 - x^2 = 7^2 - x^2 = (7 - x)(7 + x)</m></p>
                        </li>
                        <li xml:id="auto_g8soj2ee">
                            <p xml:id="auto_2zlwf3gz"><m>x^2 + 10x + 25</m> square metres</p>
                        </li>
                    </ol>
                </p>
            </li>
        </dl>
    </axiom>

    <axiom component="lesson-plan">
        <title>Differentiation</title>
        <table xml:id="auto_oiopmsy6">
            <tabular>
                <row header="yes" bottom="medium">
                    <cell>Learner Level</cell>
                    <cell>Support / Activity</cell>
                    <cell></cell>
                </row>
                <row bottom="minor">
                    <cell>Struggling Learners</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Provide identity reference cards for each of the three identities. Use color coding to highlight matching terms. Use numerical examples first (e.g., <m>5^2 - 3^2 = 16 = (5 - 3)(5 + 3) = 2 \times 8 = 16</m>). Pair with a peer for guided support.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row bottom="minor">
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row bottom="minor">
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> 1) Factor <m>x^4 - 16</m> completely. 2) Prove that <m>(a+b)^2 - (a-b)^2 = 4ab</m>. 3) Calculate <m>51 \times 49</m> mentally using an identity. 4) Derive <m>(a+b+c)^2</m>.</line>
                        <line><alert>Solutions:</alert> 1) <m>x^4 - 16 = (x^2)^2 - 4^2 = (x^2 - 4)(x^2 + 4) = (x - 2)(x + 2)(x^2 + 4)</m>. 2) <m>(a+b)^2 - (a-b)^2 = (a^2 + 2ab + b^2) - (a^2 - 2ab + b^2) = 4ab</m>. 3) <m>51 \times 49 = (50 + 1)(50 - 1) = 50^2 - 1^2 = 2500 - 1 = 2499</m>. 4) <m>(a+b+c)^2 = a^2 + b^2 + c^2 + 2ab + 2bc + 2ac</m>.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>
