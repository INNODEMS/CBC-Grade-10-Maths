                </exercise>
    <exercises xml:id="exercises-using-reciprocals-of-real-numbers-in-mathematical-computations">
        <exercise xml:id="auto_dcr5ks7v">
            <statement>
                <p xml:id="auto_hs9gko2o">
                    Solve the following using reciprocals:
                </p>
                <p xml:id="auto_rrrv078m">
                    <ol xml:id="auto_av6dgixs" marker="(a)" cols="2"> 
                        <li xml:id="auto_9dag1ty1">
                            <p xml:id="auto_3550xmqd">
                            <m>6 \div \frac{2}{3}</m>   
                            </p>
                        </li>
                        <li xml:id="auto_usykiwt3">
                            <p xml:id="auto_alrxdxar">
                                <m>4x = 12</m>
                            </p>
                        </li>
                        <li xml:id="auto_ujcl3j98">
                            <p xml:id="auto_o00oew2s">
                                <m>\frac{3}{5} \times x = 9</m>
                            </p>
                        </li>
                        <li xml:id="auto_7xbtadvy">
                            <p xml:id="auto_v0anmvjj">
                                <m>0.2 \div 4.5</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_ycqnk8wu">
                    <ol xml:id="auto_evhqov9t" marker="(a)">
                        <li xml:id="auto_ioe135pi">
                            <p xml:id="auto_mlx0qrv3">
                                <m> 6 \times \frac{3}{2} = 9</m>  
                            </p>
                        </li>
                        <li xml:id="auto_t3it73u2">
                            <p xml:id="auto_fl69l6dr">
                                 <m>x = 12 \times \frac{1}{4} = 3</m> 
                            </p>
                        </li>
                        <li xml:id="auto_i194sggw">
                            <p xml:id="auto_wkn5hcia">
                                <m>x = 9 \times \frac{5}{3} = 15</m>  
                            </p>
                        </li>
                        <li xml:id="auto_oecymwku">
                            <p xml:id="auto_x8wtv00q">
                                 <m> 0.2 \times \frac{1}{4.5} = \frac{2}{45} = 0.0444</m>
                            </p>
                        </li>
                    </ol>
                </p>
                
            </answer>
        </exercise>
        <exercise xml:id="auto_lde52iro">
            <statement>
                <p xml:id="auto_a7mxpf4f">
                     Solve: <m>\left( \frac{4}{7} \div \frac{2}{5}\right)</m> <m>\times</m> <m>\left(\frac{3}{8} \div \frac{9}{16}\right)</m>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_unexujxf">
                    <md>
                        <mrow>=\amp \left( \frac{4}{7} \times \frac{5}{2}\right) \times \left(\frac{3}{8} \times \frac{16}{9}\right)</mrow>
                        <mrow>=\amp \frac{20}{14} \times \frac{48}{72} </mrow>
                        <mrow>=\amp \frac{10}{7} \times \frac{2}{3} </mrow>
                        <mrow>=\amp \frac{20}{21} </mrow>
                    </md>
                </p>
            </answer>
        </exercise>
        <exercise>
        <statement>
        <p xml:id="auto_p7he0rqg">
            If a car travels at <m>80</m> km/h, to find out the time taken per km we can use reciprocal.
        </p>
        </statement>
        <answer>
            <p xml:id="auto_vil2mdao">
                Time per km = <m>\frac{1}{80}</m> hours per km.
            </p>
        </answer>
    </exercise>
    <exercise>
        <statement>
             <p xml:id="auto_dgoq9l1e">
            If a factory produces <m>300</m> items in <m>5</m> hours, what is the production rate per hour?
            </p>
        </statement>
        <solution>
            <p xml:id="auto_ez5eomwn">
                To determine how much time is needed per item, we use reciprocal:
            </p>
            <p xml:id="auto_fvu28x14">
                        <m>\frac{300}{5} = 60</m> items per hour.
            </p>
        </solution>
        
    </exercise>
        <exercise xml:id="auto_bfi4ugvf">
            <statement>
                <p xml:id="auto_mt5h1gsc">
                     If <m>x \times \frac{3}{8} = \frac{5}{12}</m>, find the value of <m>x</m> using reciprocals.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_czjzrzpt">
                    <m>x = \frac{5}{12} \times \frac{8}{3} = \frac{40}{36} = \frac{10}{9}</m>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_ina3a960">
            <statement>
                <p xml:id="auto_oooze3i7">
                     A rope of length <m>18</m> m is cut into pieces each measuring <m>\frac{3}{4}</m> m.
                     How many pieces are obtained?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_05bq193s">
                    <m>18 \div \frac{3}{4} = 18 \times \frac{4}{3} = 24</m> pieces.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_mzmekbg7">
            <statement>
                <p xml:id="auto_dfp2oi3c">
                    A hiker is walking <m>24</m> km and takes breaks every <m>\frac{2}{3}</m> km.
                    How many breaks will he take by the end of the journey? If he changes his break interval to <m>1\frac{1}{3}</m> km, how does the number of breaks change?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_ipqmgrm9">
                Number of breaks at <m>\frac{2}{3}</m> km intervals: <m>24 \times \frac{3}{2} = 36</m> breaks.
                </p>
                <p xml:id="auto_qs3y5lcv">
                    Number of breaks at <m>1\frac{1}{3}</m> km intervals: <m>= 24 \times \frac{3}{4} = 18</m> breaks.
                </p>
                <p xml:id="auto_wffuv7o5">
                    Changing the break interval to <m>1\frac{1}{3}</m> km reduces the number of breaks from <m>36</m> to <m>18</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_se45tyvf">
            <statement>
                <p xml:id="auto_xtub6iht">
                    A road is <m>12.6</m> km long and is divided into equal segments of <m>0.35</m> km for maintenance.
                     How many segments are there?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_genjcmoc">
                    <m> 12.6 \times \frac{1}{0.35} = 36</m> segments.
                </p>
            </answer>
        </exercise>        
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        Provide a step-by-step reference card showing how to find reciprocals of whole numbers, fractions, and decimals. Begin with simple whole number divisions before progressing to fractions. Use visual fraction models to illustrate division.
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        Complete all practice problems as designed. Encourage students to verify answers by multiplying the result by the divisor.
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        Create their own real-world problems involving reciprocals and present them to the class. Explore combined work-rate problems (e.g. two pipes filling a tank at different rates).
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>

    <xi:include href="../../resources-assessment.ptx" />
    <xi:include href="../../resources-reflection.ptx"/>
    
    
</subsubsection>