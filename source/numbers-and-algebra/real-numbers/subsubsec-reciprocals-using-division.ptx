                </exercise>
    <exercises xml:id="exercises-division-reciprocals-of-real-numbers">
        <title>Exercise</title>
        <exercise xml:id="auto_0f77i6zh">
            <statement>
                <p xml:id="auto_5kf6agy3">
                    Using division, find the reciprocal of following numbers:
                    </p>
                    <p xml:id="auto_pgd37teb">
                        <ol xml:id="auto_svpnfcux" marker="(a)" cols="3">
                            <li xml:id="auto_wa48w9ym">
                                <p xml:id="auto_7uwa1b3r">
                                  <m>5</m>  
                                </p>
                            </li>
                            <li xml:id="auto_6o3ws5fs">
                                <p xml:id="auto_i5w36du4">
                                    <m>-3</m>
                                </p>
                            </li>
                            <li xml:id="auto_r6h84rkg">
                                <p xml:id="auto_s5ema6ik">
                                    <m>2.5</m>
                                </p>
                            </li>
                            <li xml:id="auto_clnzpgr5">
                                <p xml:id="auto_84xcvyi5">
                                    <m>-0.4</m>
                                </p>
                            </li>
                            <li xml:id="auto_o4i9yh7y">
                                <p xml:id="auto_gnmld06f">
                                    <m>\frac{2}{7}</m>
                                </p>
                            </li>
                            <li xml:id="auto_7s2qvfo3">
                                <p xml:id="auto_6h73d3ky">
                                    <m>-\frac{5}{8}</m>
                                </p>
                            </li>
                        </ol>
                    </p>
            </statement>
            <answer>
                <p xml:id="auto_jj51rhf4">
                    <ol xml:id="auto_alhh53s0" marker="(a)" cols="3">
                        <li xml:id="auto_mtgjzch1">
                            <p xml:id="auto_rouh2xi8">
                                <m>\frac{1}{5} = 0.2</m>
                            </p>
                        </li>
                        <li xml:id="auto_w2awep28">
                            <p xml:id="auto_y3jpbztx">
                                <m>\frac{1}{-3} = -0.333...</m>
                            </p>
                        </li>
                        <li xml:id="auto_k3nht2mu">
                            <p xml:id="auto_68gv4w66">
                                <m>\frac{1}{2.5} = 0.4</m>
                            </p>
                        </li>
                        <li xml:id="auto_eoeaoj62">
                            <p xml:id="auto_7shs4s14">
                                <m>\frac{1}{-0.4} = -2.5</m>
                            </p>
                        </li>
                        <li xml:id="auto_saru0vla">
                            <p xml:id="auto_1scbzcwu">
                                <m>\frac{1}{\frac{2}{7}} = 3.5</m>
                            </p>
                        </li>
                        <li xml:id="auto_o2uivrqs">
                            <p xml:id="auto_866c2dmg">
                                <m>\frac{1}{-\frac{5}{8}} = -1.6</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_iblq0lnh">
            <statement>
                <p xml:id="auto_stccdu0z">
                    If the reciprocal of <m>x</m> is <m>\frac{1}{6}</m>, find the value of <m>x</m>.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_bfghq1q5">
                 <m>\frac{1}{x} = \frac{1}{6}</m>. 
                    Therefore, <m>x = 6</m>.
                </p>
            </answer>
        </exercise> 
        <exercise xml:id="auto_3l6d5rfd">
            <statement>
                <p xml:id="auto_a2841x26">
                     Movin, a Grade <m>10</m> learner covers <m>\frac{1}{x}</m> km from home to school. If the distance he covers each day from home to school is <m>0.2</m> km. Find the value of <m>x</m>.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_ul71ayt4">
                 <m>\frac{1}{x} = \frac{2}{10} = \frac{1}{5}</m> which implies that <m>x = 5</m>.
                </p>
            </answer>
        </exercise> 
        <exercise xml:id="auto_ho7ikhgb">
            <statement>
                <p xml:id="auto_fo2zu91q">
                    A cyclist covers a distance of <m>12 </m> km in <m>1</m> hour. Using division to find reciprocals, determine the time taken to cover <m>1</m> km at the same speed.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_bf6ntt2w">
                    The reciprocal of <m>12</m> is <m>1 \div 12 = 0.0833</m> hours.
                </p>
            </answer>
        </exercise> 
        <exercise xml:id="auto_vao6c0tq">
            <statement>
                <p xml:id="auto_4mkd09qq">
                     A factory machine produces <m>\frac{5}{8}</m> of a widget every minute. How long will it take the machine to produce <m>40</m> widgets?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_2wv8afg3">
                    The reciprocal of <m>\frac{5}{8}</m> is <m>1 \div \frac{5}{8}  = 1.6</m> minutes per widget. 
                    Time taken to produce <m>40</m> widgets is <m> 64</m> minutes.
                </p>
            </answer>
        </exercise> 
        <exercise xml:id="auto_g328qi6g">
            <statement>
                <p xml:id="auto_oi4gurfx">
                    A typist can type <m>\frac{4}{7}</m> of a page in <m>8</m> minutes. At this rate, how long will it take to type a full <m>25</m>-page document?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_syj45rq9">
                       The reciprocal of <m>\frac{4}{7}</m> is <m>1 \div \frac{4}{7} = 1.75</m> minutes per page. 
                        Time taken to type <m>25</m> pages is <m>43.75</m> minutes.  
                </p>
            </answer>
        </exercise>
    </exercises>
