        <exercise xml:id="auto_x4096meg">
            <title>Determining Common Logarithms Using a Calculator</title>

            <introduction xml:id="auto_hae62406">
                <p xml:id="auto_u5sex221">Load the question by clicking the button below.</p>
            </introduction>

            <stack label="common-logs-calculator" source="stack/top/1-0-Numbers-Algebra/Indices-and-Logarithms/Logarithms/Determining-Common-Logarithms-Using-Mathematical-Tables-and-Calc/Determining-common-logarithms-using-a-calculator.xml"/>
        </exercise>

        <exercises xml:id="exercises-Determining-common-logarithms-using-mathematical-tables-and-calculators">
            <exercise xml:id="auto_i61mukpf">
                <statement>
                    <p xml:id="auto_ejjtmd2s">
                        Use a logarithm table to find the logarithm of the following numbers:
                    </p>
                    <p xml:id="auto_shxtqivc">
                        <ol xml:id="auto_9omofkeq" marker="(a)" cols="2">
                            <li xml:id="auto_4kocfy15">
                                <p xml:id="auto_dj9o5it1">
                                    <m>0.00893</m>
                                </p>
                            </li>
                            <li xml:id="auto_3lb8kbsi">
                                <p xml:id="auto_gknd1bqa">
                                    <m>3140</m>
                                </p>
                            </li>
                            <li xml:id="auto_w8oa1p72">
                                <p xml:id="auto_3jiftgmc">
                                    <m>52.7</m>
                                </p>
                            </li>
                            <li xml:id="auto_51hzzeqj">
                                <p xml:id="auto_fv65ekl8">
                                    <m>0.000978</m>
                                </p>
                            </li>
                            <li xml:id="auto_4kocfy15_e">
                                <p xml:id="auto_9new_e">
                                    <m>0.000245</m>
                                </p>
                            </li>
                            <li xml:id="auto_3lb8kbsi_f">
                                <p xml:id="auto_9new_f">
                                    <m>6.42 \times 10^3</m>
                                </p>
                            </li>
                            <li xml:id="auto_w8oa1p72_g">
                                <p xml:id="auto_9new_g">
                                    <m>78900</m>
                                </p>
                            </li>
                        </ol>
                    </p>
                </statement>
            <answer>
                <p xml:id="auto_9uvc3906">
                    <ol xml:id="auto_8ta41gzb" marker="(a)">
                        <li xml:id="auto_5v1fxe4j"><m>\log(0.00893)=\bar{3}.9509\quad(\approx -2.0491)</m></li>
                        <li xml:id="auto_6lawz20f"><m>\log(3140)=3.4969</m></li>
                        <li xml:id="auto_okr3ycnk"><m>\log(52.7)=1.7218</m></li>
                        <li xml:id="auto_onf21k7h"><m>\log(0.000978)=\bar{4}.9903\quad(\approx -3.0097)</m></li>
                        <li xml:id="auto_c3ngfiew"><m>\log(0.000245)=\bar{4}.3892\quad(\approx -3.6108)</m></li>
                        <li xml:id="auto_80hvk6zm"><m>\log(6.42\times10^{3})=3.8075</m></li>
                        <li xml:id="auto_p6fct9qs"><m>\log(78900)=4.8971</m></li>
                    </ol>
                </p>
            </answer>
            </exercise>
        </exercises>

