    <exercises xml:id="exercises-indicies-intro">
        <exercise xml:id="auto_tlp0ss1t">
            <statement>
                <p xml:id="auto_s4u1m9r8">
                    Express the following numbers in standard form.
                </p>
                <p xml:id="auto_t53i5mut">
                    <ol xml:id="auto_aeagwwtx" marker="(a)" cols="2">
                        <li xml:id="auto_ejyvdle0">
                            <p xml:id="auto_f1x6kzo1">
                                <m>4820</m>
                            </p>
                        </li>
                        <li xml:id="auto_ipa8qxk1">
                            <p xml:id="auto_z8sm418c">
                                <m>37.6</m>
                            </p>
                        </li>
                        <li xml:id="auto_88vuh0ma">
                            <p xml:id="auto_03a5k2pf">
                                <m>672000</m>
                            </p>
                        </li>
                        <li xml:id="auto_bm17ez3c">
                            <p xml:id="auto_by08hkhh">
                                <m>321000</m>
                            </p>
                        </li>
                        <li xml:id="auto_tgjxwoqz">
                            <p xml:id="auto_7vtt4h51">
                                <m>4850</m>
                            </p>
                        </li>
                        <li xml:id="auto_c31zxfzd">
                            <p xml:id="auto_3ceeuj9a">
                                <m>91800</m>
                            </p>
                        </li>
                        <li xml:id="auto_0c9yb107">
                            <p xml:id="auto_zbc9md8k">
                                <m>52.7 \times 10^5</m>
                            </p>
                        </li>
                        <li xml:id="auto_9ezhe16h">
                            <p xml:id="auto_so1cz1wg">
                                <m>60</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
        <answer>
            <p xml:id="auto_zjpzae3x">
                <ol xml:id="auto_z2ujuzx6" marker="(a)" cols="2">
                    <li xml:id="auto_zar4mn58"><m>4.82 \times 10^{3}</m></li>
                    <li xml:id="auto_7iebpwvl"><m>3.76 \times 10^{1}</m></li>
                    <li xml:id="auto_5t00v92b"><m>6.72 \times 10^{5}</m></li>
                    <li xml:id="auto_ynb7c7jk"><m>3.21 \times 10^{5}</m></li>
                    <li xml:id="auto_4c097nfh"><m>4.85 \times 10^{3}</m></li>
                    <li xml:id="auto_e7m4ubhj"><m>9.18 \times 10^{4}</m></li>
                    <li xml:id="auto_0w7pn0ud"><m>5.27 \times 10^{6}</m></li>
                    <li xml:id="auto_06m0oiso"><m>6 \times 10^{1}</m></li>
                </ol>
            </p>
        </answer>
    </exercise>
    </exercises>
