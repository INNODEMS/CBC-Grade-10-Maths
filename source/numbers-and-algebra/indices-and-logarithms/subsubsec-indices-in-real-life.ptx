    <exercises xml:id="exercises-pplication-of-indices-in-real-life-situations">
        <exercise xml:id="auto_a0tk3i95">
            <statement>
                <p xml:id="auto_sodpx7d3">
                    The Science Club of Bidii Secondary School is conducting an experiment on bacteria growth. They place <m>1,000</m> bacteria in a petri dish and observe that the bacteria triple every <m>5</m> hours.
                </p>
                <p xml:id="auto_ojl32u4g">
                    <ol xml:id="auto_myel9mhy" marker = "a)">
                        <li xml:id="auto_qoird24n">
                            <p xml:id="auto_1x7h4ju8">
                                How many bacteria will be present after <m>10</m> hours?
                            </p>
                        </li>
                        <li xml:id="auto_s632gwi5">
                            <p xml:id="auto_hm51byhp">
                                How many bacteria will be present after <m>20</m> hours?
                            </p>
                        </li>
                        <li xml:id="auto_fnohw8vq">
                            <p xml:id="auto_w8sc8rub">
                                How long will it take for the bacteria to reach <m>243,000</m>?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
        <answer>
            <p xml:id="auto_b24nejky">
                <ol xml:id="auto_84ye4hv0" marker="(a)">
                    <li xml:id="auto_ibjlrpnb"><m>1{,}000\times3^{2}=9{,}000</m></li>
                    <li xml:id="auto_fjmcfc7p"><m>1{,}000\times3^{4}=81{,}000</m></li>
                    <li xml:id="auto_675fz4wv"><m>243{,}000=1{,}000\times3^{5}\Rightarrow\text{time}=5\times5=25\ \text{hours}</m></li>
                </ol>
            </p>
        </answer>
        </exercise>
        <exercise xml:id="auto_zmf11dqk">
            <statement>
                <p xml:id="auto_xu3dv24e">
                    During the tree planting month in the school, the principal planted <m>3</m> trees in the first week. Each week, the number of trees planted by the principle triples.
                </p>
                <p xml:id="auto_ttyj84f0">
                    <ol xml:id="auto_iok3tl15" marker = "a)">
                        <li xml:id="auto_pdqwoafj">
                            <p xml:id="auto_gbsek43l">
                                How many trees will be planted by the <m>5^{th}</m> week?
                            </p>
                        </li>
                        <li xml:id="auto_wr828rqg">
                            <p xml:id="auto_q4zdd7rw">
                                How long will it take for the principal to plant at least <m>2,000</m> trees?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
        <answer>
            <p xml:id="auto_pgwkgcex">
                <ol xml:id="auto_fj3r8jhv" marker="(a)">
                    <li xml:id="auto_msefth39"><m>3^{5}=243</m></li>
                    <li xml:id="auto_cncvd48q"><m>3^{7}=2{,}187\Rightarrow\text{7 weeks (first week counts as week 1)}</m></li>
                </ol>
            </p>
        </answer>
        </exercise>
        <exercise xml:id="auto_gwo8b8bu">
            <statement>
                <p xml:id="auto_8n9qz5wq">
                    Upendo Bank offers compound interest where an investment grows by a factor of <m>1.05</m> per year. A person invests Ksh <m>50,000</m>.
                </p>
                <p xml:id="auto_kn875xkt">
                    <ol xml:id="auto_ad3k3aw4" marker = "a)">
                        <li xml:id="auto_ixxpuugx">
                            <p xml:id="auto_s2eea6x9">
                                Write an index notation for the amount after <m>10</m> years.
                            </p>
                        </li>
                        <li xml:id="auto_ziqznvo4">
                            <p xml:id="auto_ifynuh6x">
                                Find the total amount after <m>10</m> years.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
        <answer>
            <p xml:id="auto_99miovnd">
                <ol xml:id="auto_8qxcm8xu" marker="(a)">
                    <li xml:id="auto_89y6j0pu"><m>50{,}000\times(1.05)^{10}</m></li>
                    <li xml:id="auto_i91r0onx"><m>50{,}000\times(1.05)^{10}\approx81{,}444.73\ \text{Ksh}</m></li>
                </ol>
            </p>
        </answer>
        </exercise>
        <exercise xml:id="auto_ikq9cq99">
            <statement>
                <p xml:id="auto_k36unn4q">
                    The storage capacity of computers has been increasing exponentially. The school library computer storage was <m>2</m> GB in the year <m>2000</m>, and its capacity doubles every <m>2</m> years.
                </p>
                <p xml:id="auto_dlllbstl">
                    <ol xml:id="auto_7mh9r8ns" marker = "a)">
                        <li xml:id="auto_nxl54lui">
                            <p xml:id="auto_exnjhrs1">
                                Write an expression using indices for the capacity after <m>8</m> years.
                            </p>
                        </li>
                        <li xml:id="auto_wxyjocbv">
                            <p xml:id="auto_9zi68md6">
                                What will the storage capacity be after <m>5</m> years?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
        <answer>
            <p xml:id="auto_pkzukxc3">
                <ol xml:id="auto_2ou3cwgi" marker="(a)">
                    <li xml:id="auto_4k246zrw"><m>2\times2^{4}=2^{5}=32\ \text{GB}</m></li>
                    <li xml:id="auto_klnzmu1v"><m>2\times2^{5/2}=2^{7/2}\approx11.31\ \text{GB}</m></li>
                </ol>
            </p>
        </answer>
        </exercise>
        <exercise xml:id="auto_j4le95oq">
            <statement>
                <p xml:id="auto_tlbrqzyx">
                    A doctor prescribes a medicine that reduces to <m>\frac {1}{4}</m> of its original amount in the body every <m>6</m> hours.
                </p>
                <p xml:id="auto_mlfu8pqi">
                    <ol xml:id="auto_zo2d0sgv" marker = "a)">
                        <li xml:id="auto_6bec17jm">
                            <p xml:id="auto_6nabz922">
                                Express the remaining amount after <m>18</m> hours in index form.
                            </p>
                        </li>
                        <li xml:id="auto_52qswwe4">
                            <p xml:id="auto_slzig0mr">
                                If the initial dosage was <m>200</m> mg, calculate the amount left after <m>18</m> hours.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
        <answer>
            <p xml:id="auto_11e6rsxp">
                <ol xml:id="auto_6n39kric" marker="(a)">
                    <li xml:id="auto_zkvd96zw"><m>(\tfrac{1}{4})^{3}</m></li>
                    <li xml:id="auto_j18dp9sz"><m>200\times(\tfrac{1}{4})^{3}=200\times\tfrac{1}{64}=3.125\,\text{mg}</m></li>
                </ol>
            </p>
        </answer>
        </exercise>
        <exercise xml:id="auto_z4fn5wq5">
            <statement>
                <p xml:id="auto_oufx5wpz">
                    The intensity of sound is measured in decibels and follows an exponential scale. If a normal conversation is <m>10^2</m> times louder than a whisper and a jet engine is <m>10</m> times louder than a whisper:
                </p>
                <p xml:id="auto_okr268ah">
                    <ol xml:id="auto_9emk1p6c" marker="(a)">
                        <li xml:id="auto_s2mrd2yc">
                            <p xml:id="auto_9rzsqg7x">
                                How many times louder is a jet engine compared to a normal conversation?
                            </p>
                        </li>
                        <li xml:id="auto_0m29boyn">
                            <p xml:id="auto_taz2ippm">
                                Express this in index notation.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
        <answer>
            <p xml:id="auto_p2xzwebn">
                <ol xml:id="auto_wi6r4ur5" marker="(a)">
                    <li xml:id="auto_bobnk55u"><m>\dfrac{10}{10^{2}}=10^{-1}=\dfrac{1}{10}</m></li>
                    <li xml:id="auto_hynjadti"><m>10^{-1}</m></li>
                </ol>
            </p>
        </answer>
        </exercise>
        </exercises>
    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Provide formula cards with <m>P = P_0 \times r^n</m>. Use tables to show step-by-step growth. Start with simple doubling patterns. Allow calculator use for calculations.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> 1) A doctor prescribes medicine that reduces to <m>\frac{1}{4}</m> every 6 hours. Express the remaining amount after 18 hours in index form. If the initial dose was 200 mg, calculate the amount left. 2) Sound intensity: If a jet engine is <m>10^6</m> times louder than a whisper and a conversation is <m>10^2</m> times louder than a whisper, how many times louder is a jet engine than a conversation?</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>
    <xi:include href="../../resources-assessment.ptx" />
    <xi:include href="../../resources-reflection.ptx"/>
</subsubsection>
