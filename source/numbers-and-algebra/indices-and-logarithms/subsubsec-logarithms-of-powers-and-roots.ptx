        </exercise>

        <exercises xml:id="exercises-applying-logarithms-to-powers-and-roots">
            <exercise xml:id="auto_sn95t4rz">
                <statement>
                    <p xml:id="auto_c1vvazib">
                        Compute the following using logarithms:
                    </p>
                    <p xml:id="auto_lvefifw6">
                        <ol xml:id="auto_h1w1vv88" marker="(a)">
                            <li xml:id="auto_e1iyufpk">
                                <p xml:id="auto_k6971n8o">
                                    <m>(78.5)^3</m>
                                </p>
                            </li>
                            <li xml:id="auto_qq4jxjnq">
                                <p xml:id="auto_wyu19tbl">
                                    <m>(254.6)^4</m>
                                </p>
                            </li>
                            <li xml:id="auto_2nku2g6d">
                                <p xml:id="auto_tugoqrff">
                                    <m>(12.75)^{2.5}</m>
                                </p>
                            </li>
                        </ol>
                    </p>
                </statement>
            <answer>
                <p xml:id="auto_om9ellgk">
                    <ol xml:id="auto_lxdxbarj" marker="(a)">
                        <li xml:id="auto_ss8kk7m3"><m> \approx 483\,736.6</m></li>
                        <li xml:id="auto_f1b1efxu"><m> \approx 4.2018 \times 10^{9}</m></li>
                        <li xml:id="auto_p1heo7js"><m> \approx 580.4642</m></li>
                    </ol>
                </p>
            </answer>
            </exercise>
            <exercise xml:id="auto_hz0z8ie5">
                <statement>
                    <p xml:id="auto_xbzcqrqs">
                        Compute the following roots using logarithms:
                    </p>
                    <p xml:id="auto_av1fr3h3">
                        <ol xml:id="auto_0b6c1n75" marker="(a)">
                            <li xml:id="auto_dt2d9or6">
                                <p xml:id="auto_umt0rq0o">
                                    <m>\sqrt[3]{658.4}</m>
                                </p>
                            </li>
                            <li xml:id="auto_kthytji4">
                                <p xml:id="auto_pe7xhymk">
                                    <m>\sqrt{82.6}</m>
                                </p>
                            </li>
                            <li xml:id="auto_qc4fryv8">
                                <p xml:id="auto_iek7dua1">
                                    <m>\sqrt[4]{3126}</m>
                                </p>
                            </li>
                        </ol>
                    </p>
                </statement>
            <answer>
                <p xml:id="auto_w9f1qhk5">
                    <ol xml:id="auto_g2eoiikw" marker="(a)">
                        <li xml:id="auto_ubqpsxvj"><m> \approx 8.6995</m></li>
                        <li xml:id="auto_hcps5mor"><m> \approx 9.0885</m></li>
                        <li xml:id="auto_eonht7d9"><m> \approx 7.4773</m></li>
                    </ol>
                </p>
            </answer>
            </exercise>
            <exercise xml:id="auto_cprcqd6f">
                <statement>
                    <p xml:id="auto_yzy7fhzr">
                        A square field has an area of <m>18432</m> square metres. Use logarithms to determine the length of one side.
                    </p>
                </statement>
            <answer>
                <p xml:id="auto_nm7mci9o">
                    <m>\text{Side length} = \sqrt{18432} \approx 135.7645\ \text{m}</m>
                </p>
            </answer>
            </exercise>
            <exercise xml:id="auto_413n15dy">
                <statement>
                    <p xml:id="auto_1esiu7ak">
                        Use logarithm tables to evaluate:
                    </p>
                    <p xml:id="auto_oilfqvus">
                        <ol xml:id="auto_zv5i4o9t" marker="(a)">
                            <li xml:id="auto_4rkptkgx">
                                <p xml:id="auto_7hl15djx">
                                    <m>\sqrt{ \frac{(4.56 \times 12.3)}{24.7} }</m>
                                </p>
                            </li>
                            <li xml:id="auto_93xctv2r">
                                <p xml:id="auto_wjmmc741">
                                    <m>\sqrt{ \frac{(2.718 \times 9.81)}{5.432 \times 3.14} }</m>
                                </p>
                            </li>
                            <li xml:id="auto_8apuqd8m">
                                <p xml:id="auto_e1wu01c4">
                                    <m>\frac{\sqrt{52.8 \times 24.6}}{\sqrt{31.5}}</m>
                                </p>
                            </li>
                            <li xml:id="auto_rxalsepa">
                                <p xml:id="auto_b4l1uh29">
                                    <m>\sqrt[3]{\frac{(6.75 \times 432)}{0.89}}</m>
                                </p>
                            </li>
                            <li xml:id="auto_13flx8tj">
                                <p xml:id="auto_6a9uobki">
                                    <m>\sqrt[4]{\frac{(8462 \times 23.7)}{673}}</m>
                                </p>
                            </li>
                        </ol>
                    </p>
                </statement>
            <answer>
                <p xml:id="auto_yv71raay">
                    <ol xml:id="auto_ce40wl6g" marker="(a)">
                        <li xml:id="auto_a42ilufe"><m> \approx 1.5069</m></li>
                        <li xml:id="auto_fqtf5k17"><m> \approx 1.2503</m></li>
                        <li xml:id="auto_0mjo6ent"><m> \approx 6.4214</m></li>
                        <li xml:id="auto_6kdl7tdc"><m> \approx 14.8525</m></li>
                        <li xml:id="auto_rr9lpzxr"><m> \approx 4.1548</m></li>
                    </ol>
                </p>
            </answer>
            </exercise>
            <exercise xml:id="auto_7l3ixouf">
                <statement>
                    <p xml:id="auto_qn4e2iw8">
                        The volume of a cube is <m>79507</m> cubic centimetres. Use logarithms to find the length of one side.
                    </p>
                </statement>
            <answer>
                <p xml:id="auto_pjjvizgg">
                    <m>43\ \text{cm}</m>
                </p>
            </answer>
            </exercise>
        </exercises>

        <axiom component="lesson-plan">
            <title>Differentiation</title>
            <tabular bottom="medium" top="medium" left="medium" right="medium">
                <row header="yes">
                    <cell>Student Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>Provide step-by-step formula cards. Start with simple powers of 10. Use visual aids showing the power law. Allow extra time with calculators. Practice converting roots to fractional powers. Provide worked examples as reference.</cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>The core lesson activities as described above.</cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>Introduce higher order roots (4th, 5th roots). Combine power law with product and quotient laws. Solve exponential equations using logarithms. Explore applications in compound interest. Investigate logarithmic scales (Richter, pH, decibels).</cell>
                </row>
            </tabular>
        </axiom>
        <axiom component="lesson-plan">
            <title>Extension Activity</title>
            <paragraphs>
                <title>Real-World Applications Investigation</title>
                <p>
                    <alert>Objective:</alert> Apply logarithms of powers and roots to real-world scenarios.
                </p>
                <p>
                    <alert>Activity Description:</alert>
                </p>
                <ol>
                    <li><p>Research one real-world application (choose one):
                        <ul>
                            <li><p>Compound interest calculations (money growing exponentially)</p></li>
                            <li><p>Population growth models</p></li>
                            <li><p>Radioactive decay in nuclear physics</p></li>
                            <li><p>Sound intensity (decibel scale)</p></li>
                            <li><p>Earthquake magnitude (Richter scale)</p></li>
                        </ul>
                    </p></li>
                    <li><p>Identify how powers and roots are involved.</p></li>
                    <li><p>Use logarithms to solve a related problem.</p></li>
                    <li><p>Present findings with calculations to the class.</p></li>
                </ol>
            </paragraphs>
            <paragraphs>
                <title>Calculator vs. Tables Challenge</title>
                <p>Students compare results:</p>
                <ul>
                    <li><p>Solve the same power/root problem using both calculator and logarithm tables</p></li>
                    <li><p>Compare accuracy and efficiency</p></li>
                    <li><p>Discuss when each method is more appropriate</p></li>
                    <li><p>Reflect on the historical importance of logarithm tables</p></li>
                </ul>
            </paragraphs>
        </axiom>
        <xi:include href="../../resources-assessment.ptx" />
        <xi:include href="../../resources-reflection.ptx"/>

    </subsubsection>