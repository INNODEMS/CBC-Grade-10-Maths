        <p xml:id="auto_8826bq40">
            <alert>Important Properties for Applications:</alert>
            <ul>
                <li xml:id="auto_bvwpeczr"><p xml:id="auto_wd4w04a9"><m>\log(ab) = \log a + \log b</m> — useful for compound calculations</p></li>
                <li xml:id="auto_iq1qe6tq"><p xml:id="auto_4r75uok0"><m>\log(a/b) = \log a - \log b</m> — useful for ratio comparisons</p></li>
