    <exercises xml:id="exercises-finding-antilogarithms-using-a-calculator">
        <exercise xml:id="auto_dbwe1rjv">
            <statement>
                <p xml:id="auto_quldlhpt">
                    Find the antilogarithms of the following logarithmic values using logarithm tables:
                </p>
                <p xml:id="auto_k1o8ip2s">
                    <ol xml:id="auto_a33i7i2j" marker = "i)">
                        <li xml:id="auto_so7bio9y">
                            <p xml:id="auto_b4gb7hdm">
                                <m>\log P = 1.3562</m>
                            </p>
                        </li>
                        <li xml:id="auto_be22awm2">
                            <p xml:id="auto_agkih03b">
                                <m>\log Q = 3.4821</m>
                            </p>
                        </li>
                        <li xml:id="auto_wue3wvp6">
                            <p xml:id="auto_umle43bw">
                                <m>\log R = 0.7294</m>
                            </p>
                        </li>
                        <li xml:id="auto_tgfbkw5y">
                            <p xml:id="auto_mg52thek">
                                <m>\log S = 4.2187</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_687oqu79">
                    <ol xml:id="auto_gf2lyu4d" marker="i)">
                        <li xml:id="auto_1dytk5bm"><m>P = \approx 22.7091</m></li>
                        <li xml:id="auto_4x7sm0dc"><m>Q = \approx 3034.5898</m></li>
                        <li xml:id="auto_puv9ssql"><m>R = \approx 5.3629</m></li>
                        <li xml:id="auto_2zklu96d"><m>S = \approx 16546.2659</m></li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_onlogev1">
            <statement>
                <p xml:id="auto_73eh5xur">
                    Solve the following logarithms using a calculator:
                </p>
                <p xml:id="auto_bs04cd8m">
                    <ol xml:id="auto_w30bmi4b" marker="i)">
                        <li xml:id="auto_kax8q8q4">
                            <p xml:id="auto_cgk7lha7">
                                <m>\log a = 2.1457</m>
                            </p>
                        </li>
                        <li xml:id="auto_m7gd44or">
                            <p xml:id="auto_yngz22sg">
                                <m>\log b = 0.8743</m>
                            </p>
                        </li>
                        <li xml:id="auto_xb07kt7k">
                            <p xml:id="auto_8ifwxiby">
                                <m>\log c = 3.5961</m>
                            </p>
                        </li>
                        <li xml:id="auto_x4r775w3">
                            <p xml:id="auto_j9udd344">
                                <m>\log d = 1.9999</m>
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_mn5zqsso">
                    <ol xml:id="auto_jdcnlzfn" marker="i)">
                        <li xml:id="auto_3hpw4grm"><m>a = \approx 139.8621</m></li>
                        <li xml:id="auto_ey96adfv"><m>b = \approx 7.4869</m></li>
                        <li xml:id="auto_5vv7ocxj"><m>c = \approx 3945.4814</m></li>
                        <li xml:id="auto_kh8jgpwh"><m>d = \approx 99.9770</m></li>
                    </ol>
                </p>
            </answer>
        </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Assessment / Evaluate (Exit Ticket)</title>
        <p xml:id="auto_wpcthprc">
            <alert>Objective:</alert> To formatively assess individual student understanding.
        </p>
        <p xml:id="auto_v8ulpq8o">
            <alert>Learning Experience:</alert> Students complete exit ticket questions individually:
            <ol>
                <li xml:id="auto_21z7mle2"><p xml:id="auto_wrxvrrsq">Find the antilogarithms of given values using logarithm tables (e.g., <m>\log P = 1.3562</m>, <m>\log Q = 3.4821</m>)</p></li>
                <li xml:id="auto_xwh96gad"><p xml:id="auto_dct9nrez">Solve for unknowns using a calculator (e.g., <m>\log a = 2.1457</m>, <m>\log b = 0.8743</m>)</p></li>
            </ol>
        </p>
        <p xml:id="auto_ljr9sgzq">
            <alert>Teacher's Role:</alert> Collect and review the exit tickets to gauge student understanding and identify any common misconceptions that need to be addressed in the next lesson.
        </p>
    </axiom>
    <xi:include href="../../resources-checkpoint.ptx" />
