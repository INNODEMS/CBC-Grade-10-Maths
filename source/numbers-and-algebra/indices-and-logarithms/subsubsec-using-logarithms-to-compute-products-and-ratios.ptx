    <axiom component="lesson-plan">
        <title>Differentiation</title>
        <tabular bottom="medium" top="medium" left="medium" right="medium">
            <row header="yes">
                <cell>Student Group</cell>
                <cell>Strategy &amp; Learning Experience</cell>
            </row>
            <row>
                <cell>Struggling Learners (Support)</cell>
                <cell>Scaffolding: Provide step-by-step calculation templates. Use color coding for each step. Allow calculator verification. Focus on single operations before combining.</cell>
            </row>
            <row>
                <cell>On-Level Learners (Core)</cell>
                <cell>The core lesson activities as described above.</cell>
            </row>
            <row>
                <cell>Advanced Learners (Challenge)</cell>
                <cell>Extended Learning Experience: 1) Evaluate <m>\sqrt[4]{(8462 \times 23.7) \div 673}</m>. 2) Evaluate <m>\sqrt[3]{(6.75 \times 432) \div 0.89}</m>. 3) Prove: <m>\log(\sqrt{a} \times \sqrt[3]{b}) = \frac{1}{2}\log(a) + \frac{1}{3}\log(b)</m>.</cell>
            </row>
        </tabular>
    </axiom>
