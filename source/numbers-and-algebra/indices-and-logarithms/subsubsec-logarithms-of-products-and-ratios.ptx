    <exercises xml:id="exercises-applying-logarithms-to-products-and-ratios">
        <exercise xml:id="auto_1vgvxi5o">
            <statement>
                <p xml:id="auto_fzt1z3y8">
                    Express the following as a sum or difference of logarithms and evaluate:
                </p>
                <p xml:id="auto_sh9rwu5y">
                    <ol marker="(a)" cols="2">
                        <li xml:id="auto_je5p72f6">
                                <m>\log_4 (64 \times 16)</m>
                        </li>
                        <li xml:id="auto_2b0i7qcl">
                            <m>\log_4 (64 \times 16)</m>
                        </li>
                        <li xml:id="auto_ht4ak88u"><m>\log_6 \left(\frac{216}{36}\right)</m></li>
                        <li xml:id="auto_jb5e115o"><m>\log_5 (25 \times 125)</m></li>
                        <li xml:id="auto_gijo2fc9"><m>\log_8 \left(\frac{512}{64}\right)</m></li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_kzyr80p3">
                    <ol marker="(a)" cols="2">
                        <li xml:id="auto_691oojmy"><m>6</m></li>
                        <li xml:id="auto_ux690id0"><m>2</m></li>
                        <li xml:id="auto_wiq0rc5n"><m>3</m></li>
                        <li xml:id="auto_5zk3kokb"><m>3</m></li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_olc906mn">
        <statement>
            <p xml:id="auto_i76af72m">
                Given that <m>\log_{10} 2 \approx 0.3010</m> and <m>\log_{10} 3 \approx 0.4771</m>, evaluate:
            </p>
            <p xml:id="auto_zmbdityg">
                <ol marker="(a)" cols="2">
                    <li xml:id="auto_e513qkrf"><m>\log_{10} 6</m></li>
                    <li xml:id="auto_rvsdh08a"><m>\log_{10} 1.5</m></li>
                    <li xml:id="auto_6dy6uaxp"><m>\log_{10} 5</m></li>
                </ol>
            </p>
        </statement>
        <answer>
            <p xml:id="auto_p3983pvd">
                <ol marker="(a)">
                    <li xml:id="auto_x0db5imj"><m>\log_{10}(2 \times 3) = 0.3010 + 0.4771 = 0.7781</m></li>
                    <li xml:id="auto_7mutjqxo"><m>\log_{10}(3 \div 2) = 0.4771 - 0.3010 = 0.1761</m></li>
                    <li xml:id="auto_9xw2mjkd"><m>\log_{10}(10 \div 2) = 1 - 0.3010 = 0.6990</m></li>
                </ol>
            </p>
        </answer>
    </exercise>
        <exercise xml:id="auto_bt66b7k9">
            <statement>
                <p xml:id="auto_bhk92gpb">
                    Write each of the following as a single logarithm:
                </p>
                <p xml:id="auto_cmlkk85z">
                    <ol marker="(a)" cols="2">
                        <li xml:id="auto_bmuodgtf"><m>\log_a 5 + \log_a 4</m></li>
                        <li xml:id="auto_2vituffj"><m>\log_x 18 - \log_x 3</m></li>
                        <li xml:id="auto_487o8ata"><m>\log_{10} 8 + \log_{10} 125</m></li>
                        <li xml:id="auto_i4575bxm"><m>\log_b 81 - \log_b 9</m></li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_to8otcz5">
                    <ol marker="(a)" cols="2">
                        <li xml:id="auto_93x85ua2"><m>\log_a 20</m></li>
                        <li xml:id="auto_qtrj1rd7"><m>\log_x 6</m></li>
                        <li xml:id="auto_gzowrlfs"><m>\log_{10} 1000 = 3</m></li>
                        <li xml:id="auto_b535ro86"><m>\log_b 9</m></li>
                    </ol>
                </p>
            </answer>
        </exercise>
    </exercises>

