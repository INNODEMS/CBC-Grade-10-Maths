<subsection xml:id="subsec-introduction-to-probability" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Introduction to Probability</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        3.0 Statistics and Probability
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        3.2 Probability 1
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title>
                    <p>
                        <ul>
                            <li>
                                <p>
                                    Perform experiments involving probabilities in different situations
                                </p>
                            </li>
                            <li>
                                <p>
                                    Identify the range of probability in different situations
                                </p>
                            </li>
                        </ul>
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        10
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            </p>
            <p component="lesson-plan">
                <p> Upon completion of this lesson, learners will be able to:
                <ol>
                    <li>
                        <p>
                            <alert>Know (Conceptual Understanding):</alert> Understand that probability is the measure of how likely an event is to occur, expressed as a number between 0 and 1.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Do (Procedural Skill):</alert> Perform experiments involving probabilities in different situations and identify the range of probability.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Apply (Application/Problem-Solving):</alert> Appreciate the application of probability in real-life situations.
                        </p>
                    </li>
                </ol>
                </p>
            </p>
        </introduction>
    </objectives>
    <axiom component="resources">
        <!-- Link to blurb -->
        <xi:include href="../../resources-blurb-lesson.ptx" />

        <sbsgroup widths="45% 45%" margins="2% 2%">
            <sidebyside>
                <p>
                    <dataurl source="lesson_plans/statistics-and-probability/probability-1/introduction-to-probability.pdf"> Lesson Plan </dataurl>
                </p>
                <p>
                    <dataurl source="lesson_plans/statistics-and-probability/probability-1/step-by-step-guide_introduction-to-probability.pdf"> Step-by-Step Guide </dataurl>
                </p>
            </sidebyside>
        </sbsgroup>
    </axiom>
    <xi:include href="../../resources-materials.ptx" />

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    Learners work in groups to identify real-world events, predict their likelihood using everyday language (likely, unlikely, certain), and begin developing intuition about probability.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Circulate among groups, observing their discussions. Ask guiding questions: <q>Why do you think that's likely?</q> <q>What makes you certain?</q> <q>Could you be more specific than just 'likely'?</q> Note interesting examples and reasoning patterns. Use learner discoveries to bridge to formal instruction.
                </p>
            </li>
        </dl>
        <paragraphs>
            <title>Discussion Prompts</title>
            <ul>
                <li><p>What events did you think of? Share some examples.</p></li>
                <li><p>Which events did you classify as <q>certain</q>? Why?</p></li>
                <li><p>Which events are <q>unlikely</q>? What makes them unlikely?</p></li>
                <li><p>Are there any events that are <q>equally likely</q> to happen or not happen?</p></li>
                <li><p>How do we decide if something is likely or unlikely? What information do we use?</p></li>
                <li><p>Can we be more precise than just <q>likely</q> or <q>unlikely</q>? Can we use numbers?</p></li>
            </ul>
        </paragraphs>
    </axiom>


    <activity xml:id="auto_p90fe0oq">
        <p xml:id="auto_yt3wij1a">
            <m>{\color{black} \textbf{Work in groups}}</m>
        </p>
        <p xml:id="auto_0axdh2x0">
            Write down 3 events that could happen today (e.g., “It will rain” or “I will be late to school”)
        </p>
        <p xml:id="auto_vv4wg159">
            Predict the probability of each event: <m>\textbf{Is it likely, unlikely, or certain}</m>?
        </p>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the definition of probability, introduce key terms, and present the probability formula.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

    <p xml:id="auto_s33tdsh4">
        <m>{\color{black} \textbf{Key Takeaway}}</m>
    </p>
    <p xml:id="auto_bv6ndd60">
        <m>\text{Probability}</m> is the measure of how likely an event is to occur. It is expressed as a number between 0 and 1, where:
        <ul xml:id="auto_cutqbt6y">
            <li xml:id="auto_klo0cyh0">
                <p xml:id="auto_8d0w2civ">
                    <m>0</m> means the event is impossible.
                </p>
            </li>
            <li xml:id="auto_91yy52w0">
                <p xml:id="auto_0v84fwlj">
                    <m>1</m> means the event is certain.
                </p>
            </li>
            <li xml:id="auto_yfzugbco">
                <p xml:id="auto_bogjpf27">
                    A probability closer to <m>1</m> indicates a higher likelihood of the event occurring.
                </p>
            </li>
        </ul>
    </p>
    <p xml:id="auto_6i3i15nw">
        Probability is always between 0 and 1
    </p>
    <p xml:id="auto_el2n8zq6">
        <m>\text{Probability Scale}</m>
    </p>
    <image width="60%">
        <latex-image label="probability-Scale">
            \begin{tikzpicture} [scale=1.5]
                
            % Draw the horizontal line
            \draw[thick] (0,0) -- (6,0);

            % Draw the tick marks
            \foreach \x/\label in {0/0, 1.5/0.25, 3/0.5, 4.5/0.75, 6/1} {
                \draw (\x,0) -- (\x,0.1);
                \node[below] at (\x,0) {\label};
            }

            % Add the labels above the line
            \node[above] at (0,0) {Impossible};
            \node[above] at (1.5,0) {Unlikely};
            \node[above] at (3,0) {Equally Likely};
            \node[above] at (4.5,0) {Likely};
            \node[above] at (6,0) {Certain};

            % Draw the circles, divide, and color
            \begin{scope}[yshift=-1.5cm]
                \foreach \x/\fillcount in {0/0, 1.5/1, 3/2, 4.5/3, 6/4} {
                \draw (\x,0) circle (0.5cm);
                \draw (\x-0.5, 0) -- (\x+0.5, 0);
                \draw (\x, -0.5) -- (\x, 0.5);

                % Color the appropriate sections
                \ifnum\fillcount>0
                    \ifnum\fillcount>0
                    \fill[blue!80] (\x,0) -- (\x+0.5,0) arc (0:90:0.5) -- cycle;
                    \fi
                    \ifnum\fillcount>1
                    \fill[blue!80] (\x,0) -- (\x,0.5) arc (90:180:0.5) -- cycle;
                    \fi
                    \ifnum\fillcount>2
                    \fill[blue!80] (\x,0) -- (\x-0.5,0) arc (180:270:0.5) -- cycle;
                    \fi
                    \ifnum\fillcount>3
                    \fill[blue!80] (\x,0) -- (\x,-0.5) arc (270:360:0.5) -- cycle;
                    \fi
                \fi
                }
            \end{scope}
            \end{tikzpicture}
        </latex-image>       
    </image>   
    <p xml:id="auto_ay9efuyp">
        <m>{\color{black} \text{Key Terms in Probability}}</m>
    </p>
    <p xml:id="auto_wyrqysvs">
        <ul xml:id="auto_8xbfrktb">
            <li xml:id="auto_pyvlhtmh">
                <p xml:id="auto_i6xbtsmi">
                    <m>\text{Experiment}</m> - A process that leads to a specific result.
                </p>
            </li>
            <li xml:id="auto_ptopwj9k">
                <p xml:id="auto_1otj9yu7">
                    <m>\text{Outcome}</m> - A possible result of an experiment.
                </p>
            </li>
            <li xml:id="auto_5sxe28o2">
                <p xml:id="auto_1hslfs0c">
                    <m>\text{Event}</m> - A collection of one or more outcomes.
                </p>
            </li>
            <li xml:id="auto_hpd545yn">
                <p xml:id="auto_9kyso3w6">
                    <m>\text{Sample Space (S)}</m> - The set of all possible outcomes.
                </p>
            </li>
            <li xml:id="auto_h4t33w45">
                <p xml:id="auto_z9nky175">
                    <m>\text{Probability (P)}</m> - A measure of how likely an event is to occur.
                </p>
            </li>
        </ul>
    </p>
    <p xml:id="auto_s1rq2676">
        Probability is widely used in everyday life, including:
    </p>
    <p xml:id="auto_cpiag7k8">
        <ul xml:id="auto_5m8wn949">
            <li xml:id="auto_vm0b7lj7">
                <p xml:id="auto_krbal7dr">
                    <m>\text{Weather Forecasting}</m> - Meteorologists predict the likelihood of rain based on past data.
                </p>
            </li>
            <li xml:id="auto_kfwy0epf">
                <p xml:id="auto_l7ken9j9">
                    <m>\text{Sports}</m> - Coaches analyze the probability of winning based on past performance.
                </p>
            </li>
            <li xml:id="auto_zwqlpf25">
                <p xml:id="auto_3m4v0j1i">
                    <m>\text{Medicine}</m> - Doctors assess the probability of a patient responding to treatment.
                </p>
            </li>
            <li xml:id="auto_vrsgqff7">
                <p xml:id="auto_3ewm4djj">
                    <m>\text{Finance and Insurance}</m> - Insurance companies use probability to determine policy pricing.
                </p>
            </li>
            <li xml:id="auto_qd9lb2eq">
                <p xml:id="auto_y0uc4oe4">
                    <m>\text{Games of Chance}</m> - Dice rolling and card games use probability.
                </p>
            </li>
        </ul>
    </p>

    <axiom component="lesson-plan">
        <title>Practice and Application</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To apply the probability formula to calculate the probability of simple events.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Work through examples with learners step by step. Circulate during independent practice and provide assistance where needed. Emphasize the steps: identify sample space, count favorable outcomes, count total outcomes, apply the formula.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

    <activity xml:id="auto_iyqdthjo">
        <p xml:id="auto_b19vk2du">
            <m>{\color{black} \textbf{Work in groups}}</m>
        </p>
        <p xml:id="auto_taywq1yi">
            Kanyama rolls a fair six-sided die. What is the probability of Kanyama rolling a <m>4</m>
        </p>
        <p xml:id="auto_4dphqssp">
            <ol xml:id="auto_40risjsn">
                <li xml:id="auto_bhw5jr6h">
                    <p xml:id="auto_z6j97wuc">
                        Identify the Sample Space.
                    </p>
                </li>
                <li xml:id="auto_95ock9bs">
                    <p xml:id="auto_uwvbm0sa">
                        Identify the Favorable Outcomes
                    </p>
                </li>
                <li xml:id="auto_dbr63ts2">
                    <p xml:id="auto_d32xpi3x">
                        Apply the Probability Formula
                    </p>
                </li>
                <li xml:id="auto_ztfbzhi1">
                    <p xml:id="auto_9jkv4ebp">
                        Discuss and compare answers
                    </p>
                </li>
            </ol>
        </p>
    </activity>
    <p xml:id="auto_u2y76dc6">
        <m>{\color{black} \textbf{Key Takeaway}}</m>
    </p>

    <p xml:id="auto_4n7le6dd">
        A simple event is an event that consists of only one outcome in the sample space.
    </p>
    <p xml:id="auto_164nt3o0">
        The probability of a simple event is given using the formula
        <md>
            <mrow>\textbf{P(E)} = \frac{\textbf{Number of favorable outcomes}}{\textbf{Number of Outcomes}}</mrow>
        </md>
    </p>
    <p xml:id="auto_80m4e362">
        where;
        <ul xml:id="auto_tk16rfph">
            <li xml:id="auto_9gw8fnmx">
                <p xml:id="auto_zf9gzcgj">
                    <m>\textbf{P(E)}</m> is the probability of event <m>\textbf{E}</m>
                </p>
            </li>
            <li xml:id="auto_aab66mat">
                <p xml:id="auto_2uefsv5f">
                    Favorable outcomes refer to the specific event we are interested in
                </p>
            </li>
            <li xml:id="auto_k0ztt86g">
                <p xml:id="auto_offq8kna">
                    Total outcomes refer to all possible outcomes in the sample space
                </p>
            </li>
        </ul>
    </p>

    <example xml:id="auto_an82urxc">
        <statement>
            <p xml:id="auto_nhty2asc">
                A bag contains 5 red balls and 3 blue balls. If one ball is picked at random, what is the probability that it is red?
            </p>
        </statement>
        <solution>
            <p xml:id="auto_dxtkmqdi">
                Total number of balls <m>\textbf{ = 5 + 3 = 8}</m>
            </p>
            <p xml:id="auto_b01c1ecn">
                Number of red balls <m>\textbf{ = 5}</m>
            </p>
            <p xml:id="auto_7fdo94tk">
                Given a bag with <m>5</m> red balls and <m>3</m> blue balls, the possible outcomes when picking one ball are
            </p>
            <p xml:id="auto_ikf9w5qg">
                <m>\textbf{S = {Red,Blue}}</m>
            </p>
            <p xml:id="auto_aholow0b">
                Total outcomes <m>\textbf{ = 5 + 3 = 8}</m>
            </p>
            <p xml:id="auto_ordyg2ia">
                Probability of drawing a red ball is given by:
            </p>
            <p xml:id="auto_cvti3k0l">
                <m>\textbf{P(Red)}=\frac{\textbf{Number of favorable outcomes}}{\textbf{Number of Outcomes}} = \frac{5}{8}=\textbf{0.625}</m>
            </p>
            <p xml:id="auto_rjc4wown">
                the probability of picking a red ball is <m>0.625</m> or <m>62.5\%</m>
            </p>
        </solution>
    </example>
    <example xml:id="auto_62am104c">
        <statement>
            <p xml:id="auto_rm1r4o75">
                A teacher at Sironga Secondary school randomly selects a student from a class of 30 students. If there are 12 girls and 18 boys in the class, what is the probability that the selected student is a girl?
            </p>
            
        </statement>
        <solution>
            <p xml:id="auto_urw7uegl">
                <ol xml:id="auto_v3s5sqn1" marker="i).">
                    <li xml:id="auto_uvdg1jg0">
                        <p xml:id="auto_1k77btqy">
                            Sample Space is
                             <md>
                                <mrow>\textbf{S = {Girl, Boy}} </mrow>
                             </md>
                        </p>
                    </li>
                    <li xml:id="auto_1b353c1r">
                        <p xml:id="auto_6rwadmfe">
                            The number of favorable outcomes that is choosing a girl = <m>\textbf{12}</m>
                        </p>
                    </li>
                    <li xml:id="auto_g0d4w85b">
                        <p xml:id="auto_dicekt6s">
                            Now, Applying our formula gives
                            <md>
                                <mrow>\textbf{P(Girl)}=\frac{\textbf{Number of girls}}{\textbf{Total number of students}}</mrow>
                            </md>
                            <md>
                                <mrow> = \frac{12}{30}</mrow>
                            </md>
                            <md>
                                <mrow>=\textbf{0.4} </mrow>
                            </md>
                        </p>
                    </li>
                </ol>
            </p>
            <p xml:id="auto_e8qo2xwo">
                The probability of selecting a girl is <m>0.4</m> or <m>40\%</m>
            </p>
        </solution>
        
    </example>

    <axiom component="lesson-plan">
        <title>Assessment</title>
        <p>
            <dl>
            <li>
                <title>Objective</title>
                <p>
                    To formatively assess individual learner understanding.
                </p>
            </li>
            <li>
                <title>Learning Experience</title>
                <p>
                    Learners independently complete a short assessment task (select from the exercises below).
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Collect and review the exit tickets to gauge learner understanding and identify any common misconceptions that need to be addressed in the next lesson.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

    <exercises xml:id="exercises-probability-of-simple-events">
        <exercise xml:id="auto_5gmpemrv">
            <statement>
                <p xml:id="auto_xh7udamp">
                    What is the probability of selecting the letter 'a' from the name "Mukabwa"?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\approx 0.286</m> or <m>28.6\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_v7z73vvy">
            <statement>
                <p xml:id="auto_tsozp7nu">
                    A deck of standard playing cards has 52 cards. What is the probability of drawing the 5 of Hearts?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\approx 0.0192</m> or <m>1.92\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_okv1ic7f">
            <statement>
                <p xml:id="auto_rp6cnml7">
                    A bag has 3 yellow marbles, 5 black marbles, and 2 white marbles. What is the probability of selecting a white marble?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\approx 0.2</m> or <m>20\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_m06v0x3z">
            <statement>
                <p xml:id="auto_2vf82ult">
                    A month is selected at random from a year. What is the probability that it is June?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\approx 0.0833</m> or <m>8.33\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_a1gzccyt">
            <statement>
                <p xml:id="auto_tpb83gqi">
                    A coin is tossed. What is the probability of getting tails?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\approx 0.5</m> or <m>50\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_w0fbovap">
            <statement>
                <p xml:id="auto_lm2izg72">
                    A box contains tickets numbered from 1 to 10. What is the probability of drawing a ticket with the number 7?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\approx 0.1</m> or <m>10\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_4uj3ylp1">
            <statement>
                <p xml:id="auto_0paovtyy">
                    A class has 25 students, and one student is chosen at random. What is the probability that a specific student is chosen?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\approx 0.04</m> or <m>4\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_6ii4zfhf">
            <statement>
                <p xml:id="auto_h4r5cfwq">
                    What is the probability of selecting the letter "e" from the word "elephant"?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\approx 0.222</m> or <m>22.2\%</m>.
                </p>
            </answer>
        </exercise>
    </exercises> 

