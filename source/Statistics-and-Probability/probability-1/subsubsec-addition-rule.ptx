<subsubsection xml:id="subsubsec-addition-rule" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Addition Rule</title>
    <objectives component="outcomes">
        <introduction xml:id="auto_wow0x2xv">
            <dl>
                <li xml:id="auto_h8miofrj">
                    <title>Strand</title>
                    <p xml:id="auto_bvkb2i4d">
                        3.0 Statistics and Probability
                    </p>
                </li>
                <li xml:id="auto_nfcw9wih">
                    <title>Sub-Strand</title>
                    <p xml:id="auto_2egdk61c">
                        3.2 Probability 1
                    </p>
                </li>
                <li xml:id="auto_apconts8">
                    <title>Specific Learning Outcomes</title>
                    <p xml:id="auto_nhfpwh26">
                        Apply the laws of probability in different situations
                    </p>
                </li>
                <li xml:id="auto_awdtlyge" component="lesson-plan">
                    <title>Grade Level</title>
                    <p xml:id="auto_fj7dnw8t">
                        10
                    </p>
                </li>
                <li xml:id="auto_r5w7czm6" component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p xml:id="auto_66j3i1ls">
                        40 minutes
                    </p>
                </li>
            </dl>
            <p xml:id="auto_9jmt6xgj" component="lesson-plan">
                <p xml:id="auto_wz9wvuz0"> Upon completion of this lesson, learners will be able to:
                <ol>
                    <li xml:id="auto_b2ys4zej">
                        <p xml:id="auto_n2ntjj6z">
                            <alert>Know (Conceptual Understanding):</alert> Understand the addition rule for finding the probability of either one event or another occurring.
                        </p>
                    </li>
                    <li xml:id="auto_ucej2umt">
                        <p xml:id="auto_38k32x87">
                            <alert>Do (Procedural Skill):</alert> Apply the addition rule for both mutually exclusive and non-mutually exclusive events.
                        </p>
                    </li>
                    <li xml:id="auto_ft7qa8ro">
                        <p xml:id="auto_du09khp1">
                            <alert>Apply (Application/Problem-Solving):</alert> Solve real-world probability problems using the addition rule and Venn diagrams.
                        </p>
                    </li>
                </ol>
                </p>
            </p>
        </introduction>
    </objectives>
