<subsubsection xml:id="subsubsec-multiplication-rule" xmlns:xi="http://www.w3.org/2001/XInclude">
    
    <title>Multiplication Rule</title>
    <objectives component="outcomes">
        <introduction>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        3.0 Statistics and Probability
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        3.2 Probability 1
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title>
                    <p>
                        Apply the laws of probability in different situations
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        10
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            <p component="lesson-plan">
                <p> Upon completion of this lesson, learners will be able to:
                <ol>
                    <li>
                        <p>
                            <alert>Know (Conceptual Understanding):</alert> Understand that the multiplication rule is used to find the probability of two events both occurring.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Do (Procedural Skill):</alert> Apply the multiplication rule for independent and dependent events.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Apply (Application/Problem-Solving):</alert> Solve real-world problems involving the probability of combined events using the multiplication rule.
                        </p>
                    </li>
                </ol>
                </p>
            </p>
        </introduction>
        <ul>
            <li>Apply the laws of probability in different situations</li>
        </ul>
    </objectives>
    <axiom component="resources">
        <!-- Link to blurb -->
        <xi:include href="../../resources-blurb-lesson.ptx" />

        <sbsgroup widths="45% 45%" margins="2% 2%">
            <sidebyside>
                <p>
                    <dataurl source="lesson_plans/statistics-and-probability/probability-1/multiplication-rule.pdf"> Lesson Plan </dataurl>
                </p>
                <p>
                    <dataurl source="lesson_plans/statistics-and-probability/probability-1/step-by-step-guide_multiplication-rule.pdf"> Step-by-Step Guide </dataurl>
                </p>
            </sidebyside>
        </sbsgroup>
    </axiom>
    <xi:include href="../../resources-materials.ptx" />


    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    Learners work in groups to explore the multiplication rule for probability through a real-world quality control scenario.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Allow groups time to explore the problem independently. Circulate to listen to group discussions without giving direct answers. Ask probing questions: <q>What are you trying to find?</q> <q>Are you looking for one thing OR two things happening?</q> <q>How is this different from the addition rule?</q> Guide students toward the idea that when TWO things must BOTH happen, we multiply.
                </p>
            </li>
        </dl>
    </axiom>

    <activity xml:id="auto_wnf2upui">
        <p xml:id="auto_lowtrfps">
            <m>{\color{black} \textbf{Work in groups}}</m>
        </p>
        <p xml:id="auto_wsp6qh2p">
            A factory produces <m>90\%</m> good items and <m>10\%</m> defective items. A quality check is performed on two randomly selected items
        </p>
        <p xml:id="auto_zp6ijmi6">
            <ol xml:id="auto_eoaghwas" marker="a).">
                <li xml:id="auto_3uqwflkh">
                    <p xml:id="auto_gougr6f5">
                        Find the probability that both items are good.
                    </p>
                </li>
                <li xml:id="auto_2dr7ewse">
                    <p xml:id="auto_x48tqflg">
                        Find the probability that at least one item is defective.
                    </p>
                </li>
                <li xml:id="auto_q4sm40ul">
                    <p xml:id="auto_edtb1nrw">
                        Are these events independent? Explain.
                    </p>
                </li>
            </ol>
        </p>
    </activity>
    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the multiplication rule for both independent and dependent events.
                </p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Scaffolding Strategies</title>
            <ul>
                <li><p>Clarify when to multiply (both/and) vs. when to add (either/or).</p></li>
                <li><p>Emphasize that multiplying probabilities gives a SMALLER result (both happening is harder than just one).</p></li>
                <li><p>Use tree diagrams to visualize the multiplication process.</p></li>
                <li><p>Connect to real-world contexts: probability of two good items, probability of rain two days in a row.</p></li>
            </ul>
        </paragraphs>
    </axiom>

    <p xml:id="auto_13jmlj7s">
        <m>{\color{black} \textbf{Key Takeaway}}</m>
    </p>
    <p xml:id="auto_fcygjq7t">
        The multiplication rule is used to find the probability of two events happening together.
    </p>
    <p xml:id="auto_ppjise2e">
        For <m>\text{Independent events}</m>,the probability of both occurring is
    </p>
    <p xml:id="auto_pun16a1w">
        <md>
            <mrow>\textbf{P(A and B)} = \textbf{P(A)} \times \textbf{P(B)} </mrow>
        </md>
    </p>
    <p xml:id="auto_i5uy9f8d">
        For <m>\text{Dependent events}</m>
    </p>
    <p xml:id="auto_3i9qowz4">
        <md>
            <mrow> \textbf{P}(\textbf{A} \cap \textbf{B} ) \, = \, \textbf{P(A)} \, \times \, \textbf{P(B|A)} </mrow>
        </md>
    </p>
    <p xml:id="auto_rfd9dbtq">
        Here, <m>\textbf{P(B|A)}</m> is the probability that B happens given that A has already occurred.
    </p>
    <example xml:id="auto_vf0ls0ao">
        <statement>
            <p xml:id="auto_om6i6c70">
                A student in Modegashe primary school was instructed to roll a Die and Toss a Coin.
            </p>
            <p xml:id="auto_m8p0yhqe">
                What was the probability of rolling a 4 on the die and getting head on the coin?
            </p>
        </statement>
        <solution>
            <p xml:id="auto_7789jbpq">
                <ol xml:id="auto_9wshfbmv" marker="i.">
                    <li xml:id="auto_jznmv2vk">
                        <p xml:id="auto_clwzi4d7">
                            Probability of rolling a 4 on a six-sided die is
                        </p>
                        <p xml:id="auto_rwxns4xz">
                            <md>
                                <mrow> \frac{1}{6} </mrow>
                            </md>
                        </p>
                    </li>
                    <li xml:id="auto_yg7oe832">
                        <p xml:id="auto_yciw64c2">
                            Probability of getting heads on the coin is
                        </p>
                        <p xml:id="auto_3e7dd5ad">
                            <md>
                                <mrow>= \frac{1}{2} </mrow>
                            </md>
                        </p>
                    </li>
                </ol>
            </p>
            <p xml:id="auto_1yzjsv7p">
                <md>
                    <mrow> \textbf{so, } \, \textbf{P(4 and H)} =  \frac{1}{6} \times  \frac{1}{2}  </mrow>
                </md>
            </p>
            <p xml:id="auto_tcfaon4m">
                <md>
                    <mrow>  = \frac{1}{12} </mrow>
                </md>
            </p>
            <p xml:id="auto_dge41rp3">
                the probability of rolling a 4 and flipping heads is <m>\frac{1}{12}</m> or <m>8.33\%</m>
            </p>
        </solution>
    </example>
    <example xml:id="auto_aqfxvpr1">
        <statement>
            <p xml:id="auto_qhkvp3yu">
                A person has a <m>60\%</m> probability of catching the first bus and an <m>80\%</m> probability of catching the second bus (if they miss the first one)
            </p>
            <p xml:id="auto_f6nl9jqw">
                <ol xml:id="auto_11j7fbrs" marker="a).">
                    <li xml:id="auto_v3wod3x0">
                        <p xml:id="auto_g89abgn0">
                            Find the probability that the person catches the first bus.
                        </p>
                    </li>
                    <li xml:id="auto_vl26y4m2">
                        <p xml:id="auto_2d0sbjd0">
                            Find the probability that the person misses the first bus but catches the second.
                        </p>
                    </li>
                    <li xml:id="auto_c42h3ncm">
                        <p xml:id="auto_ibhhk9o1">
                            Find the probability that the person misses both buses.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p xml:id="auto_rhi4jvhp">
                Probability of catching the first bus:
            </p>
            <p xml:id="auto_1zu3zw8g">
                <md>
                    <mrow> \textbf{P(A) = 0.6} </mrow>
                </md>
            </p>
            <p xml:id="auto_xmg7vh9z">
                Probability of missing the first bus
            </p>
            <p xml:id="auto_pqp70im0">
                <md>
                    <mrow> \textbf{P}(\textbf{A}^{c}) \, = \, 1 - \textbf{P(A)} \, = \, 1 - 0.6 \, = \, 0.4 </mrow>
                </md>
            </p>
            <p xml:id="auto_x69j9ct4">
                Probability of catching the second bus, given that the first bus was missed
            </p>
            <p xml:id="auto_w7257av9">
                <md>
                    <mrow> \textbf{P}(\textbf{B}|\textbf{A}^{c}) \, = \, 0.8 </mrow>
                </md>
            </p>
            <p xml:id="auto_qbm8n6tz">
                Probability of missing the second bus, given that the first bus was missed
            </p>
            <p xml:id="auto_d4s0a9l7">
                <md>
                    <mrow> \textbf{P}(\textbf{B}^{c} | \textbf{A}^{c} ) \, = \, 1 - \textbf{P}(\textbf{B} | \textbf{A}^{c} ) \, = \, 1 - 0.8 \, = \, 0.2 </mrow>
                </md>
            </p>
            <p xml:id="auto_dpzmcwz9">  
                <ol xml:id="auto_twn05qkc" marker="a).">
                    <li xml:id="auto_nkjciahw">
                        <p xml:id="auto_2dck58rh">
                            The probability of catching the first bus is directly given as
                        </p>
                        <p xml:id="auto_yc5xpqkw">
                            <md>
                                <mrow> \textbf{P(A)} \, = \, 0.6 </mrow>
                            </md>
                        </p>
                        <p xml:id="auto_3dux8e7u">
                            The probability of catching the first bus is<m>0.6</m> or <m>60\%</m>.
                        </p>
                    </li>
                    <li xml:id="auto_9xbqy4s4">
                        <p xml:id="auto_i5usfrbi">
                            Missing the first bus <m>\textbf{A}^{c}</m>
                        </p>
                        <p xml:id="auto_cwl3nl8d">
                            Catching the second bus <m>\text{B}</m>
                        </p>
                        <p xml:id="auto_j5glnt1j">
                            Since these events are dependent, we use the multiplication rule
                        </p>
                        <p xml:id="auto_w40yntqk">
                            <md>
                                <mrow> \textbf{P}(\textbf{A}^{c} \cap \textbf{B} ) \, = \, \textbf{P}(\textbf{A}^{c}) \times \textbf{P} (\textbf{B} | \textbf{A}^{c})  </mrow>
                            </md>
                        </p>
                        <p xml:id="auto_szwlbdk3">
                            <md>
                                <mrow> \textbf{P}(\textbf{A}^{c} \cap \textbf{B} ) \, = \, 0.4 \times 0.8 \, = \, 0.32  </mrow>
                            </md>
                        </p>
                        <p xml:id="auto_0rpn27ml">
                            The probability of missing the first bus but catching the second is <m>0.32</m> or <m>32\%</m>.
                        </p>
                    </li>
                    <li xml:id="auto_b3ybowwd">
                        <p xml:id="auto_j6ow4oo2">
                            Missing the first bus <m>\textbf{A}^{c}</m>
                        </p>
                        <p xml:id="auto_5bfcse9y">
                            Missing the second bus <m>\textbf{B}^{c}</m>
                        </p>
                        <p xml:id="auto_qsw8cg0u">
                            Again, using the multiplication rule
                        </p>
                        <p xml:id="auto_4z65m2u3">
                            <md>
                                <mrow>\textbf{P}(\textbf{A}^{c} \cap \textbf{B}^{c} ) \, = \, \textbf{P(A)}^{c} \times \textbf{P}(\textbf{B}^{c}|\textbf{A}^{c})  </mrow>
                            </md>
                        </p>
                        <p xml:id="auto_t4gwtfuv">
                            <md>
                                <mrow> \textbf{P}(\textbf{A}^{c} \cap \textbf{B}^{c} ) \, = \, 0.4 \times 0.2 \, = \, 0.08  </mrow>
                            </md>
                        </p>
                        <p xml:id="auto_sx820nnq">
                            The probability of missing both buses is <m>0.08</m> or <m>8\%</m>.
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
    </example>
       <exercise xml:id="auto_yudq85xx">
        <title>Multiplication Rule</title>

        <introduction xml:id="auto_rx7cpom0">
            <p xml:id="auto_4o903m6h">Load the question by clicking in the button below.</p>
        </introduction>

        <!-- A @label is required, becomes a filename in output -->
        <stack label="multiplication-rule-prob" source="stack/top/3-0-Statistics-Probability/Probability-1/Law-of-Probability/multiplication-rule/A-bag-has-6-red-and-4-blue-balls-.xml"/>
    </exercise>
    <axiom component="lesson-plan">
        <title>Practice and Application</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To apply the multiplication rule to calculate the probability of combined events.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Work through examples with learners step by step. Circulate during independent practice and provide assistance where needed.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

    <exercises xml:id="exercises-multiplication-rule-of-probability">
        <exercise xml:id="auto_haa3x7ez">
            <statement>
                <p xml:id="auto_rep44rv0">
                    A coin is tossed twice. What is the probability of getting heads on both tosses?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\frac{1}{4}</m> or <m>25\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_3wnwod2f">
            <statement>
                <p xml:id="auto_2vswed5a">
                    A die is rolled, and a coin is tossed. What is the probability of rolling a 6 and getting tails?
                </p>
            </statement>
            <answer>
                <p>
                    <m>\frac{1}{12}</m> or <m>8.33\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_6ixi3f4x">
            <statement>
                <p xml:id="auto_d6lrsu7g">
                    A weather forecast predicts a <m>60\%</m> chance of sunshine on Monday and a <m>70\%</m> chance of sunshine on Tuesday. Assuming these forecasts are independent, what is the probability of sunshine on both Monday and Tuesday?
                </p>
            </statement>
            <answer>
                <p>
                    <m>0.42</m> or <m>42\%</m>.
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_053ol9eh">
            <statement>
                <p xml:id="auto_yyvfb3xx">
                    A farmer in Gakuonyo plants two seeds. Each seed has a <m>75\%</m> chance of germinating.
                     What is the probability that both seeds germinate?
                </p>
            </statement>
            <answer>
                <p>
                    <m>0.5625</m> or <m>56.25\%</m>.
                </p>
            </answer>
        </exercise>
    </exercises>
    <axiom component="lesson-plan">
        <title>Assessment</title>
        <p>
            <dl>
            <li>
                <title>Objective</title>
                <p>
                    To formatively assess individual learner understanding.
                </p>
            </li>
            <li>
                <title>Learning Experience</title>
                <p>
                    Learners independently complete a short assessment task (select from the exercises below).
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Collect and review the exit tickets to gauge learner understanding and identify any common misconceptions that need to be addressed in the next lesson.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

    <xi:include href="../../resources-checkpoint.ptx" />

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Use tree diagrams to visualize multiplication. Start with simple independent events before dependent events. Provide formula cards: P(A and B) = P(A) × P(B) for independent events. Use concrete examples with small numbers. Allow use of calculators for decimal multiplication. Use color-coded problems (green for independent, orange for dependent). Create comparison charts: Addition Rule vs. Multiplication Rule.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> Explore scenarios with three or more events (e.g., three machines in a factory). Investigate dependent events: P(A and B) = P(A) × P(B|A). Combine multiplication rule with complement rule. Explore Bayes' theorem introduction. Design their own real-world probability scenarios.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>
    <xi:include href="../../resources-assessment.ptx" />
