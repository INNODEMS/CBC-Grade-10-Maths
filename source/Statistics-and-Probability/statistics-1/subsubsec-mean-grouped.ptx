    </axiom>

    <exercises xml:id="exercises-mean-grouped">
        <exercise xml:id="auto_47t9l9pp">
            <statement>
                <p xml:id="auto_a64fb8ln">
                    A tea factory recorded the weight of tea leaves (in kg) delivered by <m>40</m> small-scale farmers in a single morning.
                </p>
                <table xml:id="auto_qtoatcnh">
                    <title>Tea Weight Deliveries</title>
                    <tabular halign="center" top="medium" bottom="medium" left="medium" right="medium">
                        <row header="yes">
                            <cell>Weight (kg)</cell>
                            <cell>Frequency (Farmers)</cell>
                        </row>
                        <row>
                            <cell><m>10 - 19</m></cell>
                            <cell><m>5</m></cell>
                        </row>
                        <row>
                            <cell><m>20 - 29</m></cell>
                            <cell><m>8</m></cell>
                        </row>
                        <row>
                            <cell><m>30 - 39</m></cell>
                            <cell><m>15</m></cell>
                        </row>
                        <row>
                            <cell><m>40 - 49</m></cell>
                            <cell><m>10</m></cell>
                        </row>
                        <row>
                            <cell><m>50 - 59</m></cell>
                            <cell><m>2</m></cell>
                        </row>
                    </tabular>
                </table>
                <p xml:id="auto_5a33lxog">
                    Calculate the mean weight of tea leaves delivered per farmer.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_x2nydf6i">
                    Midpoints (<m>x</m>): <m>14.5, 24.5, 34.5, 44.5, 54.5</m>
                </p>
                <p xml:id="auto_mjteemzs">
                    <m>\sum f = 40</m>
                </p>
                <p xml:id="auto_tpxa64wc">
                    <m>\sum fx = (14.5 \times 5) + (24.5 \times 8) + (34.5 \times 15) + (44.5 \times 10) + (54.5 \times 2) = 1330</m>
                </p>
                <p xml:id="auto_zhycnjjg">
                    Mean <m>= \frac{1330}{40} = 33.25</m> kg.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_ufg7962m">
            <statement>
                <p xml:id="auto_8aimx7da">
                    A Sacco operating on the Nairobi-Thika route recorded the fares paid by passengers during peak hours on a rainy day.
                </p>
                <table xml:id="auto_e1onma3o">
                    <title>Fare Distribution</title>
                    <tabular halign="center" top="medium" bottom="medium" left="medium" right="medium">
                        <row header="yes">
                            <cell>Fare (KES)</cell>
                            <cell>No. of Passengers</cell>
                        </row>
                        <row>
                            <cell><m>50 - 99</m></cell>
                            <cell><m>20</m></cell>
                        </row>
                        <row>
                            <cell><m>100 - 149</m></cell>
                            <cell><m>45</m></cell>
                        </row>
                        <row>
                            <cell><m>150 - 199</m></cell>
                            <cell><m>30</m></cell>
                        </row>
                        <row>
                            <cell><m>200 - 249</m></cell>
                            <cell><m>5</m></cell>
                        </row>
                    </tabular>
                </table>
                <p xml:id="auto_e4wu1byh">
                    Determine the mean fare paid by the passengers.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_eftkf3i3">
                    Midpoints (<m>x</m>): <m>74.5, 124.5, 174.5, 224.5</m>
                </p>
                <p xml:id="auto_3tvs2ime">
                    <m>\sum f = 100</m>
                </p>
                <p xml:id="auto_vvtkk4a3">
                    <m>\sum fx = (74.5 \times 20) + (124.5 \times 45) + (174.5 \times 30) + (224.5 \times 5) = 13,450</m>
                </p>
                <p xml:id="auto_78nsomtd">
                    Mean <m>= \frac{13,450}{100} = 134.50</m> KES.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_8q6px4u6">
            <statement>
                <p xml:id="auto_gjl30o9q">
                    The mathematics department at a High School in Nakuru analyzed the percentage scores of <m>50</m> students in a mock exam.
                </p>
                <table xml:id="auto_sqk28sx8">
                    <title>Maths Scores</title>
                    <tabular halign="center" top="medium" bottom="medium" left="medium" right="medium">
                        <row header="yes">
                            <cell>Marks (%)</cell>
                            <cell>Frequency</cell>
                        </row>
                        <row>
                            <cell><m>0 - 20</m></cell>
                            <cell><m>4</m></cell>
                        </row>
                        <row>
                            <cell><m>20 - 40</m></cell>
                            <cell><m>12</m></cell>
                        </row>
                        <row>
                            <cell><m>40 - 60</m></cell>
                            <cell><m>18</m></cell>
                        </row>
                        <row>
                            <cell><m>60 - 80</m></cell>
                            <cell><m>10</m></cell>
                        </row>
                        <row>
                            <cell><m>80 - 100</m></cell>
                            <cell><m>6</m></cell>
                        </row>
                    </tabular>
                </table>
                <p xml:id="auto_621zxpkk">
                    Calculate the mean score for the class.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_xl8265lb">
                    Midpoints (<m>x</m>): <m>10, 30, 50, 70, 90</m>
                </p>
                <p xml:id="auto_a5stexx4">
                    <m>\sum f = 50</m>
                </p>
                <p xml:id="auto_6a9eyixt">
                    <m>\sum fx = (10 \times 4) + (30 \times 12) + (50 \times 18) + (70 \times 10) + (90 \times 6) = 2,540</m>
                </p>
                <p xml:id="auto_62ujllbe">
                    Mean <m>= \frac{2,540}{50} = 50.8\%</m>.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_bvzu6ix9">
            <statement>
                <p xml:id="auto_p4ms7wof">
                    An M-Pesa agent in Kisumu recorded the value of transactions performed in the first hour of business.
                </p>
                <table xml:id="auto_4bnv5cja">
                    <title>Transaction Values</title>
                    <tabular halign="center" top="medium" bottom="medium" left="medium" right="medium">
                        <row header="yes">
                            <cell>Value (KES)</cell>
                            <cell>No. of Transactions</cell>
                        </row>
                        <row>
                            <cell><m>0 - 1000</m></cell>
                            <cell><m>12</m></cell>
                        </row>
                        <row>
                            <cell><m>1000 - 2000</m></cell>
                            <cell><m>8</m></cell>
                        </row>
                        <row>
                            <cell><m>2000 - 3000</m></cell>
                            <cell><m>6</m></cell>
                        </row>
                        <row>
                            <cell><m>3000 - 4000</m></cell>
                            <cell><m>4</m></cell>
                        </row>
                    </tabular>
                </table>
                <p xml:id="auto_dpoqg79c">
                    Estimate the mean transaction value.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_jr3u9ez3">
                    Midpoints (<m>x</m>): <m>500, 1500, 2500, 3500</m>
                </p>
                <p xml:id="auto_zfnykvqc">
                    <m>\sum f = 30</m>
                </p>
                <p xml:id="auto_2rrzh3vo">
                    <m>\sum fx = (500 \times 12) + (1500 \times 8) + (2500 \times 6) + (3500 \times 4) = 47,000</m>
                </p>
                <p xml:id="auto_k9srjjw7">
                    Mean <m>= \frac{47,000}{30} \approx 1,566.67</m> KES.
                </p>
            </answer>
        </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table xml:id="auto_n4to7v0i">
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Provide pre-filled calculation tables with midpoint column already completed. Use smaller datasets (3–5 intervals) to build confidence. Provide step-by-step worksheets with guided practice. Allow use of calculators for all calculations. Work in pairs with peer support. Provide formula cards as reference. Use simpler numbers (avoid large values like salaries).</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> Explore datasets with more intervals (10–15 classes). Compare mean from grouped data vs ungrouped data to see estimation error. Investigate how changing class width affects the mean estimate. Calculate mean, median, and mode for the same grouped dataset. Research real-world applications: census data, economic indicators, quality control.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>
