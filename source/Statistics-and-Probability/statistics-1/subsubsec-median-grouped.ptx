    <exercises xml:id="exercises-median-grouped">
        <exercise xml:id="auto_ymkoaglc">
            <statement>
                <p xml:id="auto_izqzn60s">
                    A group of <m>40</m> athletes recorded their finishing times (in minutes) during a practice run at Karura Forest.
                </p>
                <table xml:id="auto_rpaq450a">
                    <title>Finishing Times</title>
                    <tabular halign="center" top="medium" bottom="medium" left="medium" right="medium">
                        <row header="yes">
                            <cell>Time (min)</cell>
                            <cell>Frequency</cell>
                        </row>
                        <row>
                            <cell><m>120 - 129</m></cell>
                            <cell><m>4</m></cell>
                        </row>
                        <row>
                            <cell><m>130 - 139</m></cell>
                            <cell><m>12</m></cell>
                        </row>
                        <row>
                            <cell><m>140 - 149</m></cell>
                            <cell><m>15</m></cell>
                        </row>
                        <row>
                            <cell><m>150 - 159</m></cell>
                            <cell><m>9</m></cell>
                        </row>
                    </tabular>
                </table>
                <p xml:id="auto_s3aj5kdq">
                    Calculate the median finishing time.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_9xbbmsgk">
                    Total frequency (<m>n</m>) <m>= 40</m>. Median position <m>= \frac{40}{2} = 20</m>.
                </p>
                <p xml:id="auto_zi3538t3">
                    CF values: <m>4, 16, 31, 40</m>.
                </p>
                <p xml:id="auto_lj92xxgf">
                    The <m>20</m>th value lies in the <m>140 - 149</m> class.
                </p>
                <p xml:id="auto_x8f299gv">
                    <m>L = 140</m>, <m>\frac{n}{2} = 20</m>, <m>CF = 16</m>, <m>F = 15</m>, <m>C = 10</m>.
                </p>
                <p xml:id="auto_s9kw89qv">
                    Median <m>= 140 + (\frac{20 - 16}{15}) \times 10 = 140 + 2.67 = 142.67</m> minutes.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_anwu6bn0">
            <statement>
                <p xml:id="auto_bw5hjfx3">
                    A county hospital in Machakos surveyed the waiting time (in minutes) for <m>60</m> patients at the outpatient department.
                </p>
                <table xml:id="auto_bs5r5x6e">
                    <title>Patient Waiting Times</title>
                    <tabular halign="center" top="medium" bottom="medium" left="medium" right="medium">
                        <row header="yes">
                            <cell>Time (min)</cell>
                            <cell>No. of Patients</cell>
                        </row>
                        <row>
                            <cell><m>0 - 19</m></cell>
                            <cell><m>10</m></cell>
                        </row>
                        <row>
                            <cell><m>20 - 39</m></cell>
                            <cell><m>25</m></cell>
                        </row>
                        <row>
                            <cell><m>40 - 59</m></cell>
                            <cell><m>15</m></cell>
                        </row>
                        <row>
                            <cell><m>60 - 79</m></cell>
                            <cell><m>10</m></cell>
                        </row>
                    </tabular>
                </table>
                <p xml:id="auto_wuq2r3z0">
                    Estimate the median waiting time for a patient.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_vk59q95z">
                    Total frequency (<m>n</m>) <m>= 60</m>. Median position <m>= 30</m>.
                </p>
                <p xml:id="auto_c2htpy8m">
                    CF values: <m>10, 35, 50, 60</m>.
                </p>
                <p xml:id="auto_9kxzni42">
                    The <m>30</m>th value lies in the <m>20 - 39</m> class.
                </p>
                <p xml:id="auto_51fvzfv8">
                    <m>L = 20</m>, <m>CF = 10</m>, <m>F = 25</m>, <m>C = 20</m>.
                </p>
                <p xml:id="auto_b50ls1ky">
                    Median <m>= 20 + (\frac{30 - 10}{25}) \times 20 = 20 + 16 = 36</m> minutes.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_bancbmjx">
            <statement>
                <p xml:id="auto_f3x3pswc">
                    An agricultural officer in Uasin Gishu measured the height (in cm) of <m>50</m> maize stalks in a test farm.
                </p>
                <table xml:id="auto_449mufyu">
                    <title>Maize Stalk Heights</title>
                    <tabular halign="center" top="medium" bottom="medium" left="medium" right="medium">
                        <row header="yes">
                            <cell>Height (cm)</cell>
                            <cell>Frequency</cell>
                        </row>
                        <row>
                            <cell><m>100 - 119</m></cell>
                            <cell><m>8</m></cell>
                        </row>
                        <row>
                            <cell><m>120 - 139</m></cell>
                            <cell><m>18</m></cell>
                        </row>
                        <row>
                            <cell><m>140 - 159</m></cell>
                            <cell><m>14</m></cell>
                        </row>
                        <row>
                            <cell><m>160 - 179</m></cell>
                            <cell><m>10</m></cell>
                        </row>
                    </tabular>
                </table>
                <p xml:id="auto_2h6l0sa4">
                    Determine the median height of the maize stalks.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_1ite3qu8">
                    Total frequency (<m>n</m>) <m>= 50</m>. Median position <m>= 25</m>.
                </p>
                <p xml:id="auto_rk3e8d74">
                    CF values: <m>8, 26, 40, 50</m>.
                </p>
                <p xml:id="auto_2yw5fhzb">
                    The <m>25</m>th value lies in the <m>120 - 139</m> class.
                </p>
                <p xml:id="auto_dx9e7rlb">
                    <m>L = 120</m>, <m>CF = 8</m>, <m>F = 18</m>, <m>C = 20</m>.
                </p>
                <p xml:id="auto_yg70emw6">
                    Median <m>= 120 + (\frac{25 - 8}{18}) \times 20 = 120 + 18.89 = 138.89</m> cm.
                </p>
            </answer>
        </exercise>

        <exercise xml:id="auto_5inhxft5">
            <statement>
                <p xml:id="auto_mff9hdag">
                    A survey was conducted on the monthly rent (in thousands of KES) for one-bedroom houses in a Nairobi estate.
                </p>
                <table xml:id="auto_6tlr13tm">
                    <title>Monthly Rent</title>
                    <tabular halign="center" top="medium" bottom="medium" left="medium" right="medium">
                        <row header="yes">
                            <cell>Rent (Ksh '000)</cell>
                            <cell>No. of Houses</cell>
                        </row>
                        <row>
                            <cell><m>5 - 9</m></cell>
                            <cell><m>20</m></cell>
                        </row>
                        <row>
                            <cell><m>10 - 14</m></cell>
                            <cell><m>40</m></cell>
                        </row>
                        <row>
                            <cell><m>15 - 19</m></cell>
                            <cell><m>30</m></cell>
                        </row>
                        <row>
                            <cell><m>20 - 24</m></cell>
                            <cell><m>10</m></cell>
                        </row>
                    </tabular>
                </table>
                <p xml:id="auto_bta03zrc">
                    Calculate the median rent.
                </p>
            </statement>
            <answer>
                <p xml:id="auto_a73jb9hq">
                    Total frequency (<m>n</m>) <m>= 100</m>. Median position <m>= 50</m>.
                </p>
                <p xml:id="auto_d0z025xw">
                    CF values: <m>20, 60, 90, 100</m>.
                </p>
                <p xml:id="auto_sr71y6r3">
                    The <m>50</m>th value lies in the <m>10 - 14</m> class.
                </p>
                <p xml:id="auto_pi27om6m">
                    <m>L = 10</m>, <m>CF = 20</m>, <m>F = 40</m>, <m>C = 5</m>.
                </p>
                <p xml:id="auto_vdc3m08s">
                    Median <m>= 10 + (\frac{50 - 20}{40}) \times 5 = 10 + 3.75 = 13.75</m> (Ksh <m>13,750</m>).
                </p>
            </answer>
        </exercise>
    </exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table xml:id="auto_bjm9ch0s">
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Provide pre-filled CF columns to focus on formula application. Use smaller datasets (4–5 intervals) to build confidence. Provide step-by-step worksheets with spaces for each value (L, CF, F, C). Use visual number lines to show where median class is located. Work in pairs with peer support. Provide formula cards with clear labels for each variable. Practise identifying n/2 and median class before applying the formula.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> Explore datasets with more intervals (10–12 classes). Compare median from grouped data vs ungrouped data to see estimation error. Investigate how changing class width affects the median estimate. Calculate mean, median, and mode for the same grouped dataset and compare. Research real-world applications: census data, health statistics, economic indicators.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>
