<subsubsection xml:id="subsubsec-sources-of-data" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Sources of Data</title>
    <objectives component="outcomes">
        <introduction>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        3.0 Statistics and Probability
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        3.1 Statistics 1
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title>
                    <p>
                        Determine mean, mode and median of grouped and ungrouped data
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        10
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p>
                        40 minutes
                    </p>
                </li>
            </dl>
            <p component="lesson-plan">
                <p> Upon completion of this lesson, learners will be able to:
                <ol>
                    <li>
                        <p>
                            <alert>Know (Conceptual Understanding):</alert> Understand the difference between primary, secondary, and tertiary data sources.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Do (Procedural Skill):</alert> Identify and classify data sources as primary, secondary, or tertiary.
                        </p>
                    </li>
                    <li>
                        <p>
                            <alert>Apply (Application/Problem-Solving):</alert> Select appropriate data sources for real-life research scenarios.
                        </p>
                    </li>
                </ol>
                </p>
            </p>
        </introduction>
    </objectives>
    <axiom component="resources">
        <!-- Link to blurb -->
        <xi:include href="../../resources-blurb-lesson.ptx" />

        <sbsgroup widths="45% 45%" margins="2% 2%">
            <sidebyside>
                <p>
                    <dataurl source="lesson_plans/statistics-and-probability/statistics-1/sources-of-data.pdf"> Lesson Plan </dataurl>
                </p>
                <p>
                    <dataurl source="lesson_plans/statistics-and-probability/statistics-1/step-by-step-guide_sources-of-data.pdf"> Step-by-Step Guide </dataurl>
                </p>
            </sidebyside>
        </sbsgroup>
    </axiom>
    <xi:include href="../../resources-materials.ptx" />


    <introduction>
        <!-- <p>
            Think of <alert>data</alert> as the <q>raw ingredients</q> for your statistical analysis. if the ingredients are bad, the final result won't be great either. That’s why we distinguish between <alert>Primary Data</alert> (going to the farm yourself to get exactly what you need) and <alert>Secondary Data</alert> (buying what’s already on the shelf). One gives you total control and the other gives you speed and convenience. Learning to navigate these two sources ensures your research is built on a solid, trustworthy foundation. 
        </p> -->

    </introduction>

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    Students work in groups to identify appropriate data collection methods and distinguish between primary and secondary data sources in a real-world research context.
                </p>
            </li>
        </dl>
        <paragraphs>
            <title>Discussion Prompts</title>
            <ul>
                <li><p>What primary data collection method did your group suggest? Why?</p></li>
                <li><p>What secondary data sources would be helpful for this research?</p></li>
                <li><p>How would you explain the difference between primary and secondary data?</p></li>
                <li><p>What are the advantages of using secondary data?</p></li>
                <li><p>When would it be better to collect primary data instead of using secondary data?</p></li>
            </ul>
        </paragraphs>
    </axiom>

    <activity xml:id="auto_e88lf9vm">
        <introduction>
            <p xml:id="auto_6pa54apf">
                <alert>Work in groups</alert>
            </p>
            <p xml:id="auto_mjiajbad">
                A teacher assigned students a research topic on the effects of social media on teenage mental health in Kenya.
            </p>
        </introduction>
        <task>
            <statement>
                <p>
                    Suggest one potential primary data collection method that could be used.
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Suggest one potential secondary data source that could be used.
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    What is the difference between primary and secondary data?
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Why is secondary data important for research and decision-making?
                </p>
            </statement>
        </task>
        <task>
            <statement>
                <p>
                    Discuss and share with other groups.
                </p>
            </statement>
        </task>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    10 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To formalize the definitions of data, primary data, secondary data, tertiary data, and methods of data collection.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

    <insight xml:id="auto_ktorbmjt">
        <p>
            <alert>Data</alert> is a collection of facts, figures, numbers, observations, measurements, or descriptions that can be recorded, stored, and used to study or understand something.
        </p>
        <p>
            There are two primary categories of data sources: <alert>primary data</alert> and <alert>secondary data</alert>.
        </p>
        <p>
            <ul>
                <li>
                    <p>
                        <alert>Primary data</alert> is collected firsthand by the researcher or investigator specifically for the current study.
                    </p>
                </li>
                <li>
                    <p>
                        <alert>Secondary data</alert> is information that has already been collected by someone else for a different purpose and is now used by the researcher.
                    </p>
                </li>
            </ul>
        </p>
    </insight>

    <example xml:id="auto_pn6twze1">
        <statement>
            <p xml:id="auto_vb7jdkl0">
                Classify the following as primary or secondary data sources:
            </p>
            <p xml:id="auto_x1wk20i0">
                <ol xml:id="auto_tds1cky5">
                    <li xml:id="auto_ed173awp">A student conducts a survey to find out the favorite sports of their classmates.</li>
                    <li xml:id="auto_wlai9ndn">A teacher uses last year’s national exam results to analyze student performance trends.</li>
                    <li xml:id="auto_old83dlm">A researcher reads a government report on the most common diseases in Kenya.</li>
                    <li xml:id="auto_hwv2sps8"> A doctor observes a patient’s symptoms and records them for a medical study.</li>
                    <li xml:id="auto_vu7b52ec">A scientist conducts an experiment to test the growth rate of plants under different conditions.</li>
                    
                </ol>
            </p>
        </statement>
        <solution>
            <p xml:id="auto_6t5qqcth">
                <ol xml:id="auto_md2bqczy">
                    <li xml:id="auto_pyibco36">Primary because the student is collecting first-hand data directly from people.</li>
                    <li xml:id="auto_o974gzvm">Secondary because the exam results were already collected and recorded by an external body.</li>
                    <li xml:id="auto_cyiun0to">Secondary because The report was collected and published by someone else for a different purpose.</li>
                    <li xml:id="auto_7qw37yq1">Primary because The doctor is directly collecting new data from real-life observation.</li>
                    <li xml:id="auto_qi4lomqh">Primary because The scientist is generating new data through an experiment.</li>
                    
                </ol>
            </p>
        </solution>
    </example>
    <example xml:id="auto_dt72d269">
        <statement>
            <p xml:id="auto_82g60su1">
                A community group wants to understand the needs of youth in their area.
            </p>
            <p xml:id="auto_edvc02tv">
                <ol xml:id="auto_suhj77z6" marker="(a)">
                <li xml:id="auto_qbozbc05">
                    <p xml:id="auto_er0yt4ki">
                        What primary data collection methods could the group use?
                    </p>
                </li>
                <li xml:id="auto_29c5vm83">
                    <p xml:id="auto_2lfe3hxp">
                        What problems might they have when trying to find this information? 
                    </p>
                </li>
                <li xml:id="auto_yyd9717z">
                    <p xml:id="auto_zcgpwwfx">
                        How can they use the information they find to help the community?
                    </p>
                </li>
                <li xml:id="auto_zpgdl7by">
                    <p xml:id="auto_z35h5rmx">
                        What secondary data sources could be useful to this community group?
                    </p>
                </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p xml:id="auto_rt0s1ia5">
                <ol xml:id="auto_inokzlk0" marker="(a)">
                    <li xml:id="auto_5dr0my5x">
                        <p xml:id="auto_ztq587ui">
                            Focus groups, surveys, interviews.
                        </p>
                    </li>
                    <li xml:id="auto_hg4cw22u">
                        <p xml:id="auto_z34fxo8m">
                            <ul xml:id="auto_k8nw0w5x">
                                <li xml:id="auto_wuko4y5n">
                                    <p xml:id="auto_pyar4bxj">
                                        Overcoming language barriers.
                                    </p>
                                </li>
                                <li xml:id="auto_aw5a53v1">
                                    <p xml:id="auto_okjmpw3j">
                                        Getting honest responses.
                                    </p>
                                </li>
                            </ul>
                        </p>

                    </li>
                    <li xml:id="auto_91j27ikc">
                        <p xml:id="auto_j5imc3tj">
                            <ul xml:id="auto_ne0shbab">
                                <li xml:id="auto_sp7qml7j">
                                    <p xml:id="auto_1ln14lms">
                                        They can start new programs for young people.
                                    </p>
                                </li>
                                <li xml:id="auto_q5j52zo4">
                                    <p xml:id="auto_rzzvdxae">
                                        They can tell leaders what young people need.
                                    </p>
                                </li>
                            </ul>
                        </p>
                    </li>
                    <li xml:id="auto_1mnjj7cy">
                        <p xml:id="auto_n5qb6708">
                            <ul xml:id="auto_an5dul3s">
                                <li xml:id="auto_486qt700">
                                    <p xml:id="auto_cxks0qsq">
                                        Academic studies on youth issues.
                                    </p>
                                </li>
                                <li xml:id="auto_1tffgxlf">
                                    <p xml:id="auto_7h25h7zk">
                                        Government reports on youth.
                                    </p>
                                </li>
                            </ul>
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
    </example>

    <axiom component="lesson-plan">
        <title>Practice and Application</title>
        <p>
            <dl>
            <li>
                <title>Suggested Time</title>
                <p>
                    15 minutes
                </p>
            </li>
            <li>
                <title>Objective</title>
                <p>
                    To apply understanding of data sources by classifying examples as primary or secondary.
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Work through examples with learners step by step. Circulate during independent practice and provide assistance where needed.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

    <exercises xml:id="exercises-sources-of-data">
        <exercise xml:id="auto_uaszjje7">
            <statement>
                <p xml:id="auto_0bxs7ife">
                    Grade <m>10</m> students from Korinyang Primary School went to Lake Nakuru National Park and counted the flamingos they saw for their Biology project.
                </p>
                <p xml:id="auto_oivnwx89">
                    <ol xml:id="auto_rkbwcdlc" marker="(a)">
                        <li xml:id="auto_fi0jxe0b">
                            <p xml:id="auto_dxtx8vhc">
                                Is this a primary or secondary data source?
                            </p>
                        </li>
                        <li xml:id="auto_lxw816bl">
                            <p xml:id="auto_0py9ua1p">
                                Give reason.
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_lkyzdu9n">
                    <ol>
                        <li xml:id="auto_qhha9aqv">
                            <p xml:id="auto_r1mmn4qe">
                                Primary data source.
                            </p>
                        </li>
                        <li xml:id="auto_67q4x313">
                            <p xml:id="auto_es0za3ts">
                                The students collected the data themselves through direct observation and counting.
                            </p>
                        </li>
                    </ol>
                </p>
            </answer>
        </exercise>
        <exercise xml:id="auto_xzz2xgbf">
            <statement>
                <p xml:id="auto_ds7aty5a">
                    In a market, a shop owner watches what customers buy most often and looks for trends based on what they see in the store.
                    <ol marker="(a)">
                        <li xml:id="auto_av2z94wb">
                            <p xml:id="auto_b752imgk">
                                Which sources of data can the shop owner use to collect the data?
                            </p>
                        </li>
                    </ol>
                </p>
            </statement>
            <answer>
                <p xml:id="auto_6zcbz8s0">
                    Direct observation, sales transaction records, and customer surveys/interviews.
                </p>
            </answer>
        </exercise>
        <!-- <exercise xml:id="auto_e25rxiow">
            <statement>
                <p xml:id="auto_6a68iwji">
                    Define the following terms.
                </p>
                <p xml:id="auto_3h138ngx">
                    <ol xml:id="auto_wdqwskw6" marker="(a)">
                        <li xml:id="auto_9wd10wra">Data Source</li>
                        <li xml:id="auto_l3xhwbuo">Raw Data</li>
                        <li xml:id="auto_9ml1lu4i">Tertiary Sources</li>
                        <li xml:id="auto_euk2xm34">Primary sources</li>

                    </ol>
                </p>
            </statement>
        </exercise> -->
        <exercise xml:id="auto_6zz1l7zb">
            <statement>
                <p xml:id="auto_w3lynjnq">
                    What are the advantages of using secondary data over primary data in some research situations?
                </p>
            </statement>
            <answer>
                <p xml:id="auto_hjvprdko">
                    It is faster to obtain, cheaper than conducting new research, and provides access to larger historical datasets.
                </p>
            </answer>
        </exercise>
    
    </exercises>

    <axiom component="lesson-plan">
        <title>Assessment</title>
        <p>
            <dl>
            <li>
                <title>Objective</title>
                <p>
                    To formatively assess individual learner understanding.
                </p>
            </li>
            <li>
                <title>Learning Experience</title>
                <p>
                    Learners independently complete a short assessment task (select from the exercises below).
                </p>
            </li>
            <li>
                <title>Teacher's Role</title>
                <p>
                    Collect and review the exit tickets to gauge learner understanding and identify any common misconceptions that need to be addressed in the next lesson.
                </p>
            </li>
            </dl>
        </p>
    </axiom>

