        <stack label="stk-definitions-of-sources-of-data" source="stack/top/3-0-Statistics-Probability/Statistics-1/3-1-1-Collection-of-Data/3-1-1-1-Sources-of-Data/Definitions-of-sources-of-data.xml"/>
