    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table>
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Provide histograms with clearly marked frequencies on each bar. Use smaller datasets with fewer intervals. Give step-by-step guides for reading axes and counting bars. Use highlighters to mark tallest/shortest bars. Work in pairs with peer support.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> Analyse histograms with unequal class widths (frequency density). Compare two distributions using overlapping frequency polygons. Calculate mean, median, and mode from grouped data in histograms. Identify and explain skewness in distributions. Create their own histograms from raw data. Critique misleading graphs and suggest improvements.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>
