<subsection xml:id="subsec-statistics-in-real-life" xmlns:xi="http://www.w3.org/2001/XInclude">
    <title>Statistics in Real Life</title>
    <objectives component="outcomes">
        <introduction xml:id="auto_s9uuewtd">
            <dl>
                <li xml:id="auto_jvgyzz56">
                    <title>Strand</title>
                    <p xml:id="auto_regpck2b">
                        3.0 Statistics and Probability
                    </p>
                </li>
                <li xml:id="auto_4dzdjujr">
                    <title>Sub-Strand</title>
                    <p xml:id="auto_31ix32b8">
                        3.1 Statistics 1
                    </p>
                </li>
                <li xml:id="auto_tfqzzydf">
                    <title>Specific Learning Outcomes</title>
                    <p xml:id="auto_03xhoq8y">
                        <ul>
                            <li xml:id="auto_bxak1r2c">
                                <p xml:id="auto_rp2pfm1t">
                                    Collect data from real-life sources
                                </p>
                            </li>
                            <li xml:id="auto_4qfcn6mq">
                                <p xml:id="auto_latrcfkt">
                                    Promote data collection, organisation and representation for informed decision making
                                </p>
                            </li>
                        </ul>
                    </p>
                </li>
                <li xml:id="auto_covkvjfh" component="lesson-plan">
                    <title>Grade Level</title>
                    <p xml:id="auto_p80v1y9a">
                        10
                    </p>
                </li>
                <li xml:id="auto_2f8gaxi1" component="lesson-plan">
                    <title>Estimated Duration</title>
                    <p xml:id="auto_7ji94lov">
                        40 minutes
                    </p>
                </li>
            </dl>
            <p xml:id="auto_qb9lds6o" component="lesson-plan">
                <p xml:id="auto_fgvfxwko"> Upon completion of this lesson, learners will be able to:
                <ol>
                    <li xml:id="auto_x19h5axj">
                        <p xml:id="auto_5u0ep4z3">
                            <alert>Know (Conceptual Understanding):</alert> Understand the concept of informed decision-making and the six-step process for using data to make decisions.
                        </p>
                    </li>
                    <li xml:id="auto_r2ytixte">
                        <p xml:id="auto_aysvv4el">
                            <alert>Do (Procedural Skill):</alert> Collect, organise, represent, and interpret data using frequency tables, histograms, and frequency polygons.
                        </p>
                    </li>
                    <li xml:id="auto_qfwo59xl">
                        <p xml:id="auto_7j27h5v9">
                            <alert>Apply (Application/Problem-Solving):</alert> Apply statistical methods to real-life problems and make evidence-based recommendations.
                        </p>
                    </li>
                </ol>
                </p>
            </p>
        </introduction>
    </objectives>
    <axiom component="resources">
        <!-- Link to blurb -->
        <xi:include href="../../resources-blurb-lesson.ptx" />

        <sbsgroup widths="45% 45%" margins="2% 2%">
            <sidebyside>
                <p xml:id="auto_1i70awww">
                    <dataurl source="lesson_plans/statistics-and-probability/statistics-1/statistics-in-real-life.pdf"> Lesson Plan </dataurl>
                </p>
                <p xml:id="auto_m3e47t87">
                    <dataurl source="lesson_plans/statistics-and-probability/statistics-1/step-by-step-guide_statistics-in-real-life.pdf"> Step-by-Step Guide </dataurl>
                </p>
            </sidebyside>
        </sbsgroup>
    </axiom>

    <xi:include href="../../resources-materials.ptx" />

    <axiom component="lesson-plan">
        <title>Problem-Solving and Discovery</title>
        <dl>
            <li xml:id="auto_2dfmknvf">
                <title>Suggested Time</title>
                <p xml:id="auto_pzvviy4g">15 minutes</p>
            </li>
            <li xml:id="auto_plbi0xqo">
                <title>Objective</title>
                <p xml:id="auto_xmd7vomz">Students work in groups to collect data on school lunch preferences, organise it in a frequency table, represent it visually, and interpret the results to make a recommendation.</p>
            </li>
            <li xml:id="auto_spk75497">
                <title>Teacher's Role</title>
                <p xml:id="auto_yykpypae">Circulate among groups, asking guiding questions. Observe how students organise and represent data. Note common approaches and misconceptions. Select 2–3 groups to share their findings.</p>
            </li>
        </dl>
    </axiom>

    <activity xml:id="auto_osmusk0c">
        <statement>
            <p xml:id="auto_2ekf6tcv">
               <alert>Work in Groups</alert>
            </p>
            <p xml:id="auto_sxjucuhw">
                <alert>What you need</alert>
            </p>
            <p xml:id="auto_7cvqmuc2">
                <ul>
                    <li xml:id="auto_78iaoqn6">
                        <p xml:id="auto_di9bmy99">
                            A pen or a pencil and an eraser.
                        </p>
                    </li>
                    <li xml:id="auto_nf0rumjz">
                        <p xml:id="auto_a30u6ed1">
                            A ruler.
                        </p>
                    </li>
                    <li xml:id="auto_q49awp34">
                        <p xml:id="auto_ly09dkv6">
                            An exercise book and a graph paper.
                        </p>
                    </li>
                </ul>
            </p>
            <p xml:id="auto_q2f8h9cx">
                <alert>What to do</alert>
            </p>
            <p xml:id="auto_vainy8op">
                <ol>
                    <li xml:id="auto_amwe8hs8">
                        <p xml:id="auto_v2o937k3">
                            Collect data from <m>30</m> students in your class or from other classes asking:
                        </p>
                        <p xml:id="auto_rqsy6kvw">
                            Which of the following school lunch options do you prefer?
                        </p>
                        <p xml:id="auto_7ccfv7vw">
                            <ul>
                                <li xml:id="auto_8p4n0x8y">Option A: Rice and beans</li>
                                <li xml:id="auto_w6z55v6g">Option B: Githeri</li>
                                <li xml:id="auto_zeqpbvtu">Option C: Chapati and beans</li>
                                <li xml:id="auto_w66i63k4">Option D: Ugali and vegetables</li>
                            </ul>
                        </p>
                        <p xml:id="auto_5n7r58qm">
                            Record the responses as follows:
                        </p>
                        <p xml:id="auto_hgk1x4cn">
                            A, D, C, C, B, A, D, A, B, C, A, D, A,...
                        </p>
                    </li>
                    <li xml:id="auto_cbqkvkqe">
                        <p xml:id="auto_t26v977u">
                            Prepared an ungrouped frequency table of the responses.
                        </p>
                        <tabular top="medium">
                            <row >
                                <cell right="medium">Options</cell>
                                 <cell right="medium">Tally</cell>
                                <cell>Frequency</cell>
                                
                            </row>
                            <row>
                               <cell right="medium"> A: Rice and beans</cell>
                                <cell right="medium"></cell>
                                <cell></cell>
                            </row>
                            <row bottom="medium">
                                <cell right="medium"> B: Githeri</cell>
                                <cell right="medium"></cell>
                                <cell></cell>
                            </row>
                            <row bottom="medium">
                                <cell right="medium"> C: Chapati and beans</cell>
                                <cell right="medium"></cell>
                                <cell></cell>
                            </row>
                            <row bottom="medium">
                                <cell right="medium"> D: Ugali and vegetables</cell>
                                <cell right="medium"></cell>
                                <cell></cell>
                            </row>
                        </tabular>
                    </li>
                    <li xml:id="auto_jp1lj5bd">
                        <p xml:id="auto_buq8d2c2">
                            Draw an histogram and a frequency table for the lunch preferences.
                        </p>
                    </li>
                    <li xml:id="auto_gzgnkdzk">
                        <p xml:id="auto_ltym5b5o">
                            Interpret the data to determine:
                        </p>
                        <p xml:id="auto_cu1q21nb">
                            <ol marker="i)">
                                <li xml:id="auto_h2pxt231">
                                    <p xml:id="auto_7zutimv9">
                                       Which lunch option is the most preferred? 
                                    </p>
                                </li>
                                <li xml:id="auto_ki6xz7p4">
                                    <p xml:id="auto_jql9p0ws">
                                        Which lunch option is the least preferred?
                                    </p>
                                </li>
                                <li xml:id="auto_cii1u9r6">
                                    <p xml:id="auto_5xvs9o8e">
                                        If the school wanted to serve the most preferred meal next week, which meal should they choose?
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>
                    <li xml:id="auto_t3z0hcm6">
                        <p xml:id="auto_2msnikdi">
                            Why is it important to collect data from many students rather than just a few?
                        </p>
                    </li>
                    <li xml:id="auto_6hfjdemy">
                        <p xml:id="auto_y5mjuj9b">
                            How did organizing and representing the data help you in interpreting the results and making a decision about which lunch option to serve?
                        </p>
                    </li>
                    <li xml:id="auto_87n30lk3">
                        <p xml:id="auto_pqmo8tq6">
                            Share your work with fellow students.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
    </activity>

    <axiom component="lesson-plan">
        <title>Structured Instruction</title>
        <p xml:id="auto_or0q2j8u">
            <dl>
            <li xml:id="auto_n58rpcrt">
                <title>Suggested Time</title>
                <p xml:id="auto_i6cjljdd">10 minutes</p>
            </li>
            <li xml:id="auto_vi0btnp2">
                <title>Objective</title>
                <p xml:id="auto_d0ej4a4s">To formalize the concept of informed decision-making and the six-step process for making decisions based on data.</p>
            </li>
            </dl>
        </p>
        <paragraphs>
            <title>Teaching Tips</title>
            <ul>
                <li xml:id="auto_jwpxwjlq"><p xml:id="auto_an0bznhy">Make it real: Use examples from students' daily lives and local contexts.</p></li>
                <li xml:id="auto_53b3mlta"><p xml:id="auto_pjy3ajbj">Emphasize the process: Focus on the six steps, not just calculations.</p></li>
                <li xml:id="auto_6j618yqe"><p xml:id="auto_8b5bykdl">Encourage critical thinking: Always ask <q>What does this data tell us?</q> and <q>What should we do?</q></p></li>
                <li xml:id="auto_3lqd0s20"><p xml:id="auto_3dtt6fel">Use authentic data: Collect real data from the class or school.</p></li>
                <li xml:id="auto_bq80ka3c"><p xml:id="auto_lt06z9m1">Connect across topics: This lesson integrates all previous statistics topics.</p></li>
            </ul>
        </paragraphs>
    </axiom>

    <definition xml:id="def-informed-decision">
        <statement>
            <p xml:id="auto_btlzx5xz">
                Informed decision-making is the process of using data and evidence to make choices that are based on facts and analysis rather than assumptions or guesses.
            </p>
        </statement>
    </definition>
    <insight xml:id="auto_7ah1zzwh">
        <p xml:id="auto_3neec6qj">
             How to make informed decisions based on data:
            <ol>
                <li xml:id="auto_4ckmkrwl">Identify the problem or question to be addressed.</li>
                <li xml:id="auto_8oz50glp">Collect relevant data through surveys, experiments, or observations.</li>
                <li xml:id="auto_uq8chg5e">Organize the data into useful forms such as frequency tables (both grouped and ungrouped).</li>
                <li xml:id="auto_ziptqyub">Represent the data visually using tables, histograms, and frequency polygons to identify patterns, trends, and relationships.</li>
                <li xml:id="auto_c6pw9czr">Interpret the data to draw conclusions.</li>
                <li xml:id="auto_hwoyo735">Make informed decisions based on the analysis and interpretation of the data.</li>
            </ol>
        </p>
    </insight>


    <axiom component="lesson-plan">
        <title>Practice and Application</title>
        <p xml:id="auto_j60utttx">
            <dl>
            <li xml:id="auto_fz9t4e9j">
                <title>Suggested Time</title>
                <p xml:id="auto_frhyu5xo">15 minutes</p>
            </li>
            <li xml:id="auto_o8be23qj">
                <title>Objective</title>
                <p xml:id="auto_dvcwzyy0">To apply the six-step informed decision-making process to real-world data scenarios.</p>
            </li>
            <li xml:id="auto_04kokf1q">
                <title>Teacher's Role</title>
                <p xml:id="auto_39ojok45">Work through examples with learners step by step. Circulate during independent practice and provide assistance where needed.</p>
            </li>
            </dl>
        </p>
    </axiom>
    <example xml:id="auto_1l61fsx4">
        <statement>
            <p xml:id="auto_03gkdam8">
                A class of <m>60</m> students was asked which type of school activity they preferred and the responses were recorded in the frequency table below.
            </p>
            <tabular left="medium" top="medium" right="medium" bottom="medium">
                <row>
                    <cell>Activity</cell>
                    <cell bottom="medium">Frequency</cell>
                </row>
                <row>
                    <cell>Football</cell>
                    <cell bottom="medium">12</cell>
                </row>
                <row>
                    <cell>Debate club</cell>
                    <cell>10</cell>
                </row>
                <row>
                    <cell>Basketball</cell>
                    <cell bottom="medium">8</cell>
                </row>
                <row>
                    <cell>Drama</cell>
                    <cell bottom="medium">5</cell>
                </row>
                <row>
                    <cell>Music band</cell>
                    <cell bottom="medium">10</cell>
                </row>
                <row>
                    <cell>Math club</cell>
                    <cell bottom="medium" >15</cell>
                </row>
            </tabular>
            <p xml:id="auto_i2u04i9c">
                <ol>
                    <li xml:id="auto_2zr7yigt">
                        <p xml:id="auto_rmv4bpca">
                            Which could be the method used to collect the data?
                        </p>
                    </li>
                    <li xml:id="auto_uvzu6mqp">
                        <p xml:id="auto_1ss4xmoz">
                            Represent the organized data using a histogram.
                        </p>
                    </li>
                    <li xml:id="auto_wmwj8cof">
                        <p xml:id="auto_1c0wqf8d">
                            Identify the most preferred activity.
                        </p>
                    </li>
                    <li xml:id="auto_l1ruz1rt">
                        <p xml:id="auto_ye0pbtwk">
                            If the school can support only one activity next term, which activity should they choose to support? Why?
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p xml:id="auto_wjez8g82">
                <ol>
                    <li xml:id="auto_lfzx6h86">
                        <p xml:id="auto_zpnq42a1">
                            The data could have been collected using a survey where students were asked to choose their preferred activity from a list of options.
                        </p>
                    </li>
                    <li xml:id="auto_g8875n97">
                        <image width="60%">
                            <latex-image>
                                \begin{tikzpicture}
                                    \begin{axis}[
                                        ybar,
                                        bar width=10pt,
                                        xlabel={Activities},
                                        ylabel={Frequency},
                                        symbolic x coords={Football, DebateClub, Basketball, Drama, MusicBand, MathClub},
                                        xtick=data,
                                        xticklabels={Football, Debate club, Basketball, Drama, Music band, Math club},
                                        x tick label style={rotate=90},
                                        xlabel style={yshift=-50pt},
                                        nodes near coords,
                                        nodes near coords align={vertical}
                                    ]
                                    \addplot coordinates {(Football,12) (DebateClub,10) (Basketball,8) (Drama,5) (MusicBand,10) (MathClub,15)};
                                    \end{axis}
                                \end{tikzpicture}
                            </latex-image>
                            
                        </image>
                    </li>
                    <li xml:id="auto_5snuh599">
                        <p xml:id="auto_b4kx8q52">
                            The most preferred activity is the Math club, with a frequency of 15 students.
                        </p>
                    </li>
                    <li xml:id="auto_fo51gclz">
                        <p xml:id="auto_5du2c0l1">
                            If the school can support only one activity next term, they should choose to support the Math club because it is the most preferred activity among the students, as indicated by the highest frequency in the data.
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
    </example>
    <example xml:id="auto_4elqzvk7">
        <statement>
            <p xml:id="auto_qm143xtx">
                A school principal wants to introduce an extra Mathematics clinic on Saturdays.
                 Before making a decision, she records the number of hours <m>40</m> students spend studying Mathematics per week.
            </p>
            <p xml:id="auto_oyfl36oj">
                 The data collected (in hours) is:
            </p>
            <p xml:id="auto_fkusxie3">
                <m>2, 3, 4, 5, 6, 3, 4, 5, 7, 8,</m>
            </p>
            <p xml:id="auto_fh8csal0">
                <m>2, 3, 4, 4, 5, 6, 7, 5, 4, 3,</m>
            </p>
            <p xml:id="auto_lhyugqhp">
                <m>6, 7, 8, 5, 4, 3, 2, 6, 7, 5,</m>
            </p>
            <p xml:id="auto_lflng8fl">
                <m>4, 5, 6, 3, 2, 4, 5, 6, 7, 8</m>
            </p>
            <p xml:id="auto_9to4zoxj">
                <ol marker="(a)">
                    <li xml:id="auto_vcnmxqmh">
                        <p xml:id="auto_14tnqrkx">
                            Construct a frequency distribution table.
                        </p>
                    </li>
                    <li xml:id="auto_87mjkw7s">
                        <p xml:id="auto_20wujdeq">
                            Represent the data using a histogram
                        </p>
                    </li>
                    <li xml:id="auto_uxre9hyx">
                        <p xml:id="auto_9krxn2qs">
                            Interpret the results.
                        </p>
                    </li>
                    <li xml:id="auto_6po1ti8n">
                        <p xml:id="auto_mkpe3gcd">
                            Based on the data, advise the principal whether an extra Mathematics clinic is necessary.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p xml:id="auto_m0yxssjn">
                <ol marker="(a)">
                    <li xml:id="auto_mkwma71h">
                        <p xml:id="auto_zceixkve">
                            The frequency distribution table is as follows:
                        </p>
                        <tabular left="medium" top="medium" right="medium" bottom="medium">
                            <row>
                                <cell>Hours Studied</cell>
                                <cell>Tally</cell>
                                <cell bottom="medium">Frequency</cell>
                            </row>
                            <row>
                                <cell>2</cell>
                                <cell>||||</cell>
                                <cell bottom="medium">4</cell>
                            </row>
                            <row>
                                <cell>3</cell>
                                <cell>||||||</cell>
                                <cell bottom="medium">6</cell>
                            </row>
                            <row>
                                <cell>4</cell>
                                <cell>||||||||</cell>
                                <cell bottom="medium">8</cell>
                            </row>
                            <row>
                                <cell>5</cell>
                                <cell>||||||||</cell>
                                <cell bottom="medium">8</cell>
                            </row>
                            <row>
                                <cell>6</cell>
                                <cell>||||||</cell>
                                <cell bottom="medium">6</cell>
                            </row>
                            <row>
                                <cell>7</cell>
                                <cell>|||||</cell>
                                <cell bottom="medium">5</cell>
                            </row>
                            <row>
                                <cell>8</cell>
                                <cell>|||</cell>
                                <cell bottom="medium">3</cell>
                            </row>

                        </tabular>

                    </li>
                     <li xml:id="auto_1bt7oqyz">
                    <image>
                        <latex-image>
                            \begin{tikzpicture}
                                \begin{axis}[
                                    ybar,
                                    bar width=10pt,
                                    xlabel={Hours Studied},
                                    ylabel={Frequency},
                                    symbolic x coords={2, 3, 4, 5, 6, 7, 8},
                                    xtick=data,
                                    xticklabels={2, 3, 4, 5, 6, 7, 8},
                                    nodes near coords,
                                    nodes near coords align={vertical}
                                ]
                                \addplot coordinates {(2,4) (3,6) (4,8) (5,8) (6,6) (7,5) (8,3)};
                                \end{axis}
                            \end{tikzpicture}
                        </latex-image>
                        
                    </image>
                </li>
                    <li xml:id="auto_dwz1fnj1">
                        <p xml:id="auto_swl8dqrh">
                            <ol marker="i)">
                                <li xml:id="auto_7hyz5j70">
                                    <p xml:id="auto_z42mxs4e">
                                        The average study time is about 5 hours.
                                    </p>
                                </li>
                                <li xml:id="auto_uqpl1t3b">
                                    <p xml:id="auto_hzl8jvri">
                                        Most students study between 3 and 6 hours.
                                    </p>
                                </li>
                                <li xml:id="auto_n0aok5ta">
                                    <p xml:id="auto_jb6rhz6z">
                                        The most common study time is 4 and 5 hours.
                                    </p>
                                </li>
                                <li xml:id="auto_twid6fzp">
                                    <p xml:id="auto_ogqbj755">
                                        Very few students study less than 2 hours or more than 7 hours.
                                    </p>
                                </li>
                            </ol>
                        </p>
                    </li>

                    <li xml:id="auto_oiqj97mk">
                        <p xml:id="auto_joxgskfe">
                            Based on the data, it appears that a majority of students are already dedicating a reasonable amount of time to studying Mathematics.
                             However, there is a portion of students who may benefit from additional support. 
                            Therefore, the principal could consider introducing an extra Mathematics clinic, but it may be more effective to target it towards students who are struggling or spending less time on Mathematics rather than making it compulsory.
                        </p>
                    </li>

                </ol>
            </p>
        </solution>
    </example>
    <example xml:id="auto_3561hg3z">
        <statement>
            <p xml:id="auto_4rnake6p">
                A company conducted a study on the daily number of customers visiting two supermarkets (A and B) over <m>30</m> days.
            </p>
            <p xml:id="auto_5qo2vu9e">
                The grouped data is shown below:
            </p>
            <table xml:id="auto_bxequejm">
                <title>Supermarket A</title>
                <tabular left="medium" top="medium" right="medium" bottom="medium">
                    <row>
                        <cell>Number of customers</cell>
                        <cell>Frequency</cell>
                    </row>
                    <row>
                        <cell>0 - 50</cell>
                        <cell>2</cell>
                    </row>
                    <row>
                        <cell>50 - 100</cell>
                        <cell>5</cell>
                    </row>
                    <row>
                        <cell>100 - 150</cell>
                        <cell>8</cell>
                    </row>
                    <row>
                        <cell>150 - 200</cell>
                        <cell>10</cell>

                    </row>
                    <row>
                        <cell>200 - 250</cell>
                        <cell>5</cell>
                    </row>
                </tabular>
            </table>
            <table xml:id="auto_t58vokje">
                <title>Supermarket B</title>
                <tabular left="medium" top="medium" right="medium" bottom="medium">
                    <row>
                        <cell>Number of customers</cell>
                        <cell>Frequency</cell>
                    </row>
                    <row>
                        <cell>0 - 50</cell>
                        <cell>6</cell>
                    </row>
                    <row>
                        <cell>50 - 100</cell>
                        <cell>8</cell>
                    </row>
                    <row>
                        <cell>100 - 150</cell>
                        <cell>10</cell>
                    </row>
                    <row>
                        <cell>150 - 200</cell>
                        <cell>4</cell>

                    </row>
                    <row>
                        <cell>200 - 250</cell>
                        <cell>2</cell>
                    </row>
                </tabular>
            </table>
            <p xml:id="auto_uc28xzo7">
                <ol marker="(a)">
                    <li xml:id="auto_dtqiz2vx">
                        <p xml:id="auto_u15l6j7m">
                            Calculate the estimated mean number of customers for each supermarket
                        </p>
                    </li>
                    <li xml:id="auto_fm7k8nxv">
                        <p xml:id="auto_g81fhkob">
                            State which supermarket is more consistent and justify your answer using the distribution.
                        </p>
                    </li>
                    <li xml:id="auto_uham2atk">
                        <p xml:id="auto_yobhtx8s">
                            Draw comparative histograms for both supermarkets
                        </p>
                    </li>
                    <li xml:id="auto_jmdc4uek">
                        <p xml:id="auto_lp1ymmic">
                            The company wants to expand one supermarket.
                             Using statistical evidence, advise which one should be expanded.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>
        <solution>
            <p xml:id="auto_pm2sefq8">
                <ol marker="(a)">
                    <li xml:id="auto_697yrzgc">
                        <p xml:id="auto_35492q8s">
                            The estimated mean number of customers for Supermarket A is calculated as follows:
                            <md>
                            <mrow>
                            \text{Mean}_A =\amp \frac{(25 \times 2) + (75 \times 5) + (125 \times 8) + (175 \times 10) + (225 \times 5)}{30}   
                            </mrow>
                            <mrow> =\amp \frac{50 + 375 + 1000 + 1750 + 1125}{30} </mrow>
                            <mrow> =\amp \frac{4500}{30} </mrow>
                            <mrow> =\amp 150 </mrow>
                            </md> 
                        </p>
                        <p xml:id="auto_l6qg77im"> The estimated mean number of customers for Supermarket B is calculated as follows: </p>
                        <p xml:id="auto_4da4nv80">
                            <md>
                            <mrow>
                            \text{Mean}_B =\amp \frac{(25 \times 6) + (75 \times 8) + (125 \times 10) + (175 \times 4) + (225 \times 2)}{30}
                            </mrow>
                            <mrow> =\amp \frac{150 + 600 + 1250 + 700 + 450}{30}</mrow>
                            <mrow> =\amp \frac{3150}{30} </mrow>
                            <mrow> =\amp 105 </mrow>
                            </md>
                            
                        </p>
                    </li>
                    <li xml:id="auto_ezdd3qb3">
                        <p xml:id="auto_ev3szw4p">
                            Supermarket A is more consistent because it has a higher frequency of customers in the middle range, while Supermarket B has a more spread out distribution with higher frequencies in the lower range.
                        </p>
                    </li>
                    <li xml:id="auto_8lxsbhvu">
                        
                        <image width="80%">
                            <latex-image label="Histogram - Supermarket Customers">
                                \begin{tikzpicture}
                                    % Draw fine grid (10 smaller squares per main grid unit)
                                    \draw[gray!30, very thin, step=0.1] (0,0) grid (10,10);
                                    
                                    % Draw main grid
                                    \draw[gray!70, thin, step=1] (0,0) grid (10,10);
                                    
                                    % Draw axes
                                    \draw[thick,->] (0,0) -- (10,0); % X-axis
                                    \draw[thick,->] (0,0) -- (0,10); % Y-axis
                                    \node[below] at (5,-0.8) {\textbf {Number of Customers}}; % X-axis label
                                    \node[rotate=90] at (-1,4) {\textbf {Frequency}}; % Y-axis label
                                    
                                    % X-axis labels (Customer Ranges)
                                    \foreach \x/\label in {1/0, 2/50, 3/100, 4/150, 5/200, 7/250} {
                                        \node[below] at (\x,0) {\label};
                                    }
                                    
                                    % Y-axis labels (2 grid units = 2 frequency)
                                    \foreach \y/\label in {0/0, 2/2, 4/4, 6/6, 8/8, 10/10, 12/12} {
                                        \node[left] at (0,\y) {\label};
                                    }
                                    
                                    % Draw histogram bars - Supermarket A (left bar in each pair)
                                    \draw[fill=blue!60] (0.8,0) rectangle (1.2,2);   % 0-50:  2 customers
                                    \draw[fill=blue!60] (1.8,0) rectangle (2.2,5);   % 50-100: 5 customers
                                    \draw[fill=blue!60] (2.8,0) rectangle (3.2,8);   % 100-150: 8 customers
                                    \draw[fill=blue!60] (3.8,0) rectangle (4.2,10);  % 150-200: 10 customers
                                    \draw[fill=blue!60] (4.8,0) rectangle (5.2,5);   % 200-250: 5 customers
                                    
                                    % Draw histogram bars - Supermarket B (right bar in each pair)
                                    \draw[fill=red!60] (1.0,0) rectangle (1.4,6);    % 0-50:  6 customers
                                    \draw[fill=red!60] (2.0,0) rectangle (2.4,8);    % 50-100: 8 customers
                                    \draw[fill=red!60] (3.0,0) rectangle (3.4,10);   % 100-150: 10 customers
                                    \draw[fill=red!60] (4.0,0) rectangle (4.4,4);    % 150-200: 4 customers
                                    \draw[fill=red!60] (5.0,0) rectangle (5.4,2);    % 200-250: 2 customers
                                    
                                    % Graph Title
                                    \node[above] at (5,10.5) {\textbf {Customer Distribution: Supermarket A vs Supermarket B}};
                                    
                                    % Legend
                                    \draw[fill=blue!60] (7.5,8.5) rectangle (7.9,8.9);
                                    \node[right] at (8.0,8.7) {Supermarket A};
                                    \draw[fill=red!60] (7.5,7.5) rectangle (7.9,7.9);
                                    \node[right] at (8.0,7.7) {Supermarket B};
                                    
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li xml:id="auto_hex1s3ux">
                        <p xml:id="auto_mw3mri5q">
                            Based on the estimated mean number of customers, Supermarket A has a higher average (150) compared to Supermarket B (105). 
                             Additionally, Supermarket A is more consistent with a higher frequency in the middle ranges. 
                            Therefore, it would be advisable for the company to expand Supermarket A as it has a larger customer base and more consistent traffic.
                        </p>
                    </li>
                </ol>
            </p>
        </solution>
    </example>

    <axiom component="lesson-plan">
        <title>Assessment</title>
        <p xml:id="auto_gun74gdw">
            <dl>
            <li xml:id="auto_3sn2s4ga">
                <title>Objective</title>
                <p xml:id="auto_0k24kzv8">To formatively assess individual learner understanding.</p>
            </li>
            <li xml:id="auto_k3io25te">
                <title>Learning Experience</title>
                <p xml:id="auto_ys6q8xsf">Learners independently complete a short assessment task (select from the exercises above or below).</p>
            </li>
            <li xml:id="auto_rzfko4km">
                <title>Teacher's Role</title>
                <p xml:id="auto_njj28vao">Collect and review the exit tickets to gauge learner understanding and identify any common misconceptions that need to be addressed in the next lesson.</p>
            </li>
            </dl>
        </p>
    </axiom>

    <xi:include href="../../resources-checkpoint.ptx" />

    <exercises xml:id="exercises-applying-statistics-decision-making">
    <title>Exercise</title>

    <exercise xml:id="stats01">
        <statement>
            <p xml:id="auto_kim1nbtm">
                The number of students who visited the school library over <m>10</m> days is shown below:
            </p>
            <p xml:id="auto_h1ih38dz">
                <m>20, 25, 30, 35, 25, 40, 30, 20, 25, 35</m>
            </p>
            <p xml:id="auto_j7sop3uo">
                <ol marker="(a)">
                    <li xml:id="auto_iq0sv2sq">
                        <p xml:id="auto_x0opgye8">
                            Construct a frequency table.
                        </p>
                    </li>
                    <li xml:id="auto_0zas28d7">
                        <p xml:id="auto_53439h74">
                            Calculate the mean number of students.
                        </p>
                    </li>
                    <li xml:id="auto_pbyaexle">
                        <p xml:id="auto_jmjggy2r">
                            State the mode.
                        </p>
                    </li>
                    <li xml:id="auto_4vq1mprc">
                        <p xml:id="auto_l25yyi5m">
                            Should the school increase the number of library seats from 25 to 40? Give a reason.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>

        <answer>
            <p xml:id="auto_bvburxj0">
                <ol marker="(a)">
                    <li xml:id="auto_07dcvpu8">
                        <p xml:id="auto_2r96vvwm">
                            Frequency Table:
                        </p>
                        <tabular>
                            <row>
                                <cell bottom="medium" right="medium">Number of Students</cell>
                                <cell bottom="medium">Frequency</cell>
                            </row>
                            <row>
                                <cell right="medium">20</cell>
                                <cell>2</cell>
                            </row>
                            <row>
                                <cell right="medium">25</cell>
                                <cell>3</cell>
                            </row>
                            <row>
                                <cell right="medium">30</cell>
                                <cell>2</cell>
                            </row>
                            <row>
                                <cell right="medium">35</cell>
                                <cell>2</cell>
                            </row>
                            <row>
                                <cell right="medium">40</cell>
                                <cell>1</cell>
                            </row>
                        </tabular>
                    </li>
                    <li xml:id="auto_2w1e3kh6">
                        <p xml:id="auto_mxwpcinm">
                            Mean <m>= 28.5</m>
                        </p>
                    </li>
                    <li xml:id="auto_kcotagug">
                        <p xml:id="auto_xcq5bg7n">
                            Mode = <m>25</m>
                        </p>
                    </li>
                    <li xml:id="auto_topatrx7">
                        <p xml:id="auto_846fd4fl">
                            Since the most common number is <m>25</m> students and the average is about <m>28</m>, increasing seats to <m>40</m> is not necessary at the moment. 
                            Increasing to around <m>30</m> seats would be reasonable.
                        </p>
                    </li>
                </ol>
            </p>
        </answer>
    </exercise>


    <exercise xml:id="stats02">
        <statement>
            <p xml:id="auto_2xlfcnxf">
                The marks obtained by <m>30</m> students in a Mathematics test are grouped below:
            </p>

            <tabular>
                <row >
                    <cell bottom="medium" right="medium">Marks</cell>
                    <cell bottom="medium">Frequency</cell>
                </row>
                <row>
                    <cell right="medium">0-20</cell>
                    <cell>3</cell>
                </row>
                <row>
                    <cell right="medium">20-40</cell>
                    <cell>5</cell>
                </row>
                <row>
                    <cell right="medium">40-60</cell>
                    <cell>10</cell>
                </row>
                <row>
                    <cell right="medium">60-80</cell>
                    <cell>8</cell>
                </row>
                <row>
                    <cell right="medium">80-100</cell>
                    <cell>4</cell>
                </row>
            </tabular>

            <p xml:id="auto_t5t0nclc">
                <ol marker="(a)">
                    <li xml:id="auto_ius1srhg">
                        <p xml:id="auto_alcusm4i">
                            Estimate the mean mark.
                        </p>
                    </li>
                    <li xml:id="auto_zu747ben">
                        <p xml:id="auto_eq6ibx4c">
                            Draw a histogram.
                        </p>
                    </li>
                    <li xml:id="auto_6c0qj41t">
                        <p xml:id="auto_3pb8fw2g">
                            Comment on the general performance.
                        </p>
                    </li>
                </ol>
                
            </p>
        </statement>

        <answer>
            <p xml:id="auto_kg7gr8vj">
                <ol marker="(a)">
                    <li xml:id="auto_nv6rjuqf">
                        <p xml:id="auto_3mj4y1gp">
                            Mean <m>= 53.3</m>
                        </p>
                    </li>
                    <li xml:id="auto_bdjtwzz0">
                        <image width="60%"> 
                            <latex-image label="Histogram - Student Marks">
                                \begin{tikzpicture}[y=0.4cm, x=0.12cm]
                                    % Draw axes
                                    \draw[thick,->] (0,0) -- (105,0) node[right] {\textbf{Marks}};
                                    \draw[thick,->] (0,0) -- (0,13) node[above] {\textbf{Frequency}};
                                    
                                    % Grid
                                    \foreach \x in {0,20,40,60,80,100} {
                                        \draw[gray!30, dashed] (\x,0) -- (\x,12);
                                    }
                                    \foreach \y in {0,2,4,6,8,10,12} {
                                        \draw[gray!30, dashed] (0,\y) -- (100,\y);
                                        \node[left] at (-2,\y) {\y};
                                    }
                                    
                                    % X-axis labels
                                    \foreach \x/\label in {0/0,20/20,40/40,60/60,80/80,100/100} {
                                        \node[below] at (\x,-0.5) {\label};
                                    }
                                    
                                    % Bars
                                    \fill[cyan!80!blue!70] (0,0) rectangle (20,3);
                                    \fill[cyan!80!blue!70] (20,0) rectangle (40,5);
                                    \fill[cyan!80!blue!70] (40,0) rectangle (60,10);
                                    \fill[cyan!80!blue!70] (60,0) rectangle (80,8);
                                    \fill[cyan!80!blue!70] (80,0) rectangle (100,4);
                                    
                                    % Borders
                                    \draw[thick] (0,0) rectangle (20,3);
                                    \draw[thick] (20,0) rectangle (40,5);
                                    \draw[thick] (40,0) rectangle (60,10);
                                    \draw[thick] (60,0) rectangle (80,8);
                                    \draw[thick] (80,0) rectangle (100,4);
                                    
                                    % Labels
                                    \node[above] at (10,3) {3};
                                    \node[above] at (30,5) {5};
                                    \node[above] at (50,10) {10};
                                    \node[above] at (70,8) {8};
                                    \node[above] at (90,4) {4};
                                    
                                    % Title
                                    \node[above, font=\large\bfseries] at (50,13) {Student Marks Distribution};
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                    </li>
                    <li xml:id="auto_6nlk890x">
                        <p xml:id="auto_q2e2z6ze">
                            The histogram shows a relatively uniform distribution of marks, with the highest frequency in the <m>40</m> to <m>60</m> range and the average mark is about <m>53</m>. 
                            
                        </p>
                        <p xml:id="auto_220gwpno">
                             This suggests that most students performed moderately well.
                        </p>
                    </li>
                </ol>
            </p>
            
        </answer>
    </exercise>


    <exercise xml:id="stats03">
        <statement>
            <p xml:id="auto_asvlrwe7">
                A dairy shop recorded daily milk sales (litres) below for <m>7</m> days:
            </p>
            <p xml:id="auto_l6gw47pu">
                <m>80, 90, 100, 120, 110, 95, 105</m>
            </p>
            <p xml:id="auto_a98mnb96">
                <ol marker="(a)">
                    <li xml:id="auto_imdfh5jn">
                        <p xml:id="auto_98edccyn">
                            Find the mean.
                        </p>
                    </li>
                    <li xml:id="auto_3n4j25t5">
                        <p xml:id="auto_bwi3mzpf">
                            Find the median.
                        </p>
                    </li>
                    <li xml:id="auto_e2pqc1s2">
                        <p xml:id="auto_t7emqw66">
                            Should the shop stock <m>85</m> litres daily? Give a reason.
                        </p>
                    </li>
                </ol>
            </p>
        </statement>

        <answer>
            <p xml:id="auto_kehig2et">
                <ol marker="(a)">
                    <li xml:id="auto_cq3xnfn9">
                        <p xml:id="auto_k2p12mdc">
                            Mean = <m>\frac{700}{7} = 100</m>
                        </p>
                    </li>
                    <li xml:id="auto_niavtm5m">
                        <p xml:id="auto_krpp8jd2">
                            Median = <m>100</m>
                        </p>
                    </li>
                    <li xml:id="auto_33ulu4oc">
                       <p xml:id="auto_lgvz5wz5"> 
                        The shop should stock about <m>100</m> to <m>110</m> litres to avoid shortage, since average sales are <m>100</m> litres and stocking only <m>85</m> litres may lead to running out on busy days.
                         
                     </p>
                    </li>
                </ol>
            </p>
           
        </answer>
    </exercise>


    <exercise xml:id="stats04">
        <statement>
            <p xml:id="auto_n6h5vhmr">
                The number of passengers using a bus route over 8 days is shown below:
            </p>
            <p xml:id="auto_cppdzytc">
                <m>45, 50, 55, 60, 50, 45, 65, 70</m>
            </p>
            <p xml:id="auto_f8bgxq5d">
                <ol marker="(a)">
                    <li xml:id="auto_ry3s7pty">
                        <p xml:id="auto_chhwkx6q">
                            Construct a frequency table.
                        </p>
                    </li>
                    <li xml:id="auto_e6ni2jdt">
                        <p xml:id="auto_byuiwtpw">
                            Calculate the mean.
                        </p>
                    </li>
                    <li xml:id="auto_i8rtbq8g">
                        <p xml:id="auto_h9ka9hvj">
                            Represent the data using a histogram.
                        </p>
                    </li>
                    <li xml:id="auto_7zi6bsbh">
                        <p xml:id="auto_0sqe9frv">
                            Should the company use a 50-seater bus? Give a reason.
                        </p>
                    </li>
                </ol>
                
            </p>
        </statement>

        <answer>
            <p xml:id="auto_6kbgu71g">
                <ol marker="(a)">
                    <li xml:id="auto_8qdngfxc">
                        <p xml:id="auto_a2mur076">
                            Frequency Table:
                        </p>
                        <tabular>
                            <row>
                                <cell bottom="medium">Passengers</cell>
                                <cell bottom="medium">Frequency</cell>
                            </row>
                            <row>
                                <cell>45</cell>
                                <cell>2</cell>
                            </row>
                            <row>
                                <cell>50</cell>
                                <cell>2</cell>
                            </row>
                            <row>
                                <cell>55</cell>
                                <cell>1</cell>
                            </row>
                            <row>
                                <cell>60</cell>
                                <cell>1</cell>
                            </row>
                            <row>
                                <cell>65</cell>
                                <cell>1</cell>
                            </row>
                            <row>
                                <cell>70</cell>
                                <cell>1</cell>
                            </row>
                        </tabular>
                    </li>
                    <li xml:id="auto_w2bxfbvd">
                        <p xml:id="auto_zbryodct">
                             Mean <m>= 55</m>
                        </p>
                    </li>
                    <li xml:id="auto_eyz4toga">
                        <image width="60%">
                            <latex-image label="Passenger Distribution">
                                \begin{tikzpicture}
                                    % Draw fine grid (10 smaller squares per main grid unit)
                                    \draw[gray!30, very thin, step=0.1] (0,0) grid (10,10);
                                    
                                    % Draw main grid
                                    \draw[gray!70, thin, step=1] (0,0) grid (10,10);
                                    
                                    % Draw axes
                                    \draw[thick,->] (0,0) -- (10,0); % X-axis
                                    \draw[thick,->] (0,0) -- (0,10); % Y-axis
                                    \node[below] at (5,-0.8) {\textbf {Number of Passengers}}; % X-axis label
                                    \node[rotate=90] at (-1,4) {\textbf {Frequency}}; % Y-axis label
                                    
                                    % X-axis labels (Class Boundaries)
                                    \foreach \x/\label in { 1/45, 2/50, 3/55, 4/60, 5/65, 6/70} {
                                        \node[below] at (\x,0) {\label};
                                    }
                                    
                                    % Y-axis labels (2 grid units = 1 frequency)
                                    \foreach \y/\label in {0/0, 2/1, 4/2, 6/3, 8/4, 10/5} {
                                        \node[left] at (0,\y) {\label};
                                    }
                                    
                                    % Draw histogram bars (non-overlapping, centered on each value)
                                    \draw[fill=cyan!80!blue!70] (0.7,0) rectangle (1.3,4);      % 45:  frequency 2  (4 grid units = 2)
                                    \draw[fill=cyan!80!blue!70] (1.7,0) rectangle (2.3,4);      % 50:  frequency 2  (4 grid units = 2)
                                    \draw[fill=cyan!80!blue!70] (2.7,0) rectangle (3.3,2);      % 55:  frequency 1  (2 grid units = 1)
                                    \draw[fill=cyan!80!blue!70] (3.7,0) rectangle (4.3,2);      % 60:  frequency 1  (2 grid units = 1)
                                    \draw[fill=cyan!80!blue!70] (4.7,0) rectangle (5.3,2);      % 65:  frequency 1  (2 grid units = 1)
                                    \draw[fill=cyan!80!blue!70] (5.7,0) rectangle (6.3,2);      % 70:  frequency 1  (2 grid units = 1)
                                    
                                    % Add black borders to bars
                                    \draw[thick] (0.7,0) rectangle (1.3,4);
                                    \draw[thick] (1.7,0) rectangle (2.3,4);
                                    \draw[thick] (2.7,0) rectangle (3.3,2);
                                    \draw[thick] (3.7,0) rectangle (4.3,2);
                                    \draw[thick] (4.7,0) rectangle (5.3,2);
                                    \draw[thick] (5.7,0) rectangle (6.3,2);
                                    
                                    % Graph Title
                                    \node[above, font=\large\bfseries] at (5,10.5) {Passenger Distribution};
                                    
                                \end{tikzpicture}
                            </latex-image>
                        </image>
                        
                        <p xml:id="auto_xdl0hjuh">
                            
                           The histogram shows that passenger numbers are distributed between 45 and 70, with the highest frequency in the 45 and 50 passenger values.
                        </p>
                        
                        
                    </li>
                    <li xml:id="auto_89mo6unk">
                        <p xml:id="auto_aajttsz8">
                            Since the average number of passengers is 55, a 50-seater bus is not sufficient. A larger bus is recommended.
                        </p>
                    </li>
                </ol>
            </p>

        </answer>
    </exercise>

</exercises>

    <axiom component="lesson-plan">
        <title>Differentiation</title>

        <table xml:id="auto_qe3jr922">
            <title>Differentiation</title>
            <tabular halign="left">
                <row header="yes" bottom="minor">
                    <cell>Learner Group</cell>
                    <cell>Strategy &amp; Learning Experience</cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Struggling Learners (Support)</cell>
                    <cell>
                        <line><alert>Scaffolding:</alert> Provide pre-made frequency table templates. Use smaller datasets (15–20 data points instead of 30). Pair with stronger students for peer support. Provide step-by-step checklist for the six-step process. Use visual aids showing examples of each step.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>On-Level Learners (Core)</cell>
                    <cell>
                        <line>The core lesson activities as described above.</line>
                    </cell>
                    <cell></cell>
                </row>
                <row>
                    <cell>Advanced Learners (Challenge)</cell>
                    <cell>
                        <line><alert>Extended Learning Experience:</alert> Challenge them to collect data from multiple classes (60+ students). Compare results from different groups (boys vs girls, different grades). Create grouped frequency tables in addition to ungrouped. Calculate mean, median, and mode for their data. Identify potential biases in their data collection. Present findings with recommendations to the class.</line>
                    </cell>
                    <cell></cell>
                </row>
            </tabular>
        </table>
    </axiom>
    <xi:include href="../../resources-assessment.ptx" />
    <xi:include href="../../resources-reflection.ptx"/>

</subsection>
