    <questionvariables>
      <text>/* Random factors */
a: rand(8) + 1;
b: rand(8) + 1;

/* Quadratic expression */
expr: expand((x - a)*(x - b));

/* Correct factorisation */
correct: (x - a)*(x - b);

/* Coefficients for explanation */
mid: -(a + b);
const: a*b;

/* Common mistakes */
m1: (x + a)*(x + b);
m2: x^2 - a*x - b;</text>
    </questionvariables>
