    <questionvariables>
      <text>/* Random integers for factors */
a: rand(8) + 1;
b: rand(8) + 1;

/* Quadratic expression */
expr: expand((x + a)*(x + b));

/* Correct factorisation */
correct: (x + a)*(x + b);

/* Common mistakes */
m1: (x + a + b);
m2: (x + a)^2;
m3: x^2 + a*x + b;</text>
    </questionvariables>
