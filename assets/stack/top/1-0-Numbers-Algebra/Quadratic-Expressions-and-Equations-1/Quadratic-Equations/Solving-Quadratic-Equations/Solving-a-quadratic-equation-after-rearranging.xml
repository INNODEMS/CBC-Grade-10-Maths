    <questionvariables>
      <text>/* Random integer roots */
r1: rand(7) - 3;
r2: rand(7) + 2;

/* Construct quadratic from roots */
expr: expand((x - r1)*(x - r2));

/* Rearranged equation form */
k: rand(6) + 2;

/* Equation presented to students */
lhs: expr + k*x;
rhs: k*x;

/* Standard form */
standard: expr;

/* Correct solutions */
sol1: r1;
sol2: r2;

/* Common mistakes */
m1: -r1;
m2: -r2;
m3: r1 + r2;</text>
    </questionvariables>
    <specificfeedback format="html">
