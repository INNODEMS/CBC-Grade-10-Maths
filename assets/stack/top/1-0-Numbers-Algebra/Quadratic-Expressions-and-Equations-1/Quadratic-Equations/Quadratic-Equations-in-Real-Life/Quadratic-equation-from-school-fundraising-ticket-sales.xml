    <questionvariables>
      <text>/* number of tickets in first group */
n: rand(8) + 6;

/* extra tickets in second group */
k: rand(5) + 2;

/* total tickets sold */
T: n*(n + k);

/* quadratic expression */
expr: expand(x*(x + k) - T);

/* correct equation */
eq_correct: expr = 0;

/* correct solution */
sol: n;

/* equation mistakes */
m1: expand(x*(x + k));
m2: expand(x*(x + k) + T);
m3: expr;

/* solution mistakes */
m4: sqrt(T);
m5: n + k;</text>
    </questionvariables>
