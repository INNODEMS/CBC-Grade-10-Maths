    <questionvariables>
      <text>/* Base number of chairs in first row */
r: rand(7) + 4;

/* Difference between the two rows */
k: rand(4) + 2;

/* Total chairs */
T: r*(r + k);

/* LHS expression (standard form) */
expr: expand(x*(x + k) - T);

/* Correct quadratic equation */
qeq: expr = 0;

/* Correct value of x */
sol: r;

/* Mistakes for equation part */
m1: expand(x*(x + k));        /* forgot to include total T */
m2: expand(x*(x + k) + T);    /* wrong sign */
m3: expr;                     /* wrote expression only, not an equation */

/* Mistakes for solution part */
m4: sqrt(T);                  /* square-root shortcut */
m5: -r - k;                   /* negative root */</text>
    </questionvariables>
