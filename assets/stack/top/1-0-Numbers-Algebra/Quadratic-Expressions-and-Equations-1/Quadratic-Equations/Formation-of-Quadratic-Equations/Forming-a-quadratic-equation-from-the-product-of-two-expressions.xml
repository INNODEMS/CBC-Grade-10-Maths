    <questionvariables>
      <text>/* Random constants */
a: rand(6) + 1;
b: rand(6) + 1;
k: rand(20) + 5;

/* Expanded product */
prod: expand((x + a)*(x + b));

/* Standard LHS (expression that should equal 0) */
lhs: expand(prod - k);

/* Standard equation */
standard_eqn: lhs = 0;

/* Common mistakes */
m1: prod;                     /* only expanded */
m2: expand(prod + k);         /* added instead of subtracted */
m3: expand(x^2 + (a + b)*x - k); /* missed constant a*b */
m4: lhs;                      /* wrote expression but forgot =0 */</text>
    </questionvariables>
