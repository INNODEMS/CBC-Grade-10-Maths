    <questionvariables>
      <text>/* Random difference */
k: rand(30) + 1;   /* 1 to 30 */

/* Expression and expansion */
expr: x*(x + k);
expanded: expand(expr);

/* Common mistakes */
m1: x^2 + k;        /* forgets the x term */
m2: x^2 + x + k;    /* adds extra x term */
m3: 2*x + k;        /* adds instead of multiplying */</text>
    </questionvariables>
