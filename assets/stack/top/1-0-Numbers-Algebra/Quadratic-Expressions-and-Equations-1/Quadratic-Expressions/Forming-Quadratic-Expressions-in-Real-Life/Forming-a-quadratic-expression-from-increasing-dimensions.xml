    <questionvariables>
      <text>/* Random increases */
a: rand(6) + 2;   /* 2 to 7 */
b: rand(6) + 3;   /* 3 to 8 */

/* Expression */
expr: (x + a)*(x + b);
expanded: expand(expr);

/* Common mistakes */
m1: x^2 + a*x + b;
m2: x^2 + (a + b);
m3: x^2 + a*b;</text>
