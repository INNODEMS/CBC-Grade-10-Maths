    <questionvariables>
      <text>/* Base number close to 100 */
n: rand(15) + 85;     /* 85–100 */

/* Small adjustment */
k: rand(9) + 1;       /* 1–10 */

/* Expression */
expr: (n + k)^2;

/* Correct value */
correct: expand(expr);

/* Common mistakes */
m1: n^2 + k^2;
m2: (n + k)*(n);
m3: n^2 + 2*n + k^2;</text>
