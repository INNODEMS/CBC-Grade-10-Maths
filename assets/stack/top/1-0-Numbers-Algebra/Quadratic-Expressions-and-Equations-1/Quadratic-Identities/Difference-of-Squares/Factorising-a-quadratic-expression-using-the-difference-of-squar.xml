    <questionvariables>
      <text>/* Random constants */
a: rand(30) + 2;
b: rand(30) + 2;

/* Square values */
A: a^2;
B: b^2;

/* Expression */
expr: A*x^2 - B;

/* Correct factorisation */
correct: (a*x - b)*(a*x + b);

/* Common mistakes */
m1: (a*x - b)^2;
m2: (a*x + b)^2;
m3: (a*x - b)*(a*x - b);</text>
    </questionvariables>
