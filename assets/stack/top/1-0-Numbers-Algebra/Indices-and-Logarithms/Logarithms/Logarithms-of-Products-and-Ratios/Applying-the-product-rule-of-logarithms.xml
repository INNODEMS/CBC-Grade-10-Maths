    <questionvariables>
      <text>/* Random values */
a: rand(10) + 2;
b: rand(10) + 2;

/* Given logs */
loga: rand(3) + 1;
logb: rand(3) + 1;

/* Product result */
ans: loga + logb;

/* mistakes */
m1: loga * logb;
m2: loga - logb;
m3: logb - loga;</text>
