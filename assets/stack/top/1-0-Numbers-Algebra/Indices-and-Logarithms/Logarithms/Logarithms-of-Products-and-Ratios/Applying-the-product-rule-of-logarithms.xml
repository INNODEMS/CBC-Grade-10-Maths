<quiz>
  <question type="stack">
    <name>
      <text>Applying the product rule of logarithms</text>
    </name>
    <questiontext format="moodle_auto_format">
      <text><![CDATA[<p>
Given that:
\[
\log a = {@loga@}, \quad \log b = {@logb@}
\]
</p>

<p>
Find 
\[
\log (ab)
\]
</p>

<p>
[[input:ans1]] [[validation:ans1]] [[feedback:prt1]]
</p>]]></text>
    </questiontext>
    <generalfeedback format="moodle_auto_format">
      <text><![CDATA[<h3>Worked Solution</h3>

<p>
We use the product rule of logarithms:
</p>

<p>
\[
\log(ab) = \log a + \log b
\]
</p>

<p>
Substitute the values:
</p>

<p>
\[
= {@loga@} + {@logb@}
\]
</p>

<p>
\[
= {@ans@}
\]
</p>]]></text>
    </generalfeedback>
