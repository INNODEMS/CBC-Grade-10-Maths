      <text><![CDATA[/* Base magnitudes */
m_small: rand(3) + 3;        /* 3–5 */
gap: rand(3) + 1;            /* 1–3 */
m_large: m_small + gap;

/* Difference */
diff: m_large - m_small;

/* Intensity ratio */
ratio: 10^diff;

/* Distractors (core mistakes) */
m1: diff;
m2: 10^(m_small + m_large);
m3: m_large * m_small;
m4: 10^(m_small);
m5: 10^(m_large);

/* Additional random variables (for STACK richness & variation) */
region1: rand(["Nakuru","Turkana","Garissa","Kisumu","Kitale"]);
region2: rand(["Mombasa","Eldoret","Naivasha","Nyeri","Machakos"]);
