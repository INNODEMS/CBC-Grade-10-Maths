    <questionvariables>
      <text>/* magnitudes */
m1: rand(3) + 4;
m2: m1 + rand(2) + 1;

/* difference */
diff: m2 - m1;

/* ratio of intensity */
ratio: 10^diff;

/* mistakes */
m_wrong1: diff;
m_wrong2: m1 + m2;
m_wrong3: 10^(m1 + m2);</text>
