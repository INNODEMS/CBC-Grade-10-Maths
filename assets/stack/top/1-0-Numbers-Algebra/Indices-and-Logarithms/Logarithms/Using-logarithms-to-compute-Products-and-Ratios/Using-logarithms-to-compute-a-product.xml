    <questionvariables>
      <text>/* Given logarithms */
L_a: float(rand(3000)/10000 + 0.2);
L_b: float(rand(3000)/10000 + 0.2);

/* Sum of logs */
L_sum: L_a + L_b;

/* Final answer (antilog) */
ans: 10^(L_sum);

/* Rounded answer */
ans_round: float(round(ans*1000)/1000);

/* mistakes */
m1: L_sum;
m2: L_a * L_b;
m3: 10^(L_a * L_b);</text>
