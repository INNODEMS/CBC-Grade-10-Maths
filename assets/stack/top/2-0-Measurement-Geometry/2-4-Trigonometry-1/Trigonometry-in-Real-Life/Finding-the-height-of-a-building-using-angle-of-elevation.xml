    <questionvariables>
      <text>/* Distance from object */
d: rand(10) + 10;

/* Angle (choose standard angles for clean values) */
angles: [30,45,60];
theta: angles[rand(3)];

/* Height calculation */
h: if theta=30 then d/sqrt(3)
   elseif theta=45 then d
   else d*sqrt(3);

/* Rounded */
h_round: float(round(h*100)/100);

/* mistakes */
m1: d*tan(theta);   /* incorrect use */
m2: d*cos(theta);
m3: d*sin(theta);</text>
