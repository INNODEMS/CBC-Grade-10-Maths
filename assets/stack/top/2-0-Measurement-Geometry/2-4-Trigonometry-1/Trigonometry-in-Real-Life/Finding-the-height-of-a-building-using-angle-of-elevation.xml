<quiz>
  <question type="stack">
    <name>
      <text>Finding the height of a building using angle of elevation</text>
    </name>
    <questiontext format="moodle_auto_format">
      <text><![CDATA[<p>
A student stands {@d@} m away from a building. The angle of elevation of the top of the building is {@theta@}\(^{\circ}\). Find the height of the building.
</p>

<p>
Give your answer correct to <b>2 decimal places</b>.
</p>

<p>
Height = [[input:ans1]] m [[validation:ans1]] [[feedback:prt1]]
</p>]]></text>
    </questiontext>
    <generalfeedback format="moodle_auto_format">
      <text><![CDATA[<h3>Worked Solution</h3>

<p>
Step 1: Use the tangent ratio:
</p>

<p>
\[
\tan \theta = \frac{\text{height}}{\text{distance}}
\]
</p>

<p>
\[
\tan {@theta@} = \frac{h}{@d@}
\]
</p>

<p>
Step 2: Solve for height:
</p>

<p>
\[
h = {@d@} \times \tan {@theta@}
\]
</p>

<p>
\[
h = {@h_round@} m
\]
</p>]]></text>
    </generalfeedback>
