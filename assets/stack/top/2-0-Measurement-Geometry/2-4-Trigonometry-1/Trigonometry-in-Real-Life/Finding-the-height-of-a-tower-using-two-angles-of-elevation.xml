    <questionvariables>
      <text>/* Angles in degrees for display */
theta1: 30;
theta2: 60;

/* Angles in radians for calculation */
t1: theta1*%pi/180;
t2: theta2*%pi/180;

/* Distance walked closer to the tower */
d: rand(5) + 5;

/* Correct height formula */
h: d * tan(t1) * tan(t2) / (tan(t2) - tan(t1));

/* Rounded answer */
h_round: float(round(h*100)/100);

/* Mistakes */
m1: d*tan(t1);
m2: d*tan(t2);
m3: d*(tan(t2)-tan(t1));</text>
    </questionvariables>
