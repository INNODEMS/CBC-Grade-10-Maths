    <questionvariables>
      <text><![CDATA[/* Core variables */
d: rand(5)*2+12;          /* 14,16,18,20,22 m */
theta: rand(4)*5+30;      /* 35,40,45,50 */
eye: rand(3)+2;           /* observer eye level above deck: 3 to 5 m */

extra: d*tan(theta*%pi/180);   /* vertical drop from eye level to object */
height_total: eye + extra;     /* total height above sea level */
height1: float(round(height_total*10)/10);

/* Context */
structure: rand(["lighthouse","watch tower","harbour post","viewing platform"]);
item: rand(["boat","fishing canoe","buoy","small raft"]);
coast: rand(["Mombasa","Kilifi","Lamu","Malindi"]);

/* Distractors */
m1: extra;                         /* forgot to add eye level */
m2: d/sin(theta*%pi/180);          /* used wrong trig ratio */
m3: d*cos(theta*%pi/180)+eye;      /* wrong trig usage */
m1r: float(round(m1*10)/10);
m2r: float(round(m2*10)/10);
m3r: float(round(m3*10)/10);]]></text>
    </questionvariables>
