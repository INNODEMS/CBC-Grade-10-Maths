    <questionvariables>
      <text><![CDATA[/* Length and width as decimals (1 d.p.) */
l: float((rand(120)+90)/10);   /* 9.0 to 20.0 */
w: float((rand(50)+30)/10);    /* 3.0 to 8.0 */

/* Area */
A: l*w;

/* Rounded answer (2 d.p.) */
A_round: float(round(A*100)/100);

/* Context */
crop: rand(["vegetables","flowers","maize","spinach","kales"]);

/* Mistakes */
m1: 2*(l+w);
m2: l+w;
m3: l^2;]]></text>
