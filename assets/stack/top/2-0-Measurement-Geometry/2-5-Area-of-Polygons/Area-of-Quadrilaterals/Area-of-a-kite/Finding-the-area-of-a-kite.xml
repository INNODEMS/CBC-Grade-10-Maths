    <questionvariables>
      <text>/* Diagonals */
d1 : rand(6) + 10;   /* e.g. 11–16 */
d2 : rand(6) + 8;    /* e.g. 9–14 */

/* Half diagonals */
h1 : d1/2;
h2 : d2/2;

/* Area */
ta1 : (1/2)*d1*d2;

/* Side length using Pythagoras */
ta2 : sqrt(h1^2 + h2^2);

/* Angles (in degrees) */
/* Half-angle using tan */
theta_half : atan(h2/h1);
theta : 2*theta_half;

/* Convert to degrees */
ta_3 : float(2*atan(h2/h1)*180/%pi);
ta3: decimalplaces(ta_3,1);
ta4 : 180 - ta3;</text>
