    <questionvariables>
      <text><![CDATA[/* Sides of triangle */
a: rand(6) + 4;
b: rand(6) + 5;
c: rand(6) + 6;

/* Ensure triangle inequality */
while a + b <= c or a + c <= b or b + c <= a do (
  a: rand(6) + 4,
  b: rand(6) + 5,
  c: rand(6) + 6
);

/* Semi-perimeter */
s: (a + b + c)/2;

/* Area */
A: sqrt(s*(s-a)*(s-b)*(s-c));

/* Rounded */
A_round: float(round(A*100)/100);

/* Mistakes */
m1: s*(s-a)*(s-b)*(s-c);
m2: (a+b+c)/3;
m3: sqrt(a*b*c);]]></text>
    </questionvariables>
