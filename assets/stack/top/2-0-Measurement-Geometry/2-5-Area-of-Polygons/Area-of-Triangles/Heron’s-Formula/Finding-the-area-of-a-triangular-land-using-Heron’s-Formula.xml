    <questionvariables>
      <text><![CDATA[/* Field sides */
a: rand(10) + 15;
b: rand(10) + 18;
c: rand(10) + 20;

/* Ensure triangle inequality */
while a + b <= c or a + c <= b or b + c <= a do (
  a: rand(10) + 15,
  b: rand(10) + 18,
  c: rand(10) + 20
);

/* Semi-perimeter */
s: (a + b + c)/2;

/* Area */
A: sqrt(s*(s-a)*(s-b)*(s-c));

/* Rounded */
A_round: float(round(A*100)/100);

/* Mistakes */
m1: a*b*c;
m2: s*(s-a)*(s-b)*(s-c);
m3: (a+b+c)/2;
m4: sqrt(a*b);]]></text>
