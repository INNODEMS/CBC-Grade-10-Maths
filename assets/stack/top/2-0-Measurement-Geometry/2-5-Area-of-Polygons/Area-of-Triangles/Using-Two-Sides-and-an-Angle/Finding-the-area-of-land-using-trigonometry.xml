    <questionvariables>
      <text>/* Sides (land lengths) */
a: rand(10) + 10;
b: rand(10) + 12;

/* Angle */
angles: [40,50,60,70];
C: angles[rand(4) + 1];

/* Convert to radians */
Cr: C*%pi/180;

/* Area */
A: (1/2)*a*b*sin(Cr);

/* Rounded */
A_round: float(round(A*100)/100);

/* Mistakes */
m1: a*b*sin(Cr);
m2: (1/2)*a*b*cos(Cr);
m3: a*b;
m4: (1/2)*(a+b)*sin(Cr);</text>
    </questionvariables>
