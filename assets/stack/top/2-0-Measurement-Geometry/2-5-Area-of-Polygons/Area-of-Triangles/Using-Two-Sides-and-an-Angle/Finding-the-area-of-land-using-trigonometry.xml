<quiz>
  <question type="stack">
    <name>
      <text>Finding the area of land using trigonometry</text>
    </name>
    <questiontext format="moodle_auto_format">
      <text><![CDATA[<p>
A piece of land is in the shape of a triangle. Two sides measure {@a@} m and {@b@} m, and the angle between them is {@C@}°. Find the area of the land.
</p>

<p>
Give your answer correct to <b>2 decimal places</b>.
</p>

<p>
Area = [[input:ans1]] \(\text{cm}^2\) [[validation:ans1]] [[feedback:prt1]]
</p>]]></text>
    </questiontext>
    <generalfeedback format="moodle_auto_format">
      <text><![CDATA[<h3>Worked Solution</h3>

<p>
Step 1: Use the formula:
</p>

<p>
\[
A = \frac{1}{2}ab\sin C
\]
</p>

<p>
Step 2: Substitute the values:
</p>

<p>
\[
A = \frac{1}{2} \times {@a@} \times {@b@} \times \sin {@C@}^\circ
\]
</p>

<p>
Step 3: Evaluate:
</p>

<p>
\[
A = {@A_round@}\text{ m}^2
\]
</p>

<p>
Therefore, the area of the land is {@A_round@} \(\text{cm}^2\).
</p>]]></text>
    </generalfeedback>
    <defaultgrade>1</defaultgrade>
    <penalty>0.1</penalty>
    <hidden>0</hidden>
    <idnumber/>
    <stackversion>
      <text>2026010500</text>
