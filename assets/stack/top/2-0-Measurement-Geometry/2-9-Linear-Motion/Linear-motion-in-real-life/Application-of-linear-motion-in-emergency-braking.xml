    <questionvariables>
      <text>/* 1. Randomized Initial Conditions */
v_initial: 15 + rand(11);      /* Initial velocity: 15 to 25 m/s */
t_thinking: 0.6 + (rand(6)/10); /* Thinking time: 0.6 to 1.1 s */
t_braking: 4 + rand(4);        /* Time to stop: 4 to 7 s */

/* 2. Linear Motion Calculations */
/* Phase 1: Constant Velocity (Distance = Speed * Time) */
dist_thinking: v_initial * t_thinking;

/* Phase 2: Acceleration (a = (v-u)/t) */
/* Final velocity v is 0 (comes to rest) */
accel: (0 - v_initial) / t_braking;

/* Phase 3: Total Displacement (Sum of both phases) */
/* Using s = ut + 0.5at^2 for the braking phase */
dist_braking: (v_initial * t_braking) + (0.5 * accel * t_braking^2);
total_displacement: dist_braking;

/* 3. Teacher Answers (Teacher values) */
ta1: dist_thinking;
ta2: accel;
ta3: total_displacement;</text>
