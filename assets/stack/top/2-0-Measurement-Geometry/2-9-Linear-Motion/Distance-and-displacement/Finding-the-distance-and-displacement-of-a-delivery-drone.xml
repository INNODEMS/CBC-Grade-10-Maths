    <questionvariables>
      <text>/* 1. Randomized Directions and Distances */
/* We use East as positive, West as negative */
d1: 150 + rand(101);     /* First leg: 150 to 250 m East */
d2: 50 + rand(51);       /* Second leg: 50 to 100 m West */

/* 2. Calculations */
/* Total Distance = sum of absolute magnitudes */
total_dist: d1 + d2;

/* Displacement = Final Position - Initial Position */
/* Since West is negative, we subtract d2 from d1 */
displacement: d1 - d2;

/* 3. Teacher Answers */
ta1: total_dist;
ta2: displacement;</text>
