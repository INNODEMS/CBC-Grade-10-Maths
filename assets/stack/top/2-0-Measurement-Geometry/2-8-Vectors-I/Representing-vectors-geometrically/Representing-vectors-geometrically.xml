    <questionvariables>
      <text>/* 1. Define Points P and Q (for magnitude) */
x1: 1 + rand(3); y1: 1 + rand(3);
x2: x1 + 3 + rand(3); y2: y1 + 3 + rand(3);

/* 2. Vector PQ components and Magnitude */
ta1: x2 - x1;
ta2: y2 - y1;
mag_sq: (ta1^2) + (ta2^2);
ta3: sqrt(mag_sq);

/* 3. Define Vector b (for addition) */
bx: 1 + rand(4);
by: 1 + rand(4);

/* 4. Resultant Vector R = PQ + b */
ta4: ta1 + bx;
ta5: ta2 + by;</text>
