    <questionvariables>
      <text>/* 1. Define vectors a and b (from origin to points A and B) */
ax: 5 + rand(5);  /* x-component of a: 5 to 9 */
ay: 2 + rand(3);  /* y-component of a: 2 to 4 */
bx: 1 + rand(3);  /* x-component of b: 1 to 3 */
by: 5 + rand(4);  /* y-component of b: 5 to 8 */

/* 2. Subtraction Operation: R = a - b */
ta1: ax - bx;
ta2: ay - by;

/* 3. Magnitude Calculation for the Resultant */
mag_sq: (ta1^2) + (ta2^2);
ta3: sqrt(mag_sq);</text>
    </questionvariables>
