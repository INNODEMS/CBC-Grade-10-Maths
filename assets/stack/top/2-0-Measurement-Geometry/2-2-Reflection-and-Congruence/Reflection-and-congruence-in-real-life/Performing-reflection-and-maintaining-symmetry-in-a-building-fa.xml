    <questionvariables>
      <text><![CDATA[/* 1. Define possible x and y coordinates for features */
/* Features must be on the left side (negative x) */
x_pool: [-5, -4, -3, -2];
y_pool: [0, 1, 2, 3, 4, 5, 6];

/* Shuffle to pick unique locations for a window and a door */
x_coords: random_permutation(x_pool);
y_coords: random_permutation(y_pool);

/* Feature 1: Window (W) */
w_left: [x_coords[1], y_coords[1]];
/* Feature 2: Door (D) */
d_left: [x_coords[2], y_coords[2]];

/* 2. Reflection across the Axis of Symmetry (x = 0) */
/* Rule: (x, y) -> (-x, y) */
w_right: [-w_left[1], w_left[1]];
d_right: [-d_left[1], d_left[1]];
ta1:[-w_left[1], w_left[2]];
ta2:[-d_left[1], d_left[2]];

/* 3. Dropdown Options for Congruence */
ta:random_permutation([["True", true], ["False", false]]);
]]></text>
