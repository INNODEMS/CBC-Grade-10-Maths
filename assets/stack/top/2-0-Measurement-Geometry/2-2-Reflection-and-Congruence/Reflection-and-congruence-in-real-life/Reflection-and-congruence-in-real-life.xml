    <questionvariables>
      <text><![CDATA[/* Define vertices of a triangular flower bed in the first quadrant */
/* Randomizing to ensure a unique triangle for each student */
x1: 1 + rand(2);   /* 1 or 2 */
y1: 1 + rand(2);   /* 1 or 2 */
x2: x1 + 2 + rand(2);
y2: y1;
x3: x1 + 1;
y3: y1 + 3 + rand(2);

/* Reflection across the y-axis (x -> -x) */
rx1: -x1; ry1: y1;
rx2: -x2; ry2: y2;
rx3: -x3; ry3: y3;

/* Teacher Answers for the coordinates */
ta_v1: [rx1, ry1];
ta_v2: [rx2, ry2];
ta_v3: [rx3, ry3];

/* Congruence check (always true for reflection) */
ta:random_permutation([["yes", true],["no", false]]);
]]></text>
